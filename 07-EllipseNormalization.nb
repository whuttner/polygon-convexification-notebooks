Notebook[{

Cell[CellGroupData[{
Cell["EllipseNormalization", "Title",ExpressionUUID->"1ea58a63-0a29-4617-826e-4957e76b745a"],

Cell["Canonical normalization of first-harmonic ellipses", "Subtitle",ExpressionUUID->"bb63ca51-355c-4b4d-ab41-50d288c1dc87"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"84f4b55b-d9da-431a-95fb-21ede4c02af6"],

Cell[TextData[{
 "This notebook supports the ellipse-normalization material in Chapter 3. It \
extracts the first-harmonic ellipse determined by ",
 Cell[BoxData[
  SubscriptBox["c", "1"]], "InlineFormula",ExpressionUUID->
  "98441ccf-23cb-4a87-947f-ff351770d3d1"],
 " and ",
 Cell[BoxData[
  SubscriptBox["c", 
   RowBox[{"n", "-", "1"}]]], "InlineFormula",ExpressionUUID->
  "75ae90e0-20c7-44c3-9a58-4fdbd6e421fc"],
 ", computes its semi-axes and orientation, and constructs canonical affine \
normalizations."
}], "Text",ExpressionUUID->"0712bf66-565b-44e8-a2ff-979951639554"],

Cell["\<\
All executable cells are ordinary Wolfram Language Input cells. Typeset box \
expressions appear only in explanatory cells.\
\>", "Text",ExpressionUUID->"9f8d18f0-2e2e-4d7a-957d-3a2769cc2a78"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Fourier and pair-plane definitions", "Section",ExpressionUUID->"0af1dda3-48ce-4870-af4a-882e1b3d7574"],

Cell["\<\
ClearAll[\"Global`*\"];

omega[n_Integer?Positive] := Exp[2 Pi I/n];

fourierVector[n_Integer?Positive, k_Integer] :=
  Table[omega[n]^(j k), {j, 0, n - 1}]/Sqrt[n];

fourierMatrix[n_Integer?Positive] :=
  Transpose@Table[fourierVector[n, k], {k, 0, n - 1}];

fourierCoefficients[p_List] := Module[{F},
  F = fourierMatrix[Length[p]];
  ConjugateTranspose[F] . N[p]
];

fourierSynthesis[c_List] :=
  fourierMatrix[Length[c]] . c;

centerPolygon[p_List] :=
  N[p] - Mean[N[p]];

firstHarmonicData[p_List] := Module[{n, c},
  n = Length[p];
  c = fourierCoefficients[p];
  <|
    \"c1\" -> c[[2]],
    \"cNMinus1\" -> c[[n]]
  |>
];

pairPlaneProjection[p_List] := Module[{n, c, result},
  n = Length[p];
  c = fourierCoefficients[p];
  result = ConstantArray[0, n];
  result[[2]] = c[[2]];
  result[[n]] = c[[n]];
  fourierSynthesis[result]
];\
\>", "Input",
 CellLabel->
  "In[2606]:=",ExpressionUUID->"73e9ec0c-adc3-4d73-80af-a111c811aac1"],

Cell["\<\
nExample = 12;
SeedRandom[4040];
pExample = RandomReal[{-1, 1}, nExample] + I RandomReal[{-1, 1}, nExample];
pExample = centerPolygon[pExample];
pEllipse = pairPlaneProjection[pExample];\
\>", "Input",
 CellLabel->
  "In[2623]:=",ExpressionUUID->"a4882e3e-fea5-479b-9d65-9b5e3380a5a8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Continuous ellipse determined by the first harmonic", "Section",ExpressionUUID->"f2006c28-8ae1-4bea-9593-7b9668699dbb"],

Cell["\<\
Ignoring the common Fourier normalization, the first-harmonic curve is\
\>", "Text",ExpressionUUID->"17ee7abc-818e-4570-a46d-91425ca9d632"],

Cell[BoxData[
 FormBox[
  RowBox[{"z", 
   RowBox[{"(", "t", ")"}], "=", 
   SubscriptBox["c", "1"], 
   SuperscriptBox["e", 
    RowBox[{"i", "t"}]], "+", 
   SubscriptBox["c", 
    RowBox[{"n", "-", "1"}]], 
   SuperscriptBox["e", 
    RowBox[{"-", "i", "t"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"8ddfeee9-b38e-4641-be68-4383370beca1"],

Cell["\<\
ellipseCurve[c1_, cN_, t_] :=
  c1 Exp[I t] + cN Exp[-I t];

ellipseSample[n_Integer?Positive, c1_, cN_] :=
  Table[ellipseCurve[c1, cN, 2 Pi j/n], {j, 0, n - 1}];\
\>", "Input",
 CellLabel->
  "In[2628]:=",ExpressionUUID->"a949947d-3445-49d2-b9b1-c490c0db4881"],

Cell["\<\
dataExample = firstHarmonicData[pExample];
c1Example = dataExample[\"c1\"];
cNExample = dataExample[\"cNMinus1\"];\
\>", "Input",
 CellLabel->
  "In[2631]:=",ExpressionUUID->"c5934963-4f07-482b-986c-53746d8273f4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Semi-axis lengths", "Section",ExpressionUUID->"31421418-8d03-431b-93fe-0efd2677dbae"],

Cell["The semi-axis lengths of the ellipse are", "Text",ExpressionUUID->"d509a33b-323d-4cf6-9dea-917d79a01016"],

Cell[BoxData[
 FormBox[
  RowBox[{"a", "=", 
   RowBox[{"|", 
    SubscriptBox["c", "1"], "|"}], "+", 
   RowBox[{"|", 
    SubscriptBox["c", 
     RowBox[{"n", "-", "1"}]], "|"}], ",", "\[ThickSpace]", "b", "=", 
   RowBox[{"|", 
    RowBox[{
     RowBox[{"|", 
      SubscriptBox["c", "1"], "|"}], "-", 
     RowBox[{"|", 
      SubscriptBox["c", 
       RowBox[{"n", "-", "1"}]], "|"}]}], "|"}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"2550d4ac-e9b2-4ae0-\
801c-c49eb7acf520"],

Cell["\<\
ellipseSemiAxesFromCoefficients[c1_, cN_] := Module[{a, b},
  a = Abs[c1] + Abs[cN];
  b = Abs[Abs[c1] - Abs[cN]];
  {a, b}
];

ellipseSemiAxes[p_List] := Module[{data},
  data = firstHarmonicData[p];
  ellipseSemiAxesFromCoefficients[data[\"c1\"], data[\"cNMinus1\"]]
];\
\>", "Input",
 CellLabel->
  "In[2634]:=",ExpressionUUID->"c2052f1e-6b52-44ee-819a-a91cf52edb38"],

Cell[CellGroupData[{

Cell["\<\
axesExample = ellipseSemiAxes[pExample];
axesExample\
\>", "Input",
 CellLabel->
  "In[2637]:=",ExpressionUUID->"91ce24a8-f76a-4103-b8c5-bbdee3b1e7b3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2.0802076063767707`", ",", "1.1406000090183241`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.9928049651600647`*^9},
 CellLabel->
  "Out[2638]=",ExpressionUUID->"480a2762-38a5-48a0-8312-3d55342e7714"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Nondegeneracy and eccentricity", "Section",ExpressionUUID->"12ae70ae-d70d-4651-9ec7-8907aae84b54"],

Cell["\<\
nondegenerateEllipseQ[c1_, cN_, tol_: 10^-10] :=
  TrueQ[Abs[Abs[c1] - Abs[cN]] > tol];

ellipseEccentricity[c1_, cN_] := Module[{a, b},
  {a, b} = ellipseSemiAxesFromCoefficients[c1, cN];
  If[a == 0, Indeterminate, Sqrt[Max[0, 1 - (b/a)^2]]]
];

ellipseAxisRatio[c1_, cN_] := Module[{a, b},
  {a, b} = ellipseSemiAxesFromCoefficients[c1, cN];
  If[b == 0, Infinity, a/b]
];\
\>", "Input",
 CellLabel->
  "In[2639]:=",ExpressionUUID->"a9a98249-ac97-4ec8-a6cd-548ba6f732da"],

Cell[CellGroupData[{

Cell["\<\
{
  nondegenerateEllipseQ[c1Example, cNExample],
  ellipseEccentricity[c1Example, cNExample],
  ellipseAxisRatio[c1Example, cNExample]
}\
\>", "Input",
 CellLabel->
  "In[2644]:=",ExpressionUUID->"3a9e27ba-440c-4b39-8e94-58dc401ded75"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "0.8362747265837804`", ",", "1.8237836138254417`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.9928049651664267`*^9},
 CellLabel->
  "Out[2644]=",ExpressionUUID->"c68a58df-f5e7-4c99-8c25-17ff40d063dc"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. Orientation angles", "Section",ExpressionUUID->"2847ddea-5cc2-4852-aa08-a9b79d07731f"],

Cell[TextData[{
 "Writing ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["c", "1"], "=", 
   RowBox[{
    SubscriptBox["r", "1"], 
    SuperscriptBox["e", 
     RowBox[{"i", 
      SubscriptBox["\[Theta]", "1"]}]]}]}]], "InlineFormula",ExpressionUUID->
  "b27a637c-d126-4dd7-b994-17f2cd9969de"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["c", 
    RowBox[{"n", "-", "1"}]], "=", 
   RowBox[{
    SubscriptBox["r", "2"], 
    SuperscriptBox["e", 
     RowBox[{"i", 
      SubscriptBox["\[Theta]", "2"]}]]}]}]], "InlineFormula",ExpressionUUID->
  "60d45e3b-80ec-4ed0-9f80-d095f7a3247c"],
 ", the ellipse orientation and phase parameters are"
}], "Text",ExpressionUUID->"983da9eb-bd2d-44f0-9666-9390d21fcdad"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[Psi]", "=", 
   FractionBox[
    RowBox[{
     SubscriptBox["\[Theta]", "1"], "+", 
     SubscriptBox["\[Theta]", "2"]}], "2"], ",", "\[ThickSpace]", "\[Delta]", 
   "=", 
   FractionBox[
    RowBox[{
     SubscriptBox["\[Theta]", "1"], "-", 
     SubscriptBox["\[Theta]", "2"]}], "2"]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"13f566df-71fa-4cfa-\
bfd4-cdc0ef59902c"],

Cell["\<\
ellipseOrientationData[c1_, cN_] := Module[{theta1, thetaN},
  theta1 = Arg[c1];
  thetaN = Arg[cN];
  <|
    \"Orientation\" -> (theta1 + thetaN)/2,
    \"Phase\" -> (theta1 - thetaN)/2
  |>
];\
\>", "Input",
 CellLabel->
  "In[2645]:=",ExpressionUUID->"68b94419-15ac-44ba-b5b7-4e73c8c9da74"],

Cell[CellGroupData[{

Cell["\<\
orientationExample = ellipseOrientationData[c1Example, cNExample];
orientationExample\
\>", "Input",
 CellLabel->
  "In[2646]:=",ExpressionUUID->"a39a153c-0189-4dd8-aa18-38459a86f225"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Orientation\"\>", "\[Rule]", "0.499665142418078`"}], ",", 
   RowBox[{"\<\"Phase\"\>", "\[Rule]", 
    RowBox[{"-", "1.7573482153501612`"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.992804965171488*^9},
 CellLabel->
  "Out[2647]=",ExpressionUUID->"521f9ca8-22c9-4911-b661-f05ff3a381af"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Axis-aligned parametrization", "Section",ExpressionUUID->"ed0ab744-4f20-46ce-b621-4186ef5f72d6"],

Cell["\<\
After removing the orientation angle, the curve becomes an axis-aligned \
ellipse:\
\>", "Text",ExpressionUUID->"48e53c2c-84be-46b5-a8a1-1961ae54bd28"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["e", 
    RowBox[{"-", "i", "\[Psi]"}]], "z", 
   RowBox[{"(", "t", ")"}], "=", "a", 
   RowBox[{"cos", 
    RowBox[{"(", 
     RowBox[{"t", "+", "\[Delta]"}], ")"}]}], "+", "i", "b", 
   RowBox[{"sin", 
    RowBox[{"(", 
     RowBox[{"t", "+", "\[Delta]"}], ")"}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"3590a68e-7dbc-46b5-\
956b-2e85e8ba8d66"],

Cell["\<\
axisAlignedCurve[c1_, cN_, t_] := Module[{angles, psi},
  angles = ellipseOrientationData[c1, cN];
  psi = angles[\"Orientation\"];
  Exp[-I psi] ellipseCurve[c1, cN, t]
];

axisAlignedModel[c1_, cN_, t_] := Module[{axes, angles, a, b, delta, sign},
  axes = ellipseSemiAxesFromCoefficients[c1, cN];
  angles = ellipseOrientationData[c1, cN];
  {a, b} = axes;
  delta = angles[\"Phase\"];
  sign = Sign[Abs[c1] - Abs[cN]];
  a Cos[t + delta] + I sign b Sin[t + delta]
];\
\>", "Input",
 CellLabel->
  "In[2648]:=",ExpressionUUID->"047cb43e-eab8-4f00-8320-0c543d4dc448"],

Cell["\<\
axisAlignmentError = Max@Table[
  Abs[N[
    axisAlignedCurve[c1Example, cNExample, t] -
    axisAlignedModel[c1Example, cNExample, t]
  ]],
  {t, 0., 2 Pi, 2 Pi/100}
];
axisAlignmentQ = axisAlignmentError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2651]:=",ExpressionUUID->"fa3031ba-7d9b-4452-9466-654520e3cd9e"],

Cell[CellGroupData[{

Cell["axisAlignmentError", "Input",
 CellLabel->
  "In[2653]:=",ExpressionUUID->"0b4620f2-6117-436f-8447-11074b3e91fb"],

Cell[BoxData["6.753223014464259`*^-16"], "Output",
 CellChangeTimes->{3.992804965193665*^9},
 CellLabel->
  "Out[2653]=",ExpressionUUID->"9ed6a3e3-ef19-4e6d-a7c6-eb4821585cd7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["axisAlignmentQ", "Input",
 CellLabel->
  "In[2654]:=",ExpressionUUID->"335350d5-68ff-42b8-bb5d-406aef7ce314"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992804965197612*^9},
 CellLabel->
  "Out[2654]=",ExpressionUUID->"000c23bb-5a0d-451e-9891-b9e36efddef1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["7. Real-linear anisotropy map", "Section",ExpressionUUID->"c0a01833-65c8-4339-ab4f-8de2642c7295"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{"z", "=", 
   RowBox[{"x", "+", "i", "y"}]}]], "InlineFormula",ExpressionUUID->
  "36f5a429-8f99-4640-a33f-1d1484d13337"],
 ", define"
}], "Text",ExpressionUUID->"d1f0ca09-b6c6-4903-ae66-22459084db85"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["D", "r"], 
   RowBox[{"(", "z", ")"}], "=", "x", "+", "i", "r", "y"}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"e6589c5b-5e76-44be-\
89c9-1e5e77c0ddb3"],

Cell["\<\
dilationD[z_, r_?NumericQ] :=
  Re[z] + I r Im[z];

inverseDilationD[z_, r_?NumericQ] :=
  Re[z] + I Im[z]/r;\
\>", "Input",
 CellLabel->
  "In[2655]:=",ExpressionUUID->"db666352-944f-4344-9671-8cccf46147f9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["8. Normalization to a circle", "Section",ExpressionUUID->"d7886fd6-640c-4b24-92d0-220d09b18d8c"],

Cell[TextData[{
 "For a nondegenerate ellipse with semi-axes ",
 Cell[BoxData[
 "a"], "InlineFormula",ExpressionUUID->"a60eb036-d854-4af5-9594-895406a8eb96"],
 " and ",
 Cell[BoxData[
 "b"], "InlineFormula",ExpressionUUID->"6c64cf8f-449e-438c-9f09-1111fbb0e0cc"],
 ", rotate by ",
 Cell[BoxData[
  RowBox[{"-", "\[Psi]"}]], "InlineFormula",ExpressionUUID->
  "3bf94070-2a00-4a70-9820-cfefa82277d1"],
 ", divide by ",
 Cell[BoxData[
 "a"], "InlineFormula",ExpressionUUID->"5123bdc9-83dc-48f6-b5da-d9260c7bd65c"],
 ", and scale the imaginary direction by ",
 Cell[BoxData[
  RowBox[{"a", "/", "b"}]], "InlineFormula",ExpressionUUID->
  "5456afae-653f-4ea6-8118-596e3217a486"],
 "."
}], "Text",ExpressionUUID->"834ad8d6-638e-4eb2-84e6-2e57a1f69bb3"],

Cell["\<\
ellipseNormalizationParameters[c1_, cN_] := Module[{axes, angles, a, b},
  axes = ellipseSemiAxesFromCoefficients[c1, cN];
  angles = ellipseOrientationData[c1, cN];
  {a, b} = axes;
  If[b < 10^-12, Return[Missing[\"DegenerateEllipse\"]]];
  <|
    \"MajorAxis\" -> a,
    \"MinorAxis\" -> b,
    \"Orientation\" -> angles[\"Orientation\"],
    \"Phase\" -> angles[\"Phase\"],
    \"Anisotropy\" -> a/b
  |>
];

normalizeEllipsePoint[z_, params_Association] := Module[{rotated},
  rotated = Exp[-I params[\"Orientation\"]] z/params[\"MajorAxis\"];
  dilationD[rotated, params[\"Anisotropy\"]]
];

inverseNormalizeEllipsePoint[z_, params_Association] := Module[{undilated},
  undilated = inverseDilationD[z, params[\"Anisotropy\"]];
  params[\"MajorAxis\"] Exp[I params[\"Orientation\"]] undilated
];\
\>", "Input",
 CellLabel->
  "In[2658]:=",ExpressionUUID->"6bb469d5-53ad-474a-a78e-a6c9f91505a3"],

Cell[CellGroupData[{

Cell["\<\
normalizationParamsExample = ellipseNormalizationParameters[c1Example, \
cNExample];
normalizationParamsExample\
\>", "Input",
 CellLabel->
  "In[2663]:=",ExpressionUUID->"dac29aff-b16f-421e-90ac-ec221f5a773a"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"MajorAxis\"\>", "\[Rule]", "2.0802076063767707`"}], ",", 
   RowBox[{"\<\"MinorAxis\"\>", "\[Rule]", "1.1406000090183241`"}], ",", 
   RowBox[{"\<\"Orientation\"\>", "\[Rule]", "0.499665142418078`"}], ",", 
   RowBox[{"\<\"Phase\"\>", "\[Rule]", 
    RowBox[{"-", "1.7573482153501612`"}]}], ",", 
   RowBox[{"\<\"Anisotropy\"\>", "\[Rule]", "1.8237836138254417`"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.9928049652083693`*^9},
 CellLabel->
  "Out[2664]=",ExpressionUUID->"dae48934-d973-4c4a-bc72-0a0cdd975d5f"]
}, Open  ]],

Cell["\<\
normalizationInverseError = Max@Table[
  Abs[N[
    inverseNormalizeEllipsePoint[
      normalizeEllipsePoint[ellipseCurve[c1Example, cNExample, t], \
normalizationParamsExample],
      normalizationParamsExample
    ] - ellipseCurve[c1Example, cNExample, t]
  ]],
  {t, 0., 2 Pi, 2 Pi/100}
];
normalizationInverseQ = normalizationInverseError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2665]:=",ExpressionUUID->"183f9408-43b6-4eec-ae0b-29160e66daf5"],

Cell[CellGroupData[{

Cell["normalizationInverseError", "Input",
 CellLabel->
  "In[2667]:=",ExpressionUUID->"8e460e68-86ac-432b-aefe-5ad4479456c6"],

Cell[BoxData["4.965068306494546`*^-16"], "Output",
 CellChangeTimes->{3.992804965213991*^9},
 CellLabel->
  "Out[2667]=",ExpressionUUID->"9bfbf94e-1529-4d11-a6df-4037d08f5f9c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["normalizationInverseQ", "Input",
 CellLabel->
  "In[2668]:=",ExpressionUUID->"ba08341b-fc25-493a-b253-854cc3a186ea"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992804965217059*^9},
 CellLabel->
  "Out[2668]=",ExpressionUUID->"6d1382f0-5dcc-413a-9a17-867146e0df1e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["9. Normalized curve is the unit circle", "Section",ExpressionUUID->"32f11835-424b-4d1a-bc66-c4322fef1c32"],

Cell["\<\
normalizedCurve[c1_, cN_, t_, params_Association] :=
  normalizeEllipsePoint[ellipseCurve[c1, cN, t], params];

unitCircleError = Max@Table[
  Abs[N[Abs[normalizedCurve[c1Example, cNExample, t, \
normalizationParamsExample]] - 1]],
  {t, 0., 2 Pi, 2 Pi/100}
];
unitCircleQ = unitCircleError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2669]:=",ExpressionUUID->"002da549-07e2-45c2-bcbe-2b8e63f391f9"],

Cell[CellGroupData[{

Cell["unitCircleError", "Input",
 CellLabel->
  "In[2673]:=",ExpressionUUID->"03da4b88-c11f-40a4-ae68-1fb9095ad560"],

Cell[BoxData["3.3306690738754696`*^-16"], "Output",
 CellChangeTimes->{3.992804965225943*^9},
 CellLabel->
  "Out[2673]=",ExpressionUUID->"59ec7016-8c68-4c45-90c9-9df3fd390adc"]
}, Open  ]],

