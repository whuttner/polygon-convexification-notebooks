Cell[CellGroupData[{

Cell["10. Canonical axis-aligned ellipse", "Section",ExpressionUUID->"a85061f2-9ae7-4b14-9cf1-00ae5fb1af49"],

Cell[TextData[{
 "A less aggressive normalization removes only translation, orientation, and \
overall scale. The result has major semi-axis ",
 Cell[BoxData[
 "1"], "InlineFormula",ExpressionUUID->"0be54cef-1bd1-4f01-91a9-0436c00cebdb"],
 " and minor semi-axis ",
 Cell[BoxData[
  RowBox[{"b", "/", "a"}]], "InlineFormula",ExpressionUUID->
  "ca45dc3c-e983-4839-9340-791812f978b9"],
 "."
}], "Text",ExpressionUUID->"1bf22caf-f12d-4260-a611-1506bd00e77c"],

Cell["\<\
canonicalEllipsePoint[z_, params_Association] :=
  Exp[-I params[\"Orientation\"]] z/params[\"MajorAxis\"];

canonicalMinorAxis[params_Association] :=
  params[\"MinorAxis\"]/params[\"MajorAxis\"];\
\>", "Input",
 CellLabel->
