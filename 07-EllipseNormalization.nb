      c1Example,
      cNExample,
      canonicalEllipsePoint[#, normalizationParamsExample] &,
      \"Canonical axis-aligned ellipse\"
    ],
    ellipseCurveGraphic[
      c1Example,
      cNExample,
      normalizeEllipsePoint[#, normalizationParamsExample] &,
      \"Normalized unit circle\"
    ]
  },
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
