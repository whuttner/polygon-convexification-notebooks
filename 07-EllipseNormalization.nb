Cell["12. Continuous normalization comparison", "Section",ExpressionUUID->"de853589-d71e-4cf0-b6c7-bfacae94398e"],

Cell[CellGroupData[{

Cell["\<\
GraphicsRow[
  {
    ellipseCurveGraphic[c1Example, cNExample, Identity, \"Original \
ellipse\"],
