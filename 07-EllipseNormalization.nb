Cell[CellGroupData[{

Cell["13. Invariants under rotation and scaling", "Section",ExpressionUUID->"c4b5eb85-544b-4bea-aa86-12fcbade1512"],

Cell[TextData[{
 "The axis ratio and eccentricity are unchanged by a nonzero complex scaling ",
 Cell[BoxData[
  RowBox[{"z", "\[Function]", "\[Eta]", "z"}]], "InlineFormula",
  ExpressionUUID->"a5808523-b5f3-4148-bccd-f95def44b50d"],
 "."
}], "Text",ExpressionUUID->"cb6d151f-00b6-4f14-90ba-540a9a1acc50"],

Cell["\<\
etaExample = 2.4 Exp[0.7 I];
scaledC1 = etaExample c1Example;
scaledCN = etaExample cNExample;

invariantErrors = {
  Abs[N[ellipseAxisRatio[c1Example, cNExample] - ellipseAxisRatio[scaledC1, \
scaledCN]]],
  Abs[N[ellipseEccentricity[c1Example, cNExample] - \
ellipseEccentricity[scaledC1, scaledCN]]]
};
invariantQ = Max[invariantErrors] < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2689]:=",ExpressionUUID->"615b86ff-5f35-4a8a-89eb-5e858b41c7f3"],

Cell[CellGroupData[{

Cell["invariantErrors", "Input",
 CellLabel->
  "In[2695]:=",ExpressionUUID->"041ed5ad-ebae-4be4-a523-1dc8fb2d1abb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2.220446049250313`*^-16", ",", "0.`"}], "}"}]], "Output",
 CellChangeTimes->{3.992804968044013*^9},
 CellLabel->
  "Out[2695]=",ExpressionUUID->"b4b7a8c3-b362-41d7-b4af-8f2314b02638"]
}, Open  ]],

