Cell[CellGroupData[{

Cell["Conclusion", "Section",ExpressionUUID->"7687669f-aada-408c-9f2b-060449e18334"],

Cell["\<\
The first-harmonic coefficients determine the ellipse completely. Their \
magnitudes determine the semi-axis lengths, their arguments determine \
orientation and phase, and a real-linear anisotropic normalization sends \
every nondegenerate first-harmonic ellipse to the unit circle. \
Rotation-and-scale invariants such as axis ratio and eccentricity are \
preserved under complex similarities.\
\>", "Text",ExpressionUUID->"55623225-346f-4b4b-8452-739b21365833"]
}, Open  ]]
}, Open  ]]
},
Saveable->True,
WindowSize->{808, 911},
