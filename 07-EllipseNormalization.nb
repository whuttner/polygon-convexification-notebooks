Cell["unitCircleQ", "Input",
 CellLabel->
  "In[2674]:=",ExpressionUUID->"1daacf89-f9f6-416a-b33d-af41ec18a89e"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992804965233032*^9},
 CellLabel->
  "Out[2674]=",ExpressionUUID->"e7208472-a6de-47a4-aef5-d390cfea1d44"]
}, Open  ]]
