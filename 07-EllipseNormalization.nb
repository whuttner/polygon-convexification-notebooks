Cell[CellGroupData[{

Cell["14. Canonical reconstruction", "Section",ExpressionUUID->"3dd740d8-d209-49e1-bef0-de4178175378"],

Cell["\<\
reconstructFromCanonical[z_, params_Association] :=
  params[\"MajorAxis\"] Exp[I params[\"Orientation\"]] z;

canonicalReconstructionError = Max@Table[
  Abs[N[
    reconstructFromCanonical[
      canonicalEllipsePoint[ellipseCurve[c1Example, cNExample, t], \
normalizationParamsExample],
      normalizationParamsExample
    ] - ellipseCurve[c1Example, cNExample, t]
  ]],
  {t, 0., 2 Pi, 2 Pi/100}
];
canonicalReconstructionQ = canonicalReconstructionError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2697]:=",ExpressionUUID->"3f728441-6d79-43eb-af9c-8cc14d00ddb7"],

Cell[CellGroupData[{

Cell["canonicalReconstructionError", "Input",
 CellLabel->
  "In[2701]:=",ExpressionUUID->"42d98508-b349-4a59-b9ed-28bc841ade50"],

Cell[BoxData["4.965068306494546`*^-16"], "Output",
 CellChangeTimes->{3.992804968052463*^9},
 CellLabel->
  "Out[2701]=",ExpressionUUID->"8a7d3c12-f4d5-41f3-9f8a-a710c1b5de13"]
}, Open  ]],

