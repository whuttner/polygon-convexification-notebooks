Cell[CellGroupData[{

Cell["6. First strictly convex iterate", "Section",ExpressionUUID->"c472538d-4cb9-4c17-ad80-e083505984af"],

Cell["\<\
Clear[firstStrictConvexTime];

firstStrictConvexTime[p_List, alpha_?NumericQ] :=
  firstStrictConvexTime[p, alpha, 500];

firstStrictConvexTime[p_List, alpha_?NumericQ, maxM_] /; NumericQ[maxM] := \
Module[
  {iterate, limit, m},
  iterate = N[p];
  limit = Max[0, Round[maxM]];
  For[m = 0, m <= limit, m++,
    If[TrueQ[strictlyConvexQ[iterate]], Return[m]];
    iterate = applyA[iterate, alpha];
  ];
  Missing[\"NotFound\", limit]
];\
\>", "Input",
 CellLabel->
  "In[2441]:=",ExpressionUUID->"6eda5083-6c65-4dd5-8dfb-a63ec9c5d3f3"],

Cell[CellGroupData[{

Cell["Length[DownValues[firstStrictConvexTime]]", "Input",
