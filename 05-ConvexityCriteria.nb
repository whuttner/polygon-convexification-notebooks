Cell[CellGroupData[{

Cell["2. Edge vectors and signed turn areas", "Section",ExpressionUUID->"bd0e01a7-9e1b-4e35-bda0-ae58c3921a95"],

Cell[TextData[{
 "For consecutive edges ",
 Cell[BoxData[
  SubscriptBox["e", "j"]], "InlineFormula",ExpressionUUID->
  "6694ba11-21d4-4138-b92e-1522a52df3f9"],
 " and ",
 Cell[BoxData[
  SubscriptBox["e", 
   RowBox[{"j", "+", "1"}]]], "InlineFormula",ExpressionUUID->
  "78c6c786-130a-4c52-8ef0-5fc765b4fb8e"],
 ", the signed planar determinant is"
}], "Text",ExpressionUUID->"8ae6cab1-8b53-492d-b855-52cee46ae200"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[CapitalDelta]", "j"], "=", 
   RowBox[{"Im", "(", 
    RowBox[{
     OverscriptBox[
      SubscriptBox["e", "j"], "_"], 
     SubscriptBox["e", 
      RowBox[{"j", "+", "1"}]]}], ")"}]}], TraditionalForm]], "DisplayFormula",\
ExpressionUUID->"85c87a3f-b2f9-4b0b-82bf-2ed08742e689"],

Cell["\<\
edges[p_List] :=
  RotateLeft[N[p]] - N[p];

signedTurnAreas[p_List] := Module[{e, n},
  e = edges[p];
  n = Length[e];
  Chop@N@Table[
    Im[Conjugate[e[[j]]] e[[Mod[j, n] + 1]]],
    {j, 1, n}
  ]
];\
\>", "Input",
 CellLabel->
  "In[2415]:=",ExpressionUUID->"2c93bdb4-6c35-4c0e-98cb-d080fcb9aaaf"],

Cell[CellGroupData[{

Cell["\<\
q = regularPolygon[9];
signedTurnAreas[q]\
\>", "Input",
 CellLabel->
  "In[2418]:=",ExpressionUUID->"ce54ab6c-420f-4bfd-969a-b99d1d5a3644"],

Cell[BoxData[
 RowBox[{"{", 
