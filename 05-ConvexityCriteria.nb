}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Orientation-sensitive convexity tests", "Section",ExpressionUUID->"766954ed-d097-4fdd-bde5-b4cc7368b40e"],

Cell["\<\
strictlyConvexCCWQ[p_List, tol_: 10^-10] := Module[{a},
  a = signedTurnAreas[p];
  TrueQ[Min[a] > tol]
];

strictlyConvexCWQ[p_List, tol_: 10^-10] := Module[{a},
  a = signedTurnAreas[p];
  TrueQ[Max[a] < -tol]
];

strictlyConvexQ[p_List, tol_: 10^-10] :=
  TrueQ[strictlyConvexCCWQ[p, tol] || strictlyConvexCWQ[p, tol]];

weaklyConvexQ[p_List, tol_: 10^-10] := Module[{a},
  a = signedTurnAreas[p];
  TrueQ[Min[a] >= -tol || Max[a] <= tol]
];

orientation[p_List, tol_: 10^-10] := Which[
  strictlyConvexCCWQ[p, tol], \"Counterclockwise\",
  strictlyConvexCWQ[p, tol], \"Clockwise\",
  True, \"Mixed or degenerate\"
];\
\>", "Input",
 CellLabel->
  "In[2420]:=",ExpressionUUID->"9eba9bd4-14c3-4fdd-9937-2cf266b280cc"],

Cell[CellGroupData[{

Cell["\<\
{
  strictlyConvexCCWQ[q],
  strictlyConvexCWQ[q],
  strictlyConvexQ[q],
  orientation[q]
}\
\>", "Input",
 CellLabel->
  "In[2429]:=",ExpressionUUID->"443f1e32-133c-45c3-936a-857523d226bc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "True", ",", "False", ",", "True", ",", "\<\"Counterclockwise\"\>"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992803273158342*^9},
 CellLabel->
  "Out[2429]=",ExpressionUUID->"20b8be65-576d-403f-bbe4-465ffeb8d9a4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
qReverse = Reverse[q];
{
  strictlyConvexCCWQ[qReverse],
  strictlyConvexCWQ[qReverse],
  strictlyConvexQ[qReverse],
  orientation[qReverse]
}\
\>", "Input",
 CellLabel->
  "In[2430]:=",ExpressionUUID->"a765fddc-c179-42e1-9653-506c55ffcb79"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"False", ",", "True", ",", "True", ",", "\<\"Clockwise\"\>"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992803273162182*^9},
 CellLabel->
  "Out[2431]=",ExpressionUUID->"699faf69-730d-4511-9c38-8b2925342e00"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Examples of convex, concave, and degenerate polygons", "Section",ExpressionUUID->"50919d5e-1c1c-4bd8-b591-569d752536bc"],

Cell["\<\
convexExample = regularPolygon[8];
concaveExample = {0, 2, 1 + 0.4 I, 2 I, 0.2 + 1.2 I};
degenerateExample = {0, 1, 2, 2 + I, I};\
\>", "Input",
 CellLabel->
