Notebook[{

Cell[CellGroupData[{
Cell["ConvexificationScaling", "Title",ExpressionUUID->"7bc14145-2a0a-48e8-9fc0-483bc1bb25a8"],

Cell["\<\
Empirical scaling of convexification time under polygon averaging\
\>", "Subtitle",ExpressionUUID->"67f5612d-5c7c-4c8a-95de-c8d3bd1c1b14"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"1fed9dc4-4e9f-4b10-a923-3db80c319f10"],

Cell["\<\
This notebook supports the Chapter 4 numerical study of convexification time. \
It generates random centered polygons, applies the averaging dynamics, \
records the first strictly convex iterate, summarizes retained trials, fits \
quadratic scaling laws in the number of vertices, studies dependence on \
alpha, and compares the empirical time scale with the spectral-gap prediction.\
\>", "Text",ExpressionUUID->"57ea83aa-a11d-4779-8d56-681f256c7fd7"],

Cell["\<\
All executable mathematics appears in ordinary Wolfram Language Input cells. \
Explanatory prose appears in ordinary Text cells. This notebook contains no \
hand-authored BoxData, RowBox, or FormBox expressions.\
\>", "Text",ExpressionUUID->"449ab59d-e4b8-49a6-88c6-a3ea79fd0b76"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Averaging dynamics and convexity criterion", "Section",ExpressionUUID->"a04fa0ee-467c-4f2a-9dea-adfcfc9c6a47"],

Cell["\<\
ClearAll[\"Global`*\"];

applyA[p_List, alpha_?NumericQ] :=
  (1 - alpha) N[p] + alpha RotateLeft[N[p]];

centerPolygon[p_List] :=
  N[p] - Mean[N[p]];

edges[p_List] :=
  RotateLeft[N[p]] - N[p];

signedTurnAreas[p_List] := Module[{e, n},
  e = edges[p];
  n = Length[e];
  Chop@N@Table[
    Im[Conjugate[e[[j]]] e[[Mod[j, n] + 1]]],
    {j, 1, n}
  ]
];

strictlyConvexCCWQ[p_List, tol_?NumericQ] := Module[{a},
  a = signedTurnAreas[p];
  TrueQ[Min[a] > tol]
];

strictlyConvexCWQ[p_List, tol_?NumericQ] := Module[{a},
  a = signedTurnAreas[p];
  TrueQ[Max[a] < -tol]
];

strictlyConvexQ[p_List, tol_?NumericQ] :=
  TrueQ[strictlyConvexCCWQ[p, tol] || strictlyConvexCWQ[p, tol]];\
\>", "Input",
 CellLabel->
  "In[682]:=",ExpressionUUID->"ee0bb595-f491-4ae4-aee6-1bbd5e1f6b3d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Random polygon models", "Section",
 CellChangeTimes->{
  3.992970318215952*^9},ExpressionUUID->"a3fc1519-a548-44d0-9681-\
f4b7066d9ffe"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"randomCenteredPolygon", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"n_Integer", "?", "Positive"}], ",", "\[IndentingNewLine]", 
