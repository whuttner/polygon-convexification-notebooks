Cell[CellGroupData[{

Cell["11. Confidence bands for retained means", "Section",ExpressionUUID->"27d0ebfa-bc29-4edf-aca0-88faddfe4528"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"confidenceDataByEnsemble", "=", 
    RowBox[{"GroupBy", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Cases", "[", "\[IndentingNewLine]", 
       RowBox[{"comparisonSummary", ",", 
        RowBox[{
         RowBox[{"row_", "/;", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"NumericQ", "[", 
            RowBox[{"row", "[", "\"\<meanTime\>\"", "]"}], "]"}], "&&", 
           "\[IndentingNewLine]", 
           RowBox[{"NumericQ", "[", 
            RowBox[{"row", "[", "\"\<standardError\>\"", "]"}], "]"}]}]}], ":>",
          "\[IndentingNewLine]", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"row", "[", "\"\<ensemble\>\"", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"row", "[", "\"\<n\>\"", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"row", "[", "\"\<meanTime\>\"", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
