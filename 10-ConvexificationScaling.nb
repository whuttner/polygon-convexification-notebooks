Cell[CellGroupData[{

Cell["14. Dependence on alpha", "Section",ExpressionUUID->"6e621c4d-ec2a-4d90-ad9a-aaa301c904df"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"alphaValues", "=", 
    RowBox[{"{", 
     RowBox[{"0.2", ",", "0.35", ",", "0.5", ",", "0.65", ",", "0.8"}], 
     "}"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"alphaComparisonN", "=", "30"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"alphaTrials", "=", "250"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"alphaMaxM", "=", "7500"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"alphaSeedBase", "=", "90000"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"alphaEnsembleData", "=", 
    RowBox[{"Flatten", "@", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Join", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"runConvexificationExperiment", "[", "\[IndentingNewLine]", 
          RowBox[{
          "randomCenteredPolygon", ",", 
           "\[IndentingNewLine]", "\"\<SquareCoordinates\>\"", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"{", "alphaComparisonN", "}"}], ",", "\[IndentingNewLine]",
            "alpha", ",", "\[IndentingNewLine]", "alphaTrials", ",", 
           "\[IndentingNewLine]", "alphaMaxM", ",", "\[IndentingNewLine]", 
           RowBox[{"alphaSeedBase", "+", 
            RowBox[{"Round", "[", 
             RowBox[{"1000", " ", "alpha"}], "]"}]}]}], "\[IndentingNewLine]",
           "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"runConvexificationExperiment", "[", "\[IndentingNewLine]", 
          RowBox[{
          "randomHalfNormalPolygon", ",", 
           "\[IndentingNewLine]", "\"\<HalfNormalRadial\>\"", ",", 
           "\[IndentingNewLine]", 
           RowBox[{"{", "alphaComparisonN", "}"}], ",", "\[IndentingNewLine]",
            "alpha", ",", "\[IndentingNewLine]", "alphaTrials", ",", 
           "\[IndentingNewLine]", "alphaMaxM", ",", "\[IndentingNewLine]", 
           RowBox[{"alphaSeedBase", "+", 
            RowBox[{"Round", "[", 
             RowBox[{"1000", " ", "alpha"}], "]"}]}]}], "\[IndentingNewLine]",
           "]"}]}], "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
       
       RowBox[{"{", 
        RowBox[{"alpha", ",", "alphaValues"}], "}"}]}], "\[IndentingNewLine]",
       "]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"summarizeByEnsembleAndAlpha", "[", "data_List", "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "groups", "}"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"groups", "=", 
        RowBox[{"GroupBy", "[", "\[IndentingNewLine]", 
         RowBox[{"data", ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"#ensemble", ",", "#alpha"}], "}"}], "&"}]}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"KeyValueMap", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"key", ",", "rows"}], "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Module", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", "\[IndentingNewLine]", 
              RowBox[{
              "times", ",", "\[IndentingNewLine]", "retainedCount", ",", 
               "\[IndentingNewLine]", "totalCount"}], "\[IndentingNewLine]", 
              "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"times", "=", 
               RowBox[{"Cases", "[", "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"rows", "[", 
                  RowBox[{"[", 
                   RowBox[{"All", ",", "\"\<time\>\""}], "]"}], "]"}], ",", 
                 "\[IndentingNewLine]", "_Integer"}], "\[IndentingNewLine]", 
                "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"retainedCount", "=", 
               RowBox[{"Length", "[", "times", "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"totalCount", "=", 
               RowBox[{"Length", "[", "rows", "]"}]}], ";", 
              "\[IndentingNewLine]", "\[IndentingNewLine]", 
              RowBox[{"<|", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"\"\<ensemble\>\"", "->", 
                 RowBox[{"key", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"\"\<alpha\>\"", "->", 
                 RowBox[{"key", "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"\"\<n\>\"", "->", "alphaComparisonN"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"\"\<trials\>\"", "->", "totalCount"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"\"\<retained\>\"", "->", "retainedCount"}], ",", 
                "\[IndentingNewLine]", 
                
                RowBox[{"\"\<retentionRate\>\"", "->", "\[IndentingNewLine]", 
                 
                 RowBox[{"N", "[", 
                  RowBox[{"retainedCount", "/", "totalCount"}], "]"}]}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"\"\<meanTime\>\"", "->", 
                 RowBox[{"If", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"retainedCount", ">", "0"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Mean", "[", "times", "]"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                   "Missing", "[", "\"\<NoRetainedTrials\>\"", "]"}]}], 
                  "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
                
                RowBox[{"\"\<medianTime\>\"", "->", 
                 RowBox[{"If", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"retainedCount", ">", "0"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Median", "[", "times", "]"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                   "Missing", "[", "\"\<NoRetainedTrials\>\"", "]"}]}], 
                  "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
                
                RowBox[{"\"\<standardDeviation\>\"", "->", 
                 RowBox[{"If", "[", "\[IndentingNewLine]", 
                  RowBox[{
                   RowBox[{"retainedCount", ">", "1"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{"StandardDeviation", "[", "times", "]"}], ",", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                   "Missing", "[", "\"\<InsufficientData\>\"", "]"}]}], 
                  "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
                
