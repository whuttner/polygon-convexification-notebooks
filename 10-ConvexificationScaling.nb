Cell[CellGroupData[{

Cell["3. First strictly convex iterate", "Section",
 CellChangeTimes->{
  3.992970310534687*^9},ExpressionUUID->"da8581c4-08f6-47fc-a25f-\
94e99cf148f0"],

Cell["\<\
Clear[firstStrictConvexTime];

firstStrictConvexTime[p_List, alpha_?NumericQ] :=
  firstStrictConvexTime[p, alpha, 1000, 10^-10];

firstStrictConvexTime[p_List, alpha_?NumericQ, maxM_Integer?NonNegative] :=
  firstStrictConvexTime[p, alpha, maxM, 10^-10];

firstStrictConvexTime[p_List, alpha_?NumericQ, maxM_Integer?NonNegative, \
tol_?NumericQ] := Module[
  {iterate, m},
  iterate = N[p];
  For[m = 0, m <= maxM, m++,
    If[TrueQ[strictlyConvexQ[iterate, tol]], Return[m]];
    iterate = applyA[iterate, alpha];
  ];
  Missing[\"NotFound\", maxM]
];\
\>", "Input",
 CellChangeTimes->{{3.9930495759660263`*^9, 3.9930495769708977`*^9}},
 CellLabel->
  "In[700]:=",ExpressionUUID->"8776e5e2-fcc7-4412-98e9-0599126239fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"polygonAtTime", "[", "\[IndentingNewLine]", 
    RowBox[{"p_List", ",", "\[IndentingNewLine]", 
     RowBox[{"alpha_", "?", "NumericQ"}], ",", "\[IndentingNewLine]", 
     RowBox[{"m_Integer", "?", "NonNegative"}]}], "\[IndentingNewLine]", 
    "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Nest", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"applyA", "[", 
       RowBox[{"#", ",", "alpha"}], "]"}], "&"}], ",", "\[IndentingNewLine]", 
     
     RowBox[{"N", "[", "p", "]"}], ",", "\[IndentingNewLine]", "m"}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.993049589970964*^9, 3.993049618837935*^9}},
 CellLabel->
  "In[707]:=",ExpressionUUID->"5dd5e81f-9023-4035-b9e8-2b9654b3a0fc"],

Cell[CellGroupData[{

Cell["\<\
pExample = randomHalfNormalPolygon[15,2026,1.0];
alphaExample = 0.35;
convexificationTimeExample = firstStrictConvexTime[pExample, alphaExample, \
1000];
convexificationTimeExample\
\>", "Input",
 CellChangeTimes->{{3.99297914294027*^9, 3.992979174094418*^9}, {
