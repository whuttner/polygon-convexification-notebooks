Cell["7. Mean convexification time versus n", "Section",ExpressionUUID->"5f585fc7-371b-468a-a7f0-e7fd442a9370"],

Cell["\<\
meanDataByEnsemble =
  GroupBy[
    Cases[
      comparisonSummary,
      row_ /; NumericQ[row[\"meanTime\"]] :>
        {
          row[\"ensemble\"],
          row[\"n\"],
          row[\"meanTime\"]
        }
    ],
    First -> Rest
  ];\
\>", "Input",
 CellChangeTimes->{3.9929708896717377`*^9},
 CellLabel->
