Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"muSquared", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"n_Integer", "?", "Positive"}], ",", "\[IndentingNewLine]", 
      "k_Integer", ",", "\[IndentingNewLine]", 
      RowBox[{"alpha_", "?", "NumericQ"}]}], "\[IndentingNewLine]", "]"}], ":=",
     "\[IndentingNewLine]", 
    RowBox[{"1", "-", 
     RowBox[{"2", " ", "alpha", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", "alpha"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Cos", "[", 
         RowBox[{"2", " ", "Pi", " ", 
          RowBox[{"k", "/", "n"}]}], "]"}]}], ")"}]}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"gamma", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"n_Integer", "?", "Positive"}], ",", "\[IndentingNewLine]", 
      RowBox[{"alpha_", "?", "NumericQ"}]}], "\[IndentingNewLine]", "]"}], ":=",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"1", "/", "2"}], " ", 
     RowBox[{"Log", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"muSquared", "[", 
        RowBox[{"n", ",", "1", ",", "alpha"}], "]"}], "/", 
       "\[IndentingNewLine]", 
