             RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", 
          RowBox[{"\"\<adjustedRSquared\>\"", "->", 
           RowBox[{"fit", "[", "\"\<AdjustedRSquared\>\"", "]"}]}]}], 
         "|>"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
