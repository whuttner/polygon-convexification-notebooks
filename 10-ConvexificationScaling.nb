Cell[CellGroupData[{

Cell["16. Retention-rate diagnostics", "Section",ExpressionUUID->"4155c3e9-3168-410d-9c3f-7978c9f420b3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"retentionDataByEnsemble", "=", 
    RowBox[{"GroupBy", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Cases", "[", "\[IndentingNewLine]", 
       RowBox[{"comparisonSummary", ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"row_", "/;", 
          RowBox[{"NumericQ", "[", 
           RowBox[{"row", "[", "\"\<retentionRate\>\"", "]"}], "]"}]}], ":>", 
         "\[IndentingNewLine]", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"row", "[", "\"\<ensemble\>\"", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"row", "[", "\"\<n\>\"", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"row", "[", "\"\<retentionRate\>\"", "]"}]}], 
          "\[IndentingNewLine]", "}"}]}]}], "\[IndentingNewLine]", "]"}], ",",
       "\[IndentingNewLine]", 
      RowBox[{"First", "->", "Rest"}]}], "\[IndentingNewLine]", "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"squareRetentionData", "=", 
    RowBox[{"Lookup", "[", "\[IndentingNewLine]", 
     RowBox[{
     "retentionDataByEnsemble", ",", 
      "\[IndentingNewLine]", "\"\<SquareCoordinates\>\"", ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"halfNormalRetentionData", "=", 
    RowBox[{"Lookup", "[", "\[IndentingNewLine]", 
     RowBox[{
     "retentionDataByEnsemble", ",", 
      "\[IndentingNewLine]", "\"\<HalfNormalRadial\>\"", ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"retentionThreshold", "=", "0.95"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lowRetentionRows", "=", 
    RowBox[{"Select", "[", "\[IndentingNewLine]", 
     RowBox[{"comparisonSummary", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"NumericQ", "[", "#retentionRate", "]"}], "&&", 
        "\[IndentingNewLine]", 
        RowBox[{"#retentionRate", "<", "retentionThreshold"}]}], "&"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"retentionSummary", "=", 
    RowBox[{"Dataset", "@", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"<|", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"\"\<ensemble\>\"", "->", "\"\<SquareCoordinates\>\""}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"\"\<dataPoints\>\"", "->", 
          RowBox[{"Length", "[", "squareRetentionData", "]"}]}], ",", 
         RowBox[{"\"\<minimumRetentionRate\>\"", "->", 
          RowBox[{"If", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", "squareRetentionData", "]"}], ">", "0"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Min", "[", 
             RowBox[{"squareRetentionData", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Missing", "[", "\"\<InsufficientData\>\"", "]"}]}], 
           "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"\"\<meanRetentionRate\>\"", "->", 
          RowBox[{"If", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", "squareRetentionData", "]"}], ">", "0"}], 
            ",", "\[IndentingNewLine]", 
            RowBox[{"Mean", "[", 
             RowBox[{"squareRetentionData", "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], ",", 
