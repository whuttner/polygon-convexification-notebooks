Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", "runLargerExperiment", "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"largerExperimentParameters", "=", 
    RowBox[{"<|", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\"\<nValues\>\"", "->", 
       RowBox[{"Range", "[", 
        RowBox[{"10", ",", "100", ",", "5"}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"\"\<Alpha\>\"", "->", "alphaComparison"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"\"\<Trials\>\"", "->", "250"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<MaxIterations\>\"", "->", "maxMComparison"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"\"\<SeedBase\>\"", "->", "140000"}]}], "\[IndentingNewLine]", 
     "|>"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"runLargerExperiment", "[", "]"}], ":=", "\[IndentingNewLine]", 
    RowBox[{"runLargerExperiment", "[", "largerExperimentParameters", "]"}]}],
    ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
    "runLargerExperiment", "[", "\[IndentingNewLine]", 
     "parameters_Association", "\[IndentingNewLine]", "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
       "nValues", ",", "\[IndentingNewLine]", "alpha", ",", 
        "\[IndentingNewLine]", "trials", ",", "\[IndentingNewLine]", 
        "maxIterations", ",", "\[IndentingNewLine]", "seedBase", ",", 
        "\[IndentingNewLine]", "squareData", ",", "\[IndentingNewLine]", 
        "halfNormalData", ",", "\[IndentingNewLine]", "combinedData", ",", 
        "\[IndentingNewLine]", "summary"}], "\[IndentingNewLine]", "}"}], ",",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nValues", "=", 
        RowBox[{"Lookup", "[", "\[IndentingNewLine]", 
         RowBox[{
         "parameters", ",", "\[IndentingNewLine]", "\"\<nValues\>\"", ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Range", "[", 
           RowBox[{"10", ",", "100", ",", "5"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"alpha", "=", 
        RowBox[{"Lookup", "[", "\[IndentingNewLine]", 
         RowBox[{
         "parameters", ",", "\[IndentingNewLine]", "\"\<Alpha\>\"", ",", 
          "\[IndentingNewLine]", "0.35"}], "\[IndentingNewLine]", "]"}]}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"trials", "=", 
        RowBox[{"Lookup", "[", "\[IndentingNewLine]", 
         RowBox[{
         "parameters", ",", "\[IndentingNewLine]", "\"\<Trials\>\"", ",", 
          "\[IndentingNewLine]", "250"}], "\[IndentingNewLine]", "]"}]}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"maxIterations", "=", 
        RowBox[{"Lookup", "[", "\[IndentingNewLine]", 
         RowBox[{
         "parameters", ",", "\[IndentingNewLine]", "\"\<MaxIterations\>\"", ",",
           "\[IndentingNewLine]", "7500"}], "\[IndentingNewLine]", "]"}]}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"seedBase", "=", 
        RowBox[{"Lookup", "[", "\[IndentingNewLine]", 
         RowBox[{
         "parameters", ",", "\[IndentingNewLine]", "\"\<SeedBase\>\"", ",", 
          "\[IndentingNewLine]", "140000"}], "\[IndentingNewLine]", "]"}]}], ";",
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"squareData", "=", 
        RowBox[{"runConvexificationExperiment", "[", "\[IndentingNewLine]", 
         RowBox[{
         "randomCenteredPolygon", ",", 
          "\[IndentingNewLine]", "\"\<SquareCoordinates\>\"", ",", 
          "\[IndentingNewLine]", "nValues", ",", "\[IndentingNewLine]", 
          "alpha", ",", "\[IndentingNewLine]", "trials", ",", 
          "\[IndentingNewLine]", "maxIterations", ",", "\[IndentingNewLine]", 
          "seedBase"}], "\[IndentingNewLine]", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"halfNormalData", "=", 
        RowBox[{"runConvexificationExperiment", "[", "\[IndentingNewLine]", 
         RowBox[{
         "randomHalfNormalPolygon", ",", 
          "\[IndentingNewLine]", "\"\<HalfNormalRadial\>\"", ",", 
          "\[IndentingNewLine]", "nValues", ",", "\[IndentingNewLine]", 
          "alpha", ",", "\[IndentingNewLine]", "trials", ",", 
          "\[IndentingNewLine]", "maxIterations", ",", "\[IndentingNewLine]", 
