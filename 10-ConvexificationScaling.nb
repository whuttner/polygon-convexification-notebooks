   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"powerLawFit", "[", 
      RowBox[{"summary_List", ",", "ensemble_String"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"data", ",", "fit"}], "}"}], ",", 
       RowBox[{
        RowBox[{"data", "=", 
         RowBox[{"Cases", "[", 
          RowBox[{"summary", ",", 
           RowBox[{
            RowBox[{"row_", "/;", 
             RowBox[{
              RowBox[{
               RowBox[{"row", "[", "\"\<ensemble\>\"", "]"}], "==", 
               "ensemble"}], "&&", 
              RowBox[{"NumericQ", "[", 
               RowBox[{"row", "[", "\"\<meanTime\>\"", "]"}], "]"}], "&&", 
              RowBox[{
               RowBox[{"row", "[", "\"\<meanTime\>\"", "]"}], ">", "0"}]}]}], 
            ":>", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Log", "[", 
               RowBox[{"row", "[", "\"\<n\>\"", "]"}], "]"}], ",", 
              RowBox[{"Log", "[", 
               RowBox[{"row", "[", "\"\<meanTime\>\"", "]"}], "]"}]}], 
             "}"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"fit", "=", 
         RowBox[{"LinearModelFit", "[", 
          RowBox[{"data", ",", "x", ",", "x"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<ensemble\>\"", "->", "ensemble"}], ",", 
          RowBox[{"\"\<logIntercept\>\"", "->", 
           RowBox[{
            RowBox[{"fit", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{"\"\<exponent\>\"", "->", 
           RowBox[{
            RowBox[{"fit", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{"\"\<prefactor\>\"", "->", 
           RowBox[{"Exp", "[", 
