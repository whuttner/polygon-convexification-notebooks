Cell[CellGroupData[{

Cell["4. Trial-level experiment", "Section",ExpressionUUID->"a50eee66-3c02-40f9-a287-7cf39b7a3042"],

Cell["\<\
convexificationTrial[
  generator_,
  ensembleName_String,
  n_Integer?Positive,
  alpha_?NumericQ,
  seed_Integer,
  maxM_Integer?NonNegative
] := Module[{p, time},

  p = generator[n, seed];

  time = firstStrictConvexTime[
    p,
    alpha,
    maxM
  ];

  <|
    \"ensemble\" -> ensembleName,
    \"n\" -> n,
    \"alpha\" -> alpha,
    \"seed\" -> seed,
    \"time\" -> time,
    \"retained\" -> IntegerQ[time]
  |>
];\
\>", "Input",
 CellChangeTimes->{3.992970521510633*^9},
 CellLabel->
  "In[712]:=",ExpressionUUID->"f73e7bda-733e-40ca-a968-00eea57f618d"],

