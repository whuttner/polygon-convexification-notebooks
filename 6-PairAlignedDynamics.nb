Cell[CellGroupData[{

Cell["10. Contraction on the complementary subspace", "Section",ExpressionUUID->"fce84091-402a-43cf-8cab-5ccd3ae3f656"],

Cell[BoxData[
 FormBox[
  RowBox[{
   OverscriptBox["\[Rho]", "^"], "=", 
   RowBox[{
    RowBox[{"max", 
     SubscriptBox["", 
      RowBox[{"2", "\[LessEqual]", "j", "\[LessEqual]", 
       RowBox[{"n", "-", "2"}]}]], 
     FractionBox[
      SubscriptBox["\[Mu]", "j"], 
      SubscriptBox["\[Mu]", "1"]]}], "<", "1"}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"56a69a1f-353f-470b-\
99de-90cc1b47b34c"],

Cell["\<\
rhoHat[n_Integer?Positive, alpha_?NumericQ] :=
  Max@Table[mu[n, j, alpha]/mu[n, 1, alpha], {j, 2, n - 2}];

perpendicularDecay[p_List, alpha_?NumericQ, params_Association, \
m_Integer?NonNegative] :=
  Norm[perpendicularProjection[iterateR[p, alpha, params, m]]];\
\>", "Input",
 CellLabel->
  "In[2575]:=",ExpressionUUID->"00fd6497-a347-4b96-b73a-070fd0fc41ba"],

Cell[CellGroupData[{

Cell["\<\
rhoExample = rhoHat[nExample, alphaExample];
decayTable = Table[
  {m, perpendicularDecay[pExample, alphaExample, paramsExample, m]},
  {m, 0, 40, 4}
];
{rhoExample, decayTable}\
\>", "Input",
 CellLabel->
  "In[2578]:=",ExpressionUUID->"77b95691-c570-4da2-a087-2c8c030dde63"],

