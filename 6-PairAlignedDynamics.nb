Cell[CellGroupData[{

Cell["7. Spectral rescaling", "Section",ExpressionUUID->"094c77f2-481d-4479-bb13-bb54dfec61b5"],

Cell["Define", "Text",ExpressionUUID->"6497a470-42d7-4fe2-bea3-b6ec650ee875"],

Cell[BoxData[
 FormBox[
  RowBox[{
   OverscriptBox[
    SubscriptBox["A", "\[Alpha]"], "~"], "=", 
   FractionBox[
    SubscriptBox["A", "\[Alpha]"], 
    SubscriptBox["\[Lambda]", "1"]]}], TraditionalForm]], "DisplayFormula",Exp\
ressionUUID->"74c77e33-fcc1-4e7a-90cb-72bd583eaf0d"],

Cell["\<\
applyATilde[p_List, alpha_?NumericQ] := Module[{n},
  n = Length[p];
  applyA[p, alpha]/lambda[n, 1, alpha]
];\
\>", "Input",
 CellLabel->
  "In[2553]:=",ExpressionUUID->"f84f1a38-5299-41ed-bfd0-c2d7d7d18f23"],

Cell["\<\
phi1 = fourierVector[nExample, 1];
aTildeFixError = Norm[N[applyATilde[phi1, alphaExample] - phi1]];
aTildeFixQ = aTildeFixError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2554]:=",ExpressionUUID->"05f24194-6191-4351-b698-9a30852a1320"],

