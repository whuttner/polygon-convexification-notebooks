}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Alignment parameters", "Section",ExpressionUUID->"9c3e4302-917e-480f-8de1-ff954e21ed11"],

Cell["For", "Text",ExpressionUUID->"b6f82eee-38df-4e87-a006-5ff4ec150a7b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["p", 
    RowBox[{"\[PlusMinus]", "1"}]], "=", 
   SubscriptBox["c", "1"], 
   SubscriptBox["\[CurlyPhi]", "1"], "+", 
   SubscriptBox["c", 
    RowBox[{"n", "-", "1"}]], 
   SubscriptBox["\[CurlyPhi]", 
    RowBox[{"n", "-", "1"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"a8335f65-eee5-43a8-adc0-33cf685ca3c8"],

Cell[TextData[{
 "Chapter 3 defines the rotation parameter ",
 Cell[BoxData[
  RowBox[{"\[Xi]", "=", 
   SuperscriptBox["e", 
    RowBox[{"i", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Theta]", "1"], "+", 
       SubscriptBox["\[Theta]", 
        RowBox[{"n", "-", "1"}]]}], ")"}], "/", "2"}]]}]], "InlineFormula",
  ExpressionUUID->"96649bd1-7c31-4df0-a466-00971bc3ae97"],
 " and the anisotropy parameter"
}], "Text",ExpressionUUID->"63edf0b5-33ee-467b-ad49-586b7cf35edb"],

Cell[BoxData[
 FormBox[
  RowBox[{"r", "=", 
   FractionBox[
    RowBox[{
     RowBox[{"|", 
      SubscriptBox["c", "1"], "|"}], "+", 
     RowBox[{"|", 
      SubscriptBox["c", 
       RowBox[{"n", "-", "1"}]], "|"}]}], 
    RowBox[{
     RowBox[{"|", 
      SubscriptBox["c", "1"], "|"}], "-", 
     RowBox[{"|", 
      SubscriptBox["c", 
       RowBox[{"n", "-", "1"}]], "|"}]}]]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"421722bf-b1a2-4fcc-\
81b1-5f8cf66e921b"],

Cell["\<\
alignmentParameters[p_List] := Module[
  {data, c1, cN, theta1, thetaN, denominator},
  data = firstHarmonicData[p];
  c1 = data[\"c1\"];
  cN = data[\"cNMinus1\"];
  denominator = Abs[c1] - Abs[cN];
  If[Abs[N[denominator]] < 10^-12,
    Return[Missing[\"DegenerateFirstHarmonic\"]]
  ];
  theta1 = Arg[c1];
  thetaN = Arg[cN];
  <|
    \"Xi\" -> Exp[I (theta1 + thetaN)/2],
    \"R\" -> (Abs[c1] + Abs[cN])/denominator,
    \"ThetaMinus\" -> (theta1 - thetaN)/2,
    \"AlignedAmplitude\" -> (Abs[c1] + Abs[cN]) Exp[I (theta1 - thetaN)/2]
  |>
];\
\>", "Input",
 CellLabel->
  "In[2526]:=",ExpressionUUID->"ecb19dd8-6b14-432d-bb93-a88259855f4f"],

Cell[CellGroupData[{

Cell["\<\
paramsExample = alignmentParameters[pExample];
paramsExample\
\>", "Input",
 CellLabel->
  "In[2527]:=",ExpressionUUID->"8aa776ca-8e34-4cc2-ae6c-7343fd68b34f"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Xi\"\>", "\[Rule]", 
    RowBox[{"0.9796857577160295`", "\[VeryThinSpace]", "-", 
     RowBox[{"0.20053881451821037`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"R\"\>", "\[Rule]", "5.458185683481367`"}], ",", 
   RowBox[{"\<\"ThetaMinus\"\>", "\[Rule]", 
    RowBox[{"-", "2.6668332257889737`"}]}], ",", 
   RowBox[{"\<\"AlignedAmplitude\"\>", "\[Rule]", 
    RowBox[{
     RowBox[{"-", "0.684480561828709`"}], "-", 
     RowBox[{"0.35180107328110666`", " ", "\[ImaginaryI]"}]}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.9928043837367992`*^9},
 CellLabel->
  "Out[2528]=",ExpressionUUID->"2c678438-cefd-47b1-8a08-59bd74f58121"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Real-linear dilation", "Section",ExpressionUUID->"f737e653-559e-4068-b71b-9ecc4d1376b5"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["D", "r"], 
   RowBox[{"(", "z", ")"}], "=", 
   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "r"}], ")"}], "z", "+", 
     RowBox[{"(", 
      RowBox[{"1", "-", "r"}], ")"}], 
     OverscriptBox["z", "_"]}], "2"], "=", "u", "+", "i", "r", "v"}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"75cd2a8b-3c0e-4ab6-\
9388-0ce83deee327"],

Cell["\<\
dilationD[z_, r_?NumericQ] :=
  ((1 + r) z + (1 - r) Conjugate[z])/2;

inverseDilationD[z_, r_?NumericQ] :=
  dilationD[z, 1/r];\
\>", "Input",
 CellLabel->
  "In[2529]:=",ExpressionUUID->"bb0794e1-1249-432b-befb-444eae4d9379"],

Cell["\<\
zTest = 0.7 - 1.2 I;
rTest = 2.3;
dilationInverseError = Abs[N[inverseDilationD[dilationD[zTest, rTest], rTest] \
- zTest]];
dilationInverseQ = dilationInverseError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2532]:=",ExpressionUUID->"fab3017d-db62-4f35-b5c5-e804cc03c46b"],

Cell[CellGroupData[{

Cell["dilationInverseError", "Input",
 CellLabel->
  "In[2536]:=",ExpressionUUID->"ae98e151-d3a9-4a2b-aca5-ca83c435a3f6"],

Cell[BoxData["2.220446049250313`*^-16"], "Output",
 CellChangeTimes->{3.992804383752651*^9},
 CellLabel->
  "Out[2536]=",ExpressionUUID->"266b4cdb-7e90-4d0d-8a45-ca6207ab9573"]
}, Open  ]],

Cell[CellGroupData[{

Cell["dilationInverseQ", "Input",
 CellLabel->
  "In[2537]:=",ExpressionUUID->"7f4abab3-bb80-4423-92ba-9454abbd7ee2"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992804383757861*^9},
 CellLabel->
  "Out[2537]=",ExpressionUUID->"1c3e61f7-05c6-4d47-a8d0-68d31d0d57d7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. The normalizing maps H and H inverse", "Section",ExpressionUUID->"32332d0e-f074-428b-a7b1-93a81c80d617"],

Cell[BoxData[
 FormBox[
  RowBox[{"H", "=", 
   SubscriptBox["D", "r"], "\[SmallCircle]", 
   OverscriptBox["\[Xi]", "_"], ",", "\[ThickSpace]", 
   SuperscriptBox["H", 
    RowBox[{"-", "1"}]], "=", "\[Xi]", "\[SmallCircle]", 
   SubscriptBox["D", 
    RowBox[{"1", "/", "r"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"34b2c211-0bfc-46cb-a99f-d328638f212f"],

Cell["\<\
applyH[p_List, params_Association] := Module[{xi, r},
  xi = params[\"Xi\"];
  r = params[\"R\"];
  dilationD[Conjugate[xi] N[p], r]
];

applyHInverse[p_List, params_Association] := Module[{xi, r},
  xi = params[\"Xi\"];
  r = params[\"R\"];
  xi inverseDilationD[N[p], r]
];\
\>", "Input",
 CellLabel->
  "In[2538]:=",ExpressionUUID->"52524132-0ca8-463e-b5be-ac965d303f8c"],

Cell["\<\
hInverseError = Norm[N[applyHInverse[applyH[pExample, paramsExample], \
paramsExample] - pExample]];
hInverseQ = hInverseError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2541]:=",ExpressionUUID->"4f2efded-cf53-463a-af03-8b2d0c955c22"],

Cell[CellGroupData[{

Cell["hInverseError", "Input",
 CellLabel->
  "In[2543]:=",ExpressionUUID->"9950c72a-55bf-4d9c-a1dd-8874d62a6a53"],

Cell[BoxData["9.61506381442413`*^-16"], "Output",
 CellChangeTimes->{3.992804383769711*^9},
 CellLabel->
  "Out[2543]=",ExpressionUUID->"3e89af71-e732-401f-8260-455ed9b83ba1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["hInverseQ", "Input",
 CellLabel->
  "In[2544]:=",ExpressionUUID->"76ca962c-871c-4f57-ba0b-36b8a14ecc6d"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.9928043837754393`*^9},
 CellLabel->
  "Out[2544]=",ExpressionUUID->"968fff6a-1a7d-43b8-9ab3-1ca4ef27c961"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Alignment of the first harmonic", "Section",ExpressionUUID->"927a5c47-0902-4b61-b872-d53d9b60753e"],

Cell["The alignment lemma states", "Text",ExpressionUUID->"4f99bfd1-bacf-4b2b-ac4d-0de707657cc3"],

Cell[BoxData[
 FormBox[
  RowBox[{"H", 
   SubscriptBox["p", 
    RowBox[{"\[PlusMinus]", "1"}]], "=", 
   SuperscriptBox["a", "\[Prime]"], 
   SubscriptBox["\[CurlyPhi]", "1"]}], TraditionalForm]], "DisplayFormula",Exp\
ressionUUID->"0a122701-742c-4135-8f65-0da6524f33a6"],

Cell["\<\
alignedPair = applyH[pPair, paramsExample];
alignedPairCoefficients = fourierCoefficients[alignedPair];
alignedTarget = paramsExample[\"AlignedAmplitude\"] fourierVector[nExample, 1];
alignmentError = Norm[N[alignedPair - alignedTarget]];
alignmentQ = alignmentError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2545]:=",ExpressionUUID->"a79dbc7b-0a78-40ab-a64d-637304471902"],

