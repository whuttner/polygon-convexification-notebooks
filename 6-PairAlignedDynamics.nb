Cell[CellGroupData[{

Cell["11. Convergence to the initial first harmonic", "Section",ExpressionUUID->"ff019b07-0f9b-40fd-9df6-15d66301ce45"],

Cell[BoxData[
 FormBox[
  RowBox[{
   UnderscriptBox["lim", 
    RowBox[{"m", "\[Rule]", "\[Infinity]"}]], 
   SuperscriptBox[
    SubscriptBox["R", "\[Alpha]"], "m"], "p", "=", 
   SubscriptBox["p", 
    RowBox[{"\[PlusMinus]", "1"}]]}], TraditionalForm]], "DisplayFormula",Expr\
essionUUID->"a2649ca9-1312-4041-b3a2-c93b997adf0d"],

Cell[CellGroupData[{

Cell["\<\
limitError[p_List, alpha_?NumericQ, params_Association, \
m_Integer?NonNegative] :=
  Norm[N[iterateR[p, alpha, params, m] - pairPlaneProjection[p]]];

limitTable = Table[
  {m, limitError[pExample, alphaExample, paramsExample, m]},
  {m, 0, 60, 5}
];
limitTable // TableForm\
\>", "Input",
 CellLabel->
  "In[2582]:=",ExpressionUUID->"ef134c70-18b7-4c0f-a496-73037e7a8ecd"],

