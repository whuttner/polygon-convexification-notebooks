Cell[CellGroupData[{

Cell["8. Pair-aligned rescaled operator", "Section",ExpressionUUID->"45069bd8-7835-4c6d-837c-29a7141a4046"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["R", "\[Alpha]"], "=", 
   SuperscriptBox["H", 
    RowBox[{"-", "1"}]], 
   OverscriptBox[
    SubscriptBox["A", "\[Alpha]"], "~"], "H"}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"def7c317-e0fa-4646-\
a024-7bc2af0ee0c9"],

Cell["\<\
applyR[p_List, alpha_?NumericQ, params_Association] :=
  applyHInverse[
    applyATilde[applyH[p, params], alpha],
    params
  ];

iterateR[p_List, alpha_?NumericQ, params_Association, m_Integer?NonNegative] :=
  Nest[applyR[#, alpha, params] &, N[p], m];\
\>", "Input",
 CellLabel->
  "In[2559]:=",ExpressionUUID->"86d311f9-5e72-4ce8-863e-feb70ea43af5"],

Cell["\<\
fixedPairError = Norm[N[applyR[pPair, alphaExample, paramsExample] - pPair]];
fixedPairQ = fixedPairError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2562]:=",ExpressionUUID->"920c2e0c-fc09-4ecc-acc8-e69a05f91c8a"],

Cell[CellGroupData[{

Cell["fixedPairError", "Input",
 CellLabel->
  "In[2564]:=",ExpressionUUID->"fa893cbd-c08b-4963-a829-628594b6d2d7"],

Cell[BoxData["1.0168498605462348`*^-16"], "Output",
