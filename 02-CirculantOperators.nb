b58658b36954"]
}, Open  ]],

Cell["\<\
firstRowCheck = First[T] == aExample;
rowShiftCheck = And @@ Table[
  T[[j + 1]] == RotateRight[T[[j]]],
  {j, 1, Length[T] - 1}
];\
\>", "Input",
 CellLabel->
  "In[1214]:=",ExpressionUUID->"e1e305d8-8f51-42a2-b82d-43bf21f21376"],

