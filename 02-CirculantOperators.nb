Cell[CellGroupData[{

Cell["6. Diagonalization in the Fourier basis", "Section",ExpressionUUID->"03ef5ec9-47db-4fcc-b79e-feaa8b99a491"],

Cell[TextData[{
 "Because ",
 Cell[BoxData[
 "F"], "InlineFormula",ExpressionUUID->"aae1e45e-b093-4e34-ab60-79d4d82e7dfb"],
 " is unitary, the Fourier-basis matrix is"
}], "Text",ExpressionUUID->"c416fa44-7b40-4711-adfa-6aeba0d40baa"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["F", "\[Dagger]"], "T", "F", "=", 
   RowBox[{"diag", "(", 
    RowBox[{
     SubscriptBox["\[Lambda]", "0"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["\[Lambda]", 
      RowBox[{"n", "-", "1"}]]}], ")"}]}], TraditionalForm]], "DisplayFormula",\
ExpressionUUID->"3ea6b618-22d5-43eb-8a90-3d5218d69a2e"],

Cell["\<\
diagonalizedT = Chop[ConjugateTranspose[F] . T . F];
expectedDiagonal = DiagonalMatrix[lambdaList];
diagonalizationError = Max[Abs[Flatten[N[diagonalizedT - \
expectedDiagonal]]]];
diagonalizationQ = diagonalizationError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[1236]:=",ExpressionUUID->"d0613e0c-8ca3-4dbf-8a5f-d9c00f2752d3"],

