  RowBox[{"p", 
   RowBox[{"(", "z", ")"}], "=", 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"m", "=", "0"}], 
    RowBox[{"n", "-", "1"}]], 
   SubscriptBox["a", "m"], 
   SuperscriptBox["z", "m"]}], TraditionalForm]], "DisplayFormula",ExpressionU\
UID->"a938374d-b9d6-4505-907e-4da93fd906e7"],

Cell[TextData[{
 "Then ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Lambda]", "k"], "=", 
   RowBox[{"p", "(", 
    SuperscriptBox["\[Omega]", "k"], ")"}]}]], "InlineFormula",ExpressionUUID->
  "bb418319-7f66-4011-b364-2305ceee6349"],
 "."
}], "Text",ExpressionUUID->"335c0852-f84c-4393-838e-9a6f595b0315"],

Cell["\<\
circulantPolynomial[a_List, z_] :=
  Sum[a[[m + 1]] z^m, {m, 0, Length[a] - 1}];

polynomialEigenvalues[a_List] := Module[{n = Length[a]},
  Table[circulantPolynomial[a, omega[n]^k], {k, 0, n - 1}]
];

polynomialError = Max[Abs[N[polynomialEigenvalues[aExample] - lambdaList]]];
polynomialInterpretationQ = polynomialError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[1249]:=",ExpressionUUID->"65051b58-68bc-4e71-9b58-7960aebf2bd4"],

