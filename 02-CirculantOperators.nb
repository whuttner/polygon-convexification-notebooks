Cell["8. Polynomial interpretation", "Section",ExpressionUUID->"a1df5a7d-4d9e-4f80-9051-a03ecf76fe40"],

Cell["Let", "Text",ExpressionUUID->"9e21c61d-a98b-456b-a08a-90058e5beb99"],

Cell[BoxData[
