Cell["7. Reconstruction from the diagonal form", "Section",ExpressionUUID->"862bf922-11fa-4729-b362-361e7e680b23"],

Cell[BoxData[
 FormBox[
  RowBox[{"T", "=", "F", 
   RowBox[{"diag", "(", 
    RowBox[{
     SubscriptBox["\[Lambda]", "0"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["\[Lambda]", 
      RowBox[{"n", "-", "1"}]]}], ")"}], 
   SuperscriptBox["F", "\[Dagger]"]}], TraditionalForm]], "DisplayFormula",Exp\
ressionUUID->"2d2b2a04-b8a4-429b-ba25-a0bb5fb65a84"],

Cell["\<\
reconstructedT = Chop[F . DiagonalMatrix[lambdaList] . \
ConjugateTranspose[F]];
reconstructionError = Max[Abs[Flatten[N[reconstructedT - T]]]];
reconstructionQ = reconstructionError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[1243]:=",ExpressionUUID->"8a7c487b-5365-4bf1-ad11-a05d0561c18f"],

