Cell["\<\
symbolicRow = {a0, a1, a2, a3};
symbolicEigenvalues = FullSimplify[circulantEigenvalues[symbolicRow]];
symbolicEigenvalues\
\>", "Input",
 CellLabel->
  "In[1257]:=",ExpressionUUID->"61e22db2-70c0-4a57-9828-951639136ceb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"a0", "+", "a1", "+", "a2", "+", "a3"}], ",", 
   RowBox[{"a0", "+", 
    RowBox[{"\[ImaginaryI]", " ", 
     RowBox[{"(", 
      RowBox[{"a1", "+", 
       RowBox[{"\[ImaginaryI]", " ", "a2"}], "-", "a3"}], ")"}]}]}], ",", 
   RowBox[{"a0", "-", "a1", "+", "a2", "-", "a3"}], ",", 
   RowBox[{"a0", "-", 
    RowBox[{"\[ImaginaryI]", " ", "a1"}], "-", "a2", "+", 
    RowBox[{"\[ImaginaryI]", " ", "a3"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.992801066427416*^9},
