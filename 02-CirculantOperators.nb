Cell[CellGroupData[{

Cell["5. Componentwise theorem check", "Section",ExpressionUUID->"6d6373f9-153e-4117-8b30-2a199a5ea294"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
 "j"], "InlineFormula",ExpressionUUID->"172f23e5-2a42-42d9-ac86-917ba2e11bde"],
 "th component of ",
 Cell[BoxData[
  RowBox[{"T", 
   SubscriptBox[
    OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"]}]], "InlineFormula",
  ExpressionUUID->"eef4c657-2d20-4908-a1c0-d43fc8caade6"],
 " is"
}], "Text",ExpressionUUID->"2fab6bde-c711-466e-a167-2e849b7c81c4"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["1", 
    SqrtBox["n"]], 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"\[ScriptL]", "=", "0"}], 
    RowBox[{"n", "-", "1"}]], 
   SubscriptBox["a", 
    RowBox[{"\[ScriptL]", "-", "j"}]], 
   SuperscriptBox["\[Omega]", 
    RowBox[{"\[ScriptL]", "k"}]]}], TraditionalForm]], "DisplayFormula",Expres\
sionUUID->"f3d35dd5-bb73-4fb7-9acf-dd347e37104f"],

Cell[TextData[{
 "After the substitution ",
 Cell[BoxData[
  RowBox[{"m", "=", 
   RowBox[{"\[ScriptL]", "-", "j"}]}]], "InlineFormula",ExpressionUUID->
  "52725296-2a4e-40f9-81c3-c50b1f7d85a3"],
 ", this equals"
}], "Text",ExpressionUUID->"7b42f9ad-9384-4f2b-9b07-6a7192c256d8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["\[Omega]", 
    RowBox[{"j", "k"}]], 
   FractionBox["1", 
    SqrtBox["n"]], 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"m", "=", "0"}], 
    RowBox[{"n", "-", "1"}]], 
   SubscriptBox["a", "m"], 
   SuperscriptBox["\[Omega]", 
    RowBox[{"m", "k"}]]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"bee62444-2f31-415d-9936-21ba09183de4"],

Cell["\<\
componentResidual[a_List, k_Integer, j_Integer] := Module[
  {n = Length[a], lhs, rhs, lambdaK},
  lhs = Sum[
    a[[Mod[ell - j, n] + 1]] fourierVector[n, k][[ell + 1]],
    {ell, 0, n - 1}
  ];
  lambdaK = circulantEigenvalues[a][[Mod[k, n] + 1]];
  rhs = lambdaK fourierVector[n, k][[Mod[j, n] + 1]];
  Abs[N[lhs - rhs]]
];\
\>", "Input",
 CellLabel->
  "In[1229]:=",ExpressionUUID->"d3dfc220-dbc9-4d95-af52-e12a8e8b5b4a"],

Cell[CellGroupData[{

Cell["\<\
componentErrorMatrix = Table[
  componentResidual[aExample, k, j],
  {k, 0, nExample - 1}, {j, 0, nExample - 1}
];
componentErrorMatrix // MatrixForm\
\>", "Input",
 CellLabel->
  "In[1230]:=",ExpressionUUID->"8d0f3f6f-5f6c-4f4c-9bfb-d5f86282b007"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0.`", "0.`", "0.`", "0.`", "0.`", "0.`"},
     {"2.482534153247273`*^-16", "2.220446049250313`*^-16", 
      "4.47545209131181`*^-16", "5.551115123125783`*^-16", 
      "4.742874840267547`*^-16", "3.3306690738754696`*^-16"},
     {"4.518280359883027`*^-16", "4.002966042486721`*^-16", 
