Cell[CellGroupData[{

Cell["3. Fourier eigenvalues", "Section",ExpressionUUID->"f3ebdd3f-e11a-4930-a5aa-abeb9a277edc"],

Cell[TextData[{
 "The eigenvalue associated with Fourier mode ",
 Cell[BoxData[
  SubscriptBox[
   OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"]], "InlineFormula",
  ExpressionUUID->"5d62728b-701b-4479-9fb7-efa925a98fa0"],
 " is"
}], "Text",ExpressionUUID->"cfa17e6e-ec02-4ef0-8b5e-967510e916eb"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubsuperscriptBox["\[Lambda]", "k", 
    RowBox[{"(", "n", ")"}]], "=", 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"m", "=", "0"}], 
    RowBox[{"n", "-", "1"}]], 
   SubscriptBox["a", "m"], 
   SuperscriptBox["\[Omega]", 
    RowBox[{"m", "k"}]]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"225ccc52-d880-491d-a09b-5ea6a1c6b528"],

Cell[CellGroupData[{

Cell["\<\
circulantEigenvalues[a_List] := Module[{n = Length[a]},
  Table[
    Sum[a[[m + 1]] omega[n]^(m k), {m, 0, n - 1}],
    {k, 0, n - 1}
  ]
];

lambdaList = circulantEigenvalues[aExample];
N[lambdaList, 6]\
\>", "Input",
 CellLabel->
  "In[1218]:=",ExpressionUUID->"5b904fd3-4a1e-4912-ac03-58cb10b47007"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"9.`6.", ",", 
   RowBox[{
    RowBox[{"-", "1.5`5.8494850021680085"}], "-", 
    RowBox[{
    "2.5980762113533159403`6.088045629527841", " ", "\[ImaginaryI]"}]}], ",", 
   
   RowBox[{
    RowBox[{"-", "1.5`6.088045629527841"}], "-", 
    RowBox[{
    "0.8660254037844386468`5.849485002168009", " ", "\[ImaginaryI]"}]}], ",", 
   "9.`6.", ",", 
   RowBox[{
    RowBox[{"-", "1.5`6.088045629527841"}], "+", 
    RowBox[{
    "0.8660254037844386468`5.849485002168009", " ", "\[ImaginaryI]"}]}], ",", 
   
   RowBox[{
    RowBox[{"-", "1.5`5.8494850021680085"}], "+", 
    RowBox[{
    "2.5980762113533159403`6.088045629527841", " ", "\[ImaginaryI]"}]}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992801066258733*^9},
 CellLabel->
  "Out[1221]=",ExpressionUUID->"f4109dd5-6f43-444f-bcd9-1ad596fb2918"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Direct eigenvector verification", "Section",ExpressionUUID->"9b41cc31-e8b1-46df-b208-7e745fca0bdd"],

Cell[BoxData[
 FormBox[
  RowBox[{"T", 
   SubscriptBox[
    OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"], "=", 
   SubsuperscriptBox["\[Lambda]", "k", 
    RowBox[{"(", "n", ")"}]], 
   SubscriptBox[
    OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"3f3b0cb4-eaf1-49eb-\
bcd0-fec928544b0b"],

Cell["\<\
eigenvectorResidual[a_List, k_Integer] := Module[
  {n = Length[a], Tlocal, phi, lambdaK},
  Tlocal = circulantFromFirstRow[a];
  phi = fourierVector[n, k];
  lambdaK = circulantEigenvalues[a][[Mod[k, n] + 1]];
  Max[Abs[N[Tlocal . phi - lambdaK phi]]]
];\
\>", "Input",
 CellLabel->
  "In[1222]:=",ExpressionUUID->"0def913c-621d-402a-b749-e31ea59e33d2"],

Cell[CellGroupData[{

Cell["\<\
eigenResidualTable = Table[
  {k, eigenvectorResidual[aExample, k]},
  {k, 0, nExample - 1}
];
eigenResidualTable // TableForm\
\>", "Input",
 CellLabel->
  "In[1223]:=",ExpressionUUID->"6dbddecf-f32d-47cc-a62d-81350d07e541"],

Cell[BoxData[
 TagBox[GridBox[{
    {"0", "0.`"},
    {"1", "5.551115123125783`*^-16"},
    {"2", "7.850462293418876`*^-16"},
    {"3", "0.`"},
    {"4", "8.08254562088053`*^-16"},
    {"5", "5.551115123125783`*^-16"}
   },
   GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
   GridBoxSpacings->{"Columns" -> {
       Offset[0.27999999999999997`], {
        Offset[2.0999999999999996`]}, 
       Offset[0.27999999999999997`]}, "Rows" -> {
       Offset[0.2], {
        Offset[0.4]}, 
       Offset[0.2]}}],
  Function[BoxForm`e$, 
   TableForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.992801066277001*^9},
 CellLabel->
  "Out[1224]//TableForm=",ExpressionUUID->"c31c7647-6a8b-4302-84f5-\
9df0e930a502"]
}, Open  ]],

Cell["\<\
maxEigenResidual = Max[eigenResidualTable[[All, 2]]];
eigenvectorVerificationQ = maxEigenResidual < 10^-10;\
\>", "Input",
 CellLabel->
  "In[1225]:=",ExpressionUUID->"1f35c0db-ebeb-403e-8ff4-32144e35d946"],

