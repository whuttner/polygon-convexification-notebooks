Notebook[{

Cell[CellGroupData[{
Cell["CirculantOperators", "Title",ExpressionUUID->"d9ce62eb-5a28-42e3-a2d3-7861e3e3ef32"],

Cell["Fourier diagonalization of circulant operators", "Subtitle",ExpressionUUID->"59a8ac6a-6927-430f-914e-389029642835"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"d2acfd6b-943d-431a-bf7b-10c60c4fb211"],

Cell["\<\
This notebook supports the circulant-operator theorem in Chapter 1. It \
constructs a circulant matrix from its first row, verifies the Fourier \
eigenvector formula, diagonalizes the operator in the Fourier basis, and \
reconstructs the original matrix from its spectral data.\
\>", "Text",ExpressionUUID->"ac47d500-073a-4896-a142-c46e26533567"],

Cell["\<\
All executable cells are ordinary Wolfram Language Input cells. Typeset boxes \
are used only in explanatory cells.\
\>", "Text",ExpressionUUID->"6dbca8c8-839b-49fd-8039-8440f9fab37a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Fourier definitions", "Section",ExpressionUUID->"f89df97e-abf8-438b-b3a4-3bcbcbbaebdd"],

Cell["\<\
ClearAll[\"Global`*\"];

omega[n_Integer?Positive] := Exp[2 Pi I/n];

fourierVector[n_Integer?Positive, k_Integer] :=
  Table[omega[n]^(j k), {j, 0, n - 1}]/Sqrt[n];

fourierMatrix[n_Integer?Positive] :=
  Transpose@Table[fourierVector[n, k], {k, 0, n - 1}];\
\>", "Input",
 CellLabel->
  "In[1200]:=",ExpressionUUID->"083a8b12-a760-49c9-b099-171a6940bb5f"],

Cell["The normalized Fourier vectors are", "Text",ExpressionUUID->"0a21858a-8e69-4092-8777-d67319935b59"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"], "=", 
   FractionBox["1", 
    SqrtBox["n"]], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", ",", 
      SuperscriptBox["\[Omega]", "k"], ",", 
      SuperscriptBox["\[Omega]", 
       RowBox[{"2", "k"}]], ",", "\[Ellipsis]", ",", 
      SuperscriptBox["\[Omega]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "k"}]]}], ")"}], "\[Transpose]"]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"47c41b1a-bbfe-4135-\
ae1b-bbf5b14dee1c"],

Cell[CellGroupData[{

Cell["\<\
nExample = 6;
F = fourierMatrix[nExample];
N[F, 4] // MatrixForm\
\>", "Input",
 CellLabel->
  "In[1207]:=",ExpressionUUID->"7d5edc36-9d4b-4409-981c-e62f30ddc173"],

