Cell[CellGroupData[{

Cell["11. Automated verification report", "Section",ExpressionUUID->"04f76b07-0afc-468d-b8f2-f18b8afbdb4d"],

Cell["\<\
Clear[verificationReport];

verificationReport[] := verificationReport[20];

verificationReport[maxN_Integer?Positive] := Module[{rows},
  rows = Table[
    Module[
      {a, Tn, Fn, lambdas, eigenError, diagonalError, reconstructionError},
      SeedRandom[1000 + n];
      a = RandomInteger[{-5, 5}, n];
      Tn = circulantFromFirstRow[a];
      Fn = fourierMatrix[n];
      lambdas = circulantEigenvalues[a];
      eigenError = Max@Table[
        Max[Abs[N[Tn . fourierVector[n, k] - lambdas[[k + 1]] \
fourierVector[n, k]]]],
        {k, 0, n - 1}
      ];
      diagonalError = Max[Abs[Flatten[N[
        ConjugateTranspose[Fn] . Tn . Fn - DiagonalMatrix[lambdas]
      ]]]];
      reconstructionError = Max[Abs[Flatten[N[
        Fn . DiagonalMatrix[lambdas] . ConjugateTranspose[Fn] - Tn
      ]]]];
      <|
        \"n\" -> n,
        \"Fourier eigenvectors\" -> TrueQ[eigenError < 10^-10],
        \"Diagonalization\" -> TrueQ[diagonalError < 10^-10],
        \"Reconstruction\" -> TrueQ[reconstructionError < 10^-10]
      |>
    ],
    {n, 1, maxN}
  ];
  Dataset[rows]
];\
\>", "Input",
 CellLabel->
  "In[1267]:=",ExpressionUUID->"4788ce7f-7beb-4162-ae5b-44eb5785764a"],

Cell[CellGroupData[{

Cell["Length[DownValues[verificationReport]]", "Input",
 CellLabel->
