Cell[CellGroupData[{

Cell["10. Comparison with built-in eigendata", "Section",ExpressionUUID->"c4f93c64-47b5-4877-ad85-047870295011"],

Cell["\<\
The built-in eigenvalue order need not agree with Fourier-frequency order, so \
the comparison is made after numerical sorting.\
\>", "Text",ExpressionUUID->"a19629f1-94e3-4476-a287-cc9f14c9aa78"],

Cell["\<\
builtInEigenvalues = Eigenvalues[N[T]];
sortedFourierEigenvalues = SortBy[N[lambdaList], {Re, Im}];
sortedBuiltInEigenvalues = SortBy[builtInEigenvalues, {Re, Im}];
builtInComparisonError = Max[Abs[sortedFourierEigenvalues - \
sortedBuiltInEigenvalues]];
builtInComparisonQ = builtInComparisonError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[1260]:=",ExpressionUUID->"98a3ff8e-f1d1-40f7-b637-4c2356b6b44b"],

Cell[CellGroupData[{

