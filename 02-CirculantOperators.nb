Cell[CellGroupData[{

Cell["2. Constructing the circulant matrix", "Section",ExpressionUUID->"ffbeddb1-27d7-4e65-ba5c-1086756adcca"],

Cell[TextData[{
 "If the first row is ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{
    SubscriptBox["a", "0"], ",", 
    SubscriptBox["a", "1"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["a", 
     RowBox[{"n", "-", "1"}]]}], ")"}]], "InlineFormula",ExpressionUUID->
  "b156375c-ff2a-4913-9fc7-d9309d850182"],
 ", the chapter uses the convention"
}], "Text",ExpressionUUID->"ea0545bc-ee05-483b-9cf6-0e9f6ee9cf09"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["T", 
    RowBox[{"j", ",", "\[ScriptL]"}]], "=", 
   SubscriptBox["a", 
    RowBox[{"\[ScriptL]", "-", "j"}]]}], TraditionalForm]], "DisplayFormula",E\
xpressionUUID->"61fd4e29-829e-4df6-8180-51a49221ef26"],

Cell[TextData[{
 "where the subscript on ",
 Cell[BoxData[
 "a"], "InlineFormula",ExpressionUUID->"09e190c6-22fc-4735-bab0-4455177f0a5d"],
 " is interpreted modulo ",
 Cell[BoxData[
 "n"], "InlineFormula",ExpressionUUID->"aa354ebb-2486-4e30-95a0-410e3e001437"],
 "."
}], "Text",ExpressionUUID->"8304aad6-fded-48d8-ac0b-4abc068813c4"],

Cell["\<\
circulantFromFirstRow[a_List] := Module[{n = Length[a]},
  Table[
    a[[Mod[ell - j, n] + 1]],
    {j, 0, n - 1}, {ell, 0, n - 1}
  ]
];\
\>", "Input",
 CellLabel->
  "In[1210]:=",ExpressionUUID->"cfdce732-d711-432b-975b-c40795f8255d"],

Cell[CellGroupData[{

Cell["\<\
aExample = {2, -1, 3, 0, 4, 1};
T = circulantFromFirstRow[aExample];
T // MatrixForm\
\>", "Input",
 CellLabel->
  "In[1211]:=",ExpressionUUID->"bd7fdfdd-1efa-4122-ac34-51fe66774d21"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"2", 
      RowBox[{"-", "1"}], "3", "0", "4", "1"},
     {"1", "2", 
      RowBox[{"-", "1"}], "3", "0", "4"},
     {"4", "1", "2", 
      RowBox[{"-", "1"}], "3", "0"},
     {"0", "4", "1", "2", 
      RowBox[{"-", "1"}], "3"},
     {"3", "0", "4", "1", "2", 
      RowBox[{"-", "1"}]},
     {
      RowBox[{"-", "1"}], "3", "0", "4", "1", "2"}
    },
