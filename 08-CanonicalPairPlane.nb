Cell[CellGroupData[{

Cell["14. Representative family", "Section",ExpressionUUID->"8db2445c-385b-438b-a22c-9f379b0c9bc6"],

Cell["\<\
shapeParameters = {0.1, 0.3, 0.5, 0.7, 0.9};
representativeFamily = Table[
  Module[{c},
    c = ConstantArray[0, nExample];
    c[[2]] = (1 + q)/2;
    c[[nExample]] = (1 - q)/2;
    fourierSynthesis[c]
  ],
  {q, shapeParameters}
];\
\>", "Input",
 CellLabel->
  "In[2776]:=",ExpressionUUID->"aaf48d0a-7755-4b44-aaf6-fa9bed064b09"],

Cell[CellGroupData[{

Cell["\<\
GraphicsGrid[
  Partition[
    MapThread[
      polygonGraphic[#1, Row[{\"minor/major = \", #2}]] &,
      {representativeFamily, shapeParameters}
    ],
    3,
    3,
    {1, 1},
    Nothing
  ],
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[2778]:=",ExpressionUUID->"ec919703-0510-48a6-94c5-67198698a216"],

