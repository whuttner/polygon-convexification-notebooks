Notebook[{

Cell[CellGroupData[{
Cell["CanonicalPairPlane", "Title",ExpressionUUID->"b24bfd3e-b406-4e1b-b1ad-fa561a8c3244"],

Cell["\<\
Canonical representatives and coordinates for nondegenerate first-harmonic \
data\
\>", "Subtitle",ExpressionUUID->"dd4ce353-eece-4836-a724-01eed9cb2501"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"62d1db16-abd1-4ded-ab9d-2e46ee8c3e22"],

Cell["\<\
This notebook supports the canonical pair-plane constructions in Chapter 3. \
It extracts the first-harmonic component of a polygon, assigns canonical \
coordinates to its nondegenerate pair-plane ellipse, constructs a canonical \
representative, and verifies invariance under translation, rotation, and \
nonzero scaling.\
\>", "Text",ExpressionUUID->"5a3797a3-5361-4450-842a-cf367d3b38b5"],

Cell["\<\
All executable cells are ordinary Wolfram Language Input cells. Typeset box \
expressions appear only in explanatory cells.\
\>", "Text",ExpressionUUID->"363465ce-d11d-403c-bd9d-7b64051ea00b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Fourier and pair-plane definitions", "Section",ExpressionUUID->"10db9c37-5c7d-469f-9572-6d732599dfe4"],

Cell["\<\
ClearAll[\"Global`*\"];

omega[n_Integer?Positive] := Exp[2 Pi I/n];

fourierVector[n_Integer?Positive, k_Integer] :=
  Table[omega[n]^(j k), {j, 0, n - 1}]/Sqrt[n];

fourierMatrix[n_Integer?Positive] :=
  Transpose@Table[fourierVector[n, k], {k, 0, n - 1}];

fourierCoefficients[p_List] := Module[{F},
  F = fourierMatrix[Length[p]];
  ConjugateTranspose[F] . N[p]
];

fourierSynthesis[c_List] :=
  fourierMatrix[Length[c]] . c;

centerPolygon[p_List] :=
  N[p] - Mean[N[p]];

firstHarmonicData[p_List] := Module[{n, c},
  n = Length[p];
  c = fourierCoefficients[p];
  <|
    \"c1\" -> c[[2]],
    \"cNMinus1\" -> c[[n]]
  |>
];

pairPlaneProjection[p_List] := Module[{n, c, result},
  n = Length[p];
  c = fourierCoefficients[p];
  result = ConstantArray[0, n];
  result[[2]] = c[[2]];
  result[[n]] = c[[n]];
  fourierSynthesis[result]
];\
\>", "Input",
 CellLabel->
  "In[2709]:=",ExpressionUUID->"676db42c-bbc2-450d-a692-6dc63087fecf"],

Cell["\<\
nExample = 12;
SeedRandom[5151];
pExample = RandomReal[{-1, 1}, nExample] + I RandomReal[{-1, 1}, nExample];
pExample = centerPolygon[pExample];
pPair = pairPlaneProjection[pExample];\
\>", "Input",
 CellLabel->
  "In[2726]:=",ExpressionUUID->"465aeee2-3cae-4edb-9290-34be4ae7410b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Nondegenerate pair-plane data", "Section",ExpressionUUID->"d1a327b0-285d-4282-895f-6be643bb10e8"],

Cell["For", "Text",ExpressionUUID->"14c51ed5-0ada-437a-b389-d7154b011983"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["p", 
    RowBox[{"\[PlusMinus]", "1"}]], "=", 
   SubscriptBox["c", "1"], 
   SubscriptBox["\[CurlyPhi]", "1"], "+", 
   SubscriptBox["c", 
    RowBox[{"n", "-", "1"}]], 
   SubscriptBox["\[CurlyPhi]", 
    RowBox[{"n", "-", "1"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"ba238cd0-08f0-47bb-aa44-516203ac2237"],

Cell["nondegeneracy means", "Text",ExpressionUUID->"c212ce5d-9e36-4109-8b57-1b87f8a353aa"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"|", 
    SubscriptBox["c", "1"], "|"}], "\[NotEqual]", 
   RowBox[{"|", 
    SubscriptBox["c", 
     RowBox[{"n", "-", "1"}]], "|"}]}], TraditionalForm]], "DisplayFormula",Ex\
pressionUUID->"569fc6fd-d6f6-492e-b0e0-0708deb1a7ff"],

Cell["\<\
nondegeneratePairPlaneQ[p_List, tol_: 10^-10] := Module[{data},
  data = firstHarmonicData[p];
  TrueQ[Abs[Abs[data[\"c1\"]] - Abs[data[\"cNMinus1\"]]] > tol]
];\
\>", "Input",
 CellLabel->
  "In[2731]:=",ExpressionUUID->"cd4e0f28-e9b0-4ceb-9395-b4e802deb4dd"],

Cell[CellGroupData[{

Cell["nondegeneratePairPlaneQ[pExample]", "Input",
 CellLabel->
  "In[2732]:=",ExpressionUUID->"16350497-4c3e-47e4-862c-bd76e5f12fcb"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992805343768108*^9},
 CellLabel->
  "Out[2732]=",ExpressionUUID->"d783364e-d2b0-4888-8f2c-183cfc5ffc1e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Canonical pair-plane coordinates", "Section",ExpressionUUID->"5c827078-7e5b-4bb3-8e75-e62b4edb7da3"],

Cell["\<\
The canonical data are the ordered semi-axis lengths, the orientation angle, \
and the phase angle.\
\>", "Text",ExpressionUUID->"779a8a6d-d850-478f-ae40-2e5e33c41232"],

Cell["\<\
canonicalPairCoordinates[p_List] := Module[
  {data, c1, cN, r1, rN, theta1, thetaN, major, minor, orientation, phase},
  data = firstHarmonicData[p];
  c1 = data[\"c1\"];
  cN = data[\"cNMinus1\"];
  r1 = Abs[c1];
  rN = Abs[cN];
  theta1 = Arg[c1];
  thetaN = Arg[cN];
  major = r1 + rN;
  minor = Abs[r1 - rN];
  orientation = Mod[(theta1 + thetaN)/2, Pi];
  phase = Mod[(theta1 - thetaN)/2, 2 Pi];
  <|
    \"c1\" -> c1,
    \"cNMinus1\" -> cN,
    \"MajorAxis\" -> major,
    \"MinorAxis\" -> minor,
    \"AxisRatio\" -> If[minor == 0, Infinity, major/minor],
    \"Orientation\" -> orientation,
    \"Phase\" -> phase,
    \"OrientationSign\" -> Sign[r1 - rN]
  |>
];\
\>", "Input",
 CellLabel->
  "In[2733]:=",ExpressionUUID->"d4983aaa-a2ef-4750-9873-26779e13312d"],

Cell[CellGroupData[{

Cell["\<\
coordsExample = canonicalPairCoordinates[pExample];
coordsExample\
\>", "Input",
 CellLabel->
  "In[2734]:=",ExpressionUUID->"326dd3a1-cda2-4c6e-ad70-2d146281da1a"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"c1\"\>", "\[Rule]", 
    RowBox[{
     RowBox[{"-", "0.3367446118864339`"}], "+", 
     RowBox[{"1.1495020656791672`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"cNMinus1\"\>", "\[Rule]", 
    RowBox[{"0.23573439211993455`", "\[VeryThinSpace]", "-", 
     RowBox[{"0.39687542074263504`", " ", "\[ImaginaryI]"}]}]}], ",", 
   RowBox[{"\<\"MajorAxis\"\>", "\[Rule]", "1.6594180718131273`"}], ",", 
   RowBox[{"\<\"MinorAxis\"\>", "\[Rule]", "0.7362045467436584`"}], ",", 
   RowBox[{"\<\"AxisRatio\"\>", "\[Rule]", "2.254017689992515`"}], ",", 
   RowBox[{"\<\"Orientation\"\>", "\[Rule]", "0.4104764820664081`"}], ",", 
   RowBox[{"\<\"Phase\"\>", "\[Rule]", "1.4452946485407505`"}], ",", 
   RowBox[{"\<\"OrientationSign\"\>", "\[Rule]", "1"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.992805343781169*^9},
 CellLabel->
  "Out[2735]=",ExpressionUUID->"674ddb43-809d-4826-8611-35884c85fecf"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Canonical coefficient representative", "Section",ExpressionUUID->"e56b1425-13c2-40b1-954f-b24d0f72a7b8"],

Cell["\<\
After removing overall orientation and phase, a nondegenerate pair-plane \
element may be represented by real coefficients whose sum and difference are \
the semi-axis lengths.\
\>", "Text",ExpressionUUID->"e4ee0708-c51f-40de-be86-55e265f406db"],

Cell["\<\
canonicalCoefficients[p_List] := Module[{coords, a, b, s},
  coords = canonicalPairCoordinates[p];
  a = coords[\"MajorAxis\"];
  b = coords[\"MinorAxis\"];
  s = coords[\"OrientationSign\"];
  <|
    \"c1Canonical\" -> (a + s b)/2,
    \"cNMinus1Canonical\" -> (a - s b)/2
  |>
];\
\>", "Input",
 CellLabel->
  "In[2736]:=",ExpressionUUID->"2610c287-d41a-46f6-a981-9ff3318dcf1d"],

Cell[CellGroupData[{

Cell["canonicalCoefficients[pExample]", "Input",
 CellLabel->
  "In[2737]:=",ExpressionUUID->"1368c0b5-a061-4fb3-9439-23b665b74f67"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"c1Canonical\"\>", "\[Rule]", "1.1978113092783929`"}], ",", 
   RowBox[{"\<\"cNMinus1Canonical\"\>", "\[Rule]", "0.4616067625347344`"}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.992805343787652*^9},
 CellLabel->
  "Out[2737]=",ExpressionUUID->"625c528c-78e4-4982-a502-8069ed939ea1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. Canonical pair-plane representative", "Section",ExpressionUUID->"c2e364c1-8186-4a71-a275-62bfe4cdfcf8"],

Cell["\<\
canonicalPairRepresentative[p_List] := Module[{n, coeffs, c},
  n = Length[p];
  coeffs = canonicalCoefficients[p];
  c = ConstantArray[0, n];
  c[[2]] = coeffs[\"c1Canonical\"];
  c[[n]] = coeffs[\"cNMinus1Canonical\"];
  fourierSynthesis[c]
];\
\>", "Input",
 CellLabel->
  "In[2738]:=",ExpressionUUID->"c5a36f5d-644b-4edc-8e38-e78b4f6d6e2e"],

Cell["canonicalExample = canonicalPairRepresentative[pExample];", "Input",
 CellLabel->
  "In[2739]:=",ExpressionUUID->"2390e511-47a1-453c-b2e3-494573affbe9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Reconstruction map", "Section",ExpressionUUID->"8bd35efe-0571-48ab-8819-6bd55058c959"],

Cell["\<\
The original first harmonic is recovered from the canonical representative by \
reintroducing orientation and phase.\
\>", "Text",ExpressionUUID->"52bfaffc-ba3f-4c45-ab76-23218affeb17"],

Cell["\<\
reconstructPairFromCanonical[canonical_List, coords_Association] := Module[
  {n, c, c1Canonical, cNCanonical, psi, delta, result},
  n = Length[canonical];
  c = fourierCoefficients[canonical];
  c1Canonical = c[[2]];
  cNCanonical = c[[n]];
  psi = coords[\"Orientation\"];
  delta = coords[\"Phase\"];
  result = ConstantArray[0, n];
  result[[2]] = c1Canonical Exp[I (psi + delta)];
  result[[n]] = cNCanonical Exp[I (psi - delta)];
  fourierSynthesis[result]
];\
\>", "Input",
 CellLabel->
  "In[2740]:=",ExpressionUUID->"7719872d-3618-46d9-83be-b2cf759703d7"],

Cell["\<\
reconstructedPair = reconstructPairFromCanonical[canonicalExample, \
coordsExample];
reconstructionError = Norm[N[reconstructedPair - pPair]];
reconstructionQ = reconstructionError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2741]:=",ExpressionUUID->"700bb831-3673-4d7d-95a6-95dfdaebe863"],

Cell[CellGroupData[{

Cell["reconstructionError", "Input",
 CellLabel->
  "In[2744]:=",ExpressionUUID->"b00eead1-c343-4081-b70a-16ae08a0bcb6"],

Cell[BoxData["4.266150252213274`*^-16"], "Output",
 CellChangeTimes->{3.99280534381179*^9},
 CellLabel->
  "Out[2744]=",ExpressionUUID->"2ee4686d-df38-491b-af48-8ef94dbec65a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["reconstructionQ", "Input",
 CellLabel->
  "In[2745]:=",ExpressionUUID->"b59792cb-3e75-4e00-a7ff-32a99635e925"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992805343815411*^9},
 CellLabel->
  "Out[2745]=",ExpressionUUID->"e6c47517-ed55-4ca7-962e-dac9bd8707cd"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["7. Scale-free canonical representative", "Section",ExpressionUUID->"5d10ee0c-a7e6-4bdc-9f5c-297c00f3cf15"],

Cell["\<\
Dividing by the major semi-axis removes overall size. The resulting \
representative is determined by the minor-to-major axis ratio.\
\>", "Text",ExpressionUUID->"e5675119-0132-4c8b-bfc3-87476b65624d"],

Cell["\<\
scaleFreeCanonicalRepresentative[p_List] := Module[{canonical, major},
  canonical = canonicalPairRepresentative[p];
  major = canonicalPairCoordinates[p][\"MajorAxis\"];
  canonical/major
];

shapeParameter[p_List] := Module[{coords},
  coords = canonicalPairCoordinates[p];
  coords[\"MinorAxis\"]/coords[\"MajorAxis\"]
];\
\>", "Input",
 CellLabel->
  "In[2746]:=",ExpressionUUID->"c6156293-0928-453c-b512-ee224972ddd7"],

Cell[CellGroupData[{

Cell["\<\
{
  shapeParameter[pExample],
  Norm[scaleFreeCanonicalRepresentative[pExample]]
}\
\>", "Input",
 CellLabel->
  "In[2749]:=",ExpressionUUID->"649f94d6-8988-4772-868a-41b83d60ebe1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.4436522412578407`", ",", "0.7735720106018267`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992805343827845*^9},
 CellLabel->
  "Out[2749]=",ExpressionUUID->"cc32d409-d85e-4d85-9d57-864a4b416763"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["8. Similarity invariance", "Section",ExpressionUUID->"e48261cc-0574-4e92-aeb6-5f1f3111d4d0"],

Cell["\<\
Translation, nonzero complex scaling, and rotation do not change the \
scale-free canonical shape.\
\>", "Text",ExpressionUUID->"d683bc89-fd41-4cc2-8f89-48aadd04722d"],

Cell["\<\
similarityTransform[p_List, eta_, z0_] :=
  eta N[p] + z0;

etaExample = 2.4 Exp[0.73 I];
z0Example = -1.1 + 0.8 I;
pTransformed = similarityTransform[pExample, etaExample, z0Example];\
\>", "Input",
 CellLabel->
  "In[2750]:=",ExpressionUUID->"c0a6b757-5e76-4a75-b820-3c652149e6f5"],

Cell["\<\
shapeInvariantError = Norm[N[
  scaleFreeCanonicalRepresentative[pExample] -
  scaleFreeCanonicalRepresentative[pTransformed]
]];
shapeInvariantQ = shapeInvariantError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2755]:=",ExpressionUUID->"32898488-6614-4ea6-9da2-2b4450acda1c"],

Cell[CellGroupData[{

Cell["shapeInvariantError", "Input",
 CellLabel->
  "In[2757]:=",ExpressionUUID->"383c610f-7622-4c09-848d-f12f01f1713b"],

Cell[BoxData["1.7880278822442372`*^-16"], "Output",
 CellChangeTimes->{3.992805343844893*^9},
 CellLabel->
  "Out[2757]=",ExpressionUUID->"4c5d674c-b792-469c-a008-5cfcda865d2f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["shapeInvariantQ", "Input",
 CellLabel->
  "In[2758]:=",ExpressionUUID->"ea3e9578-f3bd-4860-addf-4b3be9483edd"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992805343848197*^9},
 CellLabel->
  "Out[2758]=",ExpressionUUID->"d800b916-cc93-41ff-9039-452cf41f2ea1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["9. Coordinate transformation under similarity", "Section",ExpressionUUID->"28fbe8db-09ad-4ee2-97f8-b722b47c3968"],

Cell[CellGroupData[{

Cell["\<\
coordsTransformed = canonicalPairCoordinates[pTransformed];
coordinateComparison = <|
  \"AxisRatioOriginal\" -> coordsExample[\"AxisRatio\"],
  \"AxisRatioTransformed\" -> coordsTransformed[\"AxisRatio\"],
  \"OrientationShift\" -> Mod[
    coordsTransformed[\"Orientation\"] - coordsExample[\"Orientation\"],
    Pi
  ],
  \"ExpectedOrientationShift\" -> Mod[Arg[etaExample], Pi],
  \"ScaleFactor\" -> \
coordsTransformed[\"MajorAxis\"]/coordsExample[\"MajorAxis\"],
  \"ExpectedScaleFactor\" -> Abs[etaExample]
|>;
coordinateComparison\
\>", "Input",
 CellLabel->
  "In[2759]:=",ExpressionUUID->"c45bdc7f-f2c4-482a-a1ed-4e150941a10c"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"AxisRatioOriginal\"\>", "\[Rule]", "2.254017689992515`"}], ",", 
   RowBox[{"\<\"AxisRatioTransformed\"\>", "\[Rule]", "2.254017689992514`"}], 
   ",", 
   RowBox[{"\<\"OrientationShift\"\>", "\[Rule]", "0.7299999999999999`"}], ",", 
   RowBox[{"\<\"ExpectedOrientationShift\"\>", "\[Rule]", "0.73`"}], ",", 
   RowBox[{"\<\"ScaleFactor\"\>", "\[Rule]", "2.4000000000000004`"}], ",", 
   RowBox[{"\<\"ExpectedScaleFactor\"\>", "\[Rule]", 
    "2.4000000000000004`"}]}], "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.9928053438514853`*^9},
 CellLabel->
  "Out[2761]=",ExpressionUUID->"0e6faf77-9ca4-4012-93bb-0afb1d941a64"]
}, Open  ]],

Cell["\<\
orientationShiftError = Abs[N[
  Sin[
    coordinateComparison[\"OrientationShift\"] -
    coordinateComparison[\"ExpectedOrientationShift\"]
  ]
]];
scaleFactorError = Abs[N[
  coordinateComparison[\"ScaleFactor\"] -
  coordinateComparison[\"ExpectedScaleFactor\"]
]];\
\>", "Input",
 CellLabel->
  "In[2762]:=",ExpressionUUID->"814061cb-3b26-4a83-b92f-40dff1e11300"],

Cell[CellGroupData[{

Cell["{orientationShiftError, scaleFactorError}", "Input",
 CellLabel->
  "In[2764]:=",ExpressionUUID->"848bdf3f-3bc5-4ddb-943a-c2991f6d7887"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.1102230246251565`*^-16", ",", "0.`"}], "}"}]], "Output",
 CellChangeTimes->{3.992805343862618*^9},
 CellLabel->
  "Out[2764]=",ExpressionUUID->"3a0c44fb-fad1-4d19-aa50-aaba9ee0fd60"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Canonical uniqueness test", "Section",ExpressionUUID->"fe93a773-e8f7-448c-bc22-eb9453f1b174"],

Cell["\<\
Two nondegenerate first-harmonic polygons have the same scale-free canonical \
representative exactly when their pair-plane ellipses differ only by \
translation and nonzero complex scaling.\
\>", "Text",ExpressionUUID->"aaa8e65a-e55c-4445-8a85-debe5aa4f570"],

Cell["\<\
sameCanonicalShapeQ[p_List, q_List, tol_: 10^-10] :=
  TrueQ[
    Norm[N[
      scaleFreeCanonicalRepresentative[p] -
      scaleFreeCanonicalRepresentative[q]
    ]] < tol
  ];\
\>", "Input",
 CellLabel->
  "In[2765]:=",ExpressionUUID->"7150bf9e-887f-4f14-be31-c92a7bc47cd7"],

Cell[CellGroupData[{

Cell["\<\
{
  sameCanonicalShapeQ[pExample, pTransformed],
  sameCanonicalShapeQ[pExample, pExample + 0.2 fourierVector[nExample, 2]]
}\
\>", "Input",
 CellLabel->
  "In[2766]:=",ExpressionUUID->"1cbd4bed-e273-470c-9c71-84cc498ed112"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"True", ",", "True"}], "}"}]], "Output",
 CellChangeTimes->{3.992805343893084*^9},
 CellLabel->
  "Out[2766]=",ExpressionUUID->"f16a40b2-654e-4363-85d3-0751ddeefdf8"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["11. Canonical pair-plane basis coordinates", "Section",ExpressionUUID->"63312707-903f-4ca4-b240-3f705cb0dc2d"],

Cell["\<\
canonicalBasisCoordinates[p_List] := Module[{canonical, c, n},
  canonical = canonicalPairRepresentative[p];
  n = Length[p];
  c = fourierCoefficients[canonical];
  {c[[2]], c[[n]]}
];\
\>", "Input",
 CellLabel->
  "In[2767]:=",ExpressionUUID->"07407a91-1a6b-4f39-b819-49114edc8d59"],

Cell[CellGroupData[{

Cell["canonicalBasisCoordinates[pExample]", "Input",
 CellLabel->
  "In[2768]:=",ExpressionUUID->"ebba773c-9c0c-4585-a705-0fbad73b8ea2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"1.197811309278393`", "\[VeryThinSpace]", "+", 
    RowBox[{"0.`", " ", "\[ImaginaryI]"}]}], ",", 
   RowBox[{"0.4616067625347347`", "\[VeryThinSpace]", "-", 
    RowBox[{"1.3877787807814457`*^-17", " ", "\[ImaginaryI]"}]}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992805343902933*^9},
 CellLabel->
  "Out[2768]=",ExpressionUUID->"bcd0cfef-3799-45f9-946d-1aaffdc93ce2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["12. Axis-ratio and eccentricity invariants", "Section",ExpressionUUID->"e3259ea5-cd2f-482a-a69a-c80c1a65524a"],

Cell[CellGroupData[{

Cell["\<\
canonicalEccentricity[p_List] := Module[{q},
  q = shapeParameter[p];
  Sqrt[Max[0, 1 - q^2]]
];

{
  shapeParameter[pExample],
  canonicalEccentricity[pExample],
  canonicalEccentricity[pTransformed]
}\
\>", "Input",
 CellLabel->
  "In[2769]:=",ExpressionUUID->"cf146938-48b9-44dc-ad1d-cd0d7c31f60f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "0.4436522412578407`", ",", "0.896199023000413`", ",", 
   "0.8961990230004129`"}], "}"}]], "Output",
 CellChangeTimes->{3.992805343912918*^9},
 CellLabel->
  "Out[2771]=",ExpressionUUID->"ff5c4297-9733-4368-9c50-14205236b7e2"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["13. Visualization", "Section",ExpressionUUID->"a31b9890-454b-4e85-ad82-1cfe9a387588"],

Cell["\<\
complexPoints[p_List] :=
  N@Transpose[{Re[N[p]], Im[N[p]]}];

polygonGraphic[p_List, title_] := Module[{pts},
  pts = complexPoints[p];
  Graphics[
    {
      Thick,
      Line[Append[pts, First[pts]]],
      PointSize[0.018],
      Point[pts]
    },
    Axes -> True,
    AspectRatio -> 1,
    PlotRange -> All,
    PlotLabel -> title,
    ImageSize -> Large
  ]
];\
\>", "Input",
 CellLabel->
  "In[2772]:=",ExpressionUUID->"01842842-58a3-4d51-a1fd-f7bb840d9923"],

