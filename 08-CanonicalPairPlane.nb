  {
    polygonGraphic[pPair, \"Original first harmonic\"],
    polygonGraphic[canonicalExample, \"Canonical pair-plane \
representative\"],
    polygonGraphic[
      scaleFreeCanonicalRepresentative[pExample],
      \"Scale-free canonical representative\"
    ]
  },
  ImageSize -> Large
]\
\>", "Input",
