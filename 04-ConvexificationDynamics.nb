    {"25", "0.2464862497121528`", "0.6354971566378393`"},
    {"30", "0.15127670676312105`", "0.39007471454814063`"},
    {"35", "0.09285315516813089`", "0.23943188626495499`"},
    {"40", "0.056994005282951996`", "0.146965763281535`"},
    {"45", "0.034983485170391175`", "0.09020910252957208`"},
    {"50", "0.02147322177828224`", "0.05537127829970778`"}
   },
   GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
   GridBoxSpacings->{"Columns" -> {
