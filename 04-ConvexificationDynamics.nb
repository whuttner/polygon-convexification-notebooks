Cell[CellGroupData[{

Cell["Conclusion", "Section",ExpressionUUID->"5d7e6b7a-407d-4760-8ba2-641fac7c9d9c"],

Cell[TextData[{
 "The computations exhibit the mechanism behind convexification dynamics: the \
first-harmonic pair ",
 Cell[BoxData[
  SubscriptBox["E", 
   RowBox[{"\[PlusMinus]", "1"}]]], "InlineFormula",ExpressionUUID->
  "1b3dd073-cd1c-46df-9232-7cc6f06db8a6"],
 " decays more slowly than all higher Fourier modes, so the relative \
higher-mode contribution decreases geometrically at a rate controlled by ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Mu]", "2"], "/", 
   SubscriptBox["\[Mu]", "1"]}]], "InlineFormula",ExpressionUUID->
  "24428591-d014-4794-a38e-7b9146fca574"],
 ". The shape-normalized iterates therefore approach the pair-plane."
}], "Text",ExpressionUUID->"6a47d17e-6d8b-438b-a0b8-226f82f8adc3"]
}, Open  ]]
}, Open  ]]
},
