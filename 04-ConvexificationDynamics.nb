 CellLabel->
  "Out[2076]//TableForm=",ExpressionUUID->"8207ef47-520b-459f-98dc-\
035b8dc6dbef"]
}, Open  ]],

Cell["\<\
dominanceResiduals = Table[
  dominanceRatio[pExample, alphaExample, m] - dominanceBound[pExample, \
alphaExample, m],
  {m, 0, 50}
];
maxDominanceResidual = Max[dominanceResiduals];
dominanceQ = maxDominanceResidual < 10^-9;\
\>", "Input",
 CellLabel->
  "In[2077]:=",ExpressionUUID->"cc1d5e3c-c733-4256-b3b4-ad78fe9b7891"],

