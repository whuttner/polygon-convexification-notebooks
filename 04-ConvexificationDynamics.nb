Cell[CellGroupData[{

Cell["7. Empirical decay rate", "Section",ExpressionUUID->"24e8a06e-229c-4f74-a188-14e458aa75d0"],

Cell[TextData[{
 "The logarithm of the dominance ratio should be approximately affine in ",
 Cell[BoxData[
 "m"], "InlineFormula",ExpressionUUID->"1fa6f3d8-6814-4d3a-84db-8f5274cdc9cd"],
 ", with slope ",
 Cell[BoxData[
  RowBox[{"log", "\[Rho]"}]], "InlineFormula",ExpressionUUID->
  "2a1b8bef-e8f8-45cc-b703-df2f99fe019c"],
 "."
}], "Text",ExpressionUUID->"fafde360-f7df-48b8-bf23-dcf850c34f0e"],

Cell["\<\
fitRange = Range[5, 50];
fitData = Table[
  {m, Log[dominanceRatio[pExample, alphaExample, m]]},
  {m, fitRange}
];
linearFit = LinearModelFit[fitData, m, m];
empiricalSlope = linearFit[\"BestFitParameters\"][[2]];
theoreticalSlope = Log[rhoExample];
slopeError = Abs[empiricalSlope - theoreticalSlope];\
\>", "Input",
 CellLabel->
  "In[2091]:=",ExpressionUUID->"d31f320c-de05-403f-bdb5-473ced9bb894"],

Cell[CellGroupData[{

Cell["{empiricalSlope, theoreticalSlope, slopeError}", "Input",
 CellLabel->
  "In[2097]:=",ExpressionUUID->"4ce9cdb8-c0e3-45cf-bfb6-450a2dfc8982"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "0.09888731055352006`"}], ",", 
   RowBox[{"-", "0.09761386397339065`"}], ",", "0.0012734465801294004`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992802594004649*^9},
 CellLabel->
  "Out[2097]=",ExpressionUUID->"ce28fd0b-d1ba-45fc-bdca-15e338a8ff6d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Show[
  ListPlot[fitData, PlotMarkers -> Automatic],
  Plot[linearFit[m], {m, Min[fitRange], Max[fitRange]}],
  AxesLabel -> {\"m\", \"log dominance ratio\"},
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[2098]:=",ExpressionUUID->"9aa8ac72-43b2-4c6a-8c63-d2a7b10f7027"],

