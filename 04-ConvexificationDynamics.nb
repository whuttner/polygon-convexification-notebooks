Notebook[{

Cell[CellGroupData[{
Cell["ConvexificationDynamics", "Title",ExpressionUUID->"461f4f82-186c-4d6d-9923-2db782f7ad5f"],

Cell["\<\
Quantitative mode dominance and convergence to the pair-plane\
\>", "Subtitle",ExpressionUUID->"2cd2ed5f-9e8a-4abb-b547-c25f0b85a3d6"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"3f99eb86-8519-46b5-abc6-2b8ae0e9fca0"],

Cell[TextData[{
 "This notebook isolates the dynamical part of Chapter 2. It studies repeated \
application of the averaging operator ",
 Cell[BoxData[
  SubscriptBox["A", "\[Alpha]"]], "InlineFormula",ExpressionUUID->
  "de101fbe-04d0-4818-8a5c-bd4f2d6907c6"],
 ", decomposes polygon data into the first-harmonic pair-plane ",
 Cell[BoxData[
  SubscriptBox["E", 
   RowBox[{"\[PlusMinus]", "1"}]]], "InlineFormula",ExpressionUUID->
  "cf64eea8-a50f-4f65-b9c3-d697d88073d4"],
 " and its higher-mode complement, and compares the observed decay of higher \
modes with the spectral estimate."
}], "Text",ExpressionUUID->"31dd6860-e8bd-434c-b0a0-424c39a06524"],

Cell["\<\
All executable cells are ordinary Wolfram Language input. Typeset boxes are \
used only in explanatory text.\
\>", "Text",ExpressionUUID->"8782d2a0-dcf6-4876-991d-448406ad4be8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Definitions", "Section",ExpressionUUID->"ed0a5d35-74c6-4148-9d0c-25af34019fc3"],

Cell["\<\
ClearAll[\"Global`*\"];

omega[n_Integer?Positive] := Exp[2 Pi I/n];

fourierVector[n_Integer?Positive, k_Integer] :=
  Table[omega[n]^(j k), {j, 0, n - 1}]/Sqrt[n];

fourierMatrix[n_Integer?Positive] :=
  Transpose@Table[fourierVector[n, k], {k, 0, n - 1}];

averagingMatrix[n_Integer?Positive, alpha_?NumericQ] :=
  Table[
    (1 - alpha) Boole[ell == j] + alpha Boole[ell == Mod[j + 1, n]],
    {j, 0, n - 1}, {ell, 0, n - 1}
  ];

applyA[p_List, alpha_?NumericQ] :=
  (1 - alpha) p + alpha RotateLeft[p];

lambda[n_Integer?Positive, k_Integer, alpha_] :=
  (1 - alpha) + alpha Exp[2 Pi I k/n];

mu[n_Integer?Positive, k_Integer, alpha_] :=
  Abs[lambda[n, k, alpha]];\
\>", "Input",
 CellLabel->
  "In[2008]:=",ExpressionUUID->"3d525e27-a9e4-490d-90ca-bb310f6477a3"],

Cell["The operator is", "Text",ExpressionUUID->"371a5fd8-178c-4a9c-b625-00e61aaea76b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "\[Alpha]"], "p"}], ")"}], "j"], "=", 
   RowBox[{"(", 
    RowBox[{"1", "-", "\[Alpha]"}], ")"}], 
   SubscriptBox["p", "j"], "+", "\[Alpha]", 
   SubscriptBox["p", 
    RowBox[{"j", "+", "1"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"8e1d025d-17d1-4633-892d-b9fe1a9e2fe2"],

Cell["\<\
nExample = 12;
alphaExample = 0.35;
A = averagingMatrix[nExample, alphaExample];\
\>", "Input",
 CellLabel->
  "In[2023]:=",ExpressionUUID->"5a0a6d4b-8346-44ce-a882-a319ff42dd10"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Fourier diagonalization", "Section",ExpressionUUID->"c27711a7-6a91-4faa-9d54-0af46e0cf17b"],

Cell["The Fourier eigenvalues are", "Text",ExpressionUUID->"78749b5a-6035-44cc-a9d7-d1dbba843768"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Lambda]", "k"], "=", 
   RowBox[{"(", 
    RowBox[{"1", "-", "\[Alpha]"}], ")"}], "+", "\[Alpha]", 
   SuperscriptBox["e", 
    FractionBox[
     RowBox[{"2", "\[Pi]", "i", "k"}], "n"]]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"b8e4f3dc-1c1f-42d3-\
99eb-971504cf044b"],

Cell["\<\
F = fourierMatrix[nExample];
lambdaList = Table[lambda[nExample, k, alphaExample], {k, 0, nExample - 1}];
diagonalizedA = Chop[ConjugateTranspose[F] . A . F];
diagonalizationError = Max[Abs[Flatten[N[diagonalizedA - \
DiagonalMatrix[lambdaList]]]]];
diagonalizationQ = diagonalizationError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2026]:=",ExpressionUUID->"0e3a472c-6f67-465a-98a8-1935d00897e7"],

Cell[CellGroupData[{

Cell["diagonalizationError", "Input",
 CellLabel->
  "In[2031]:=",ExpressionUUID->"c123bae6-15d6-4b91-8125-e22867c97dcf"],

Cell[BoxData["3.433175098891678`*^-16"], "Output",
 CellChangeTimes->{3.992802591423312*^9},
 CellLabel->
  "Out[2031]=",ExpressionUUID->"6cb0e11e-22c5-4872-87fd-75675c9a2a45"]
}, Open  ]],

Cell[CellGroupData[{

Cell["diagonalizationQ", "Input",
 CellLabel->
  "In[2032]:=",ExpressionUUID->"fb19d68b-0613-41f6-85db-b9fa9d8e8771"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.9928025914276037`*^9},
 CellLabel->
  "Out[2032]=",ExpressionUUID->"2569ff24-010f-4c60-982d-e0949c077fb9"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Fourier decomposition of polygon data", "Section",ExpressionUUID->"ebe9438a-bec7-4f74-9ded-c23813415e98"],

Cell["\<\
fourierCoefficients[p_List] := Module[{F = fourierMatrix[Length[p]]},
  ConjugateTranspose[F] . p
];

reconstructFromCoefficients[c_List] := Module[{F = fourierMatrix[Length[c]]},
  F . c
];

centerPolygon[p_List] := p - Mean[p];

pairPlaneCoefficients[p_List] := Module[{n = Length[p], c = \
fourierCoefficients[p], result},
  result = ConstantArray[0, n];
  result[[2]] = c[[2]];
  result[[n]] = c[[n]];
  result
];

higherModeCoefficients[p_List] := Module[{n = Length[p], c = \
fourierCoefficients[p], result},
  result = c;
  result[[1]] = 0;
  result[[2]] = 0;
  result[[n]] = 0;
  result
];

pairPlaneProjection[p_List] :=
  reconstructFromCoefficients[pairPlaneCoefficients[p]];

higherModeProjection[p_List] :=
  reconstructFromCoefficients[higherModeCoefficients[p]];\
\>", "Input",
 CellLabel->
  "In[2033]:=",ExpressionUUID->"f215ec9a-f1ff-41b7-9d16-739e8aa65693"],

Cell["\<\
SeedRandom[2026];
pExample = RandomReal[{-1, 1}, nExample] + I RandomReal[{-1, 1}, nExample];
pExample = centerPolygon[pExample];

xExample = pairPlaneProjection[pExample];
yExample = higherModeProjection[pExample];
decompositionError = Norm[pExample - xExample - yExample];
decompositionQ = decompositionError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[2046]:=",ExpressionUUID->"127d0335-ce15-4118-9505-89b6d8c09964"],

Cell[CellGroupData[{

Cell["decompositionError", "Input",
 CellLabel->
  "In[2054]:=",ExpressionUUID->"81e115cb-6db2-4842-a2be-3272b23087ae"],

Cell[BoxData["1.0046789954275695`*^-15"], "Output",
 CellChangeTimes->{3.9928025914438963`*^9},
 CellLabel->
  "Out[2054]=",ExpressionUUID->"5d6e21de-2b85-4338-bf8b-c6b59038833e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["decompositionQ", "Input",
 CellLabel->
  "In[2055]:=",ExpressionUUID->"4f64ec88-f1c1-479e-8c9a-f3b64137f7ea"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992802591447193*^9},
 CellLabel->
  "Out[2055]=",ExpressionUUID->"7d0640a1-80f7-41aa-91f3-af619517391e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Iteration in physical and Fourier coordinates", "Section",ExpressionUUID->"aa2b3e52-17c4-4596-8253-35631a3b51a6"],

Cell["\<\
iteratePhysical[p_List, alpha_?NumericQ, m_Integer?NonNegative] :=
  Nest[applyA[#, alpha] &, N[p], m];

iterateFourier[p_List, alpha_?NumericQ, m_Integer?NonNegative] := Module[
  {n = Length[p], c, factors},
  c = fourierCoefficients[p];
  factors = Table[lambda[n, k, alpha]^m, {k, 0, n - 1}];
  reconstructFromCoefficients[factors c]
];\
\>", "Input",
 CellLabel->
  "In[2056]:=",ExpressionUUID->"cfa0f90e-24dd-4622-921f-f444110adcab"],

Cell["\<\
iterationAgreementError = Max@Table[
  Norm[iteratePhysical[pExample, alphaExample, m] - iterateFourier[pExample, \
alphaExample, m]],
  {m, 0, 30}
];
iterationAgreementQ = iterationAgreementError < 10^-9;\
\>", "Input",
 CellLabel->
  "In[2059]:=",ExpressionUUID->"34360d74-59f8-4dda-a7d2-33a5294bd149"],

Cell[CellGroupData[{

Cell["iterationAgreementError", "Input",
 CellLabel->
  "In[2061]:=",ExpressionUUID->"c1e8931e-9568-4d92-82fe-f3a320729b4d"],

Cell[BoxData["1.0336856065293927`*^-15"], "Output",
 CellChangeTimes->{3.992802591535921*^9},
 CellLabel->
  "Out[2061]=",ExpressionUUID->"99175ff4-c029-4277-978f-3d1e6e274b93"]
}, Open  ]],

Cell[CellGroupData[{

Cell["iterationAgreementQ", "Input",
 CellLabel->
  "In[2062]:=",ExpressionUUID->"7667b94e-c135-498f-9767-ee5f7024b228"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.992802591543201*^9},
 CellLabel->
  "Out[2062]=",ExpressionUUID->"2b78e6a9-a6d5-4228-8ea1-9d0e905b860c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. Quantitative mode dominance", "Section",ExpressionUUID->"5718ad6a-3162-49e8-9fcf-5484120ffcee"],

Cell[TextData[{
 "Write ",
 Cell[BoxData[
  RowBox[{"p", "=", "x", "+", "y"}]], "InlineFormula",ExpressionUUID->
  "99643dc3-2084-4731-a30d-79ca26cf89f1"],
 " with ",
 Cell[BoxData[
  RowBox[{"x", "\[Element]", 
   SubscriptBox["E", 
    RowBox[{"\[PlusMinus]", "1"}]]}]], "InlineFormula",ExpressionUUID->
  "f3da955c-5310-4a4e-8ff6-e90ff49782f8"],
 " and ",
 Cell[BoxData[
  RowBox[{"y", "\[Element]", 
   SuperscriptBox[
    SubscriptBox["E", 
     RowBox[{"\[PlusMinus]", "1"}]], "\[Perpendicular]"]}]], "InlineFormula",
  ExpressionUUID->"76cea860-d861-4d0b-873c-9f8344b82f17"],
 ". The relevant decay factor is"
}], "Text",ExpressionUUID->"ef2cd5d9-cb2b-4278-8a61-598a2a8f3fff"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[Rho]", "=", 
   FractionBox[
    SubscriptBox["\[Mu]", "2"], 
    SubscriptBox["\[Mu]", "1"]], "<", "1"}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"2946f641-8d53-444a-\
b8d9-8d1397550d62"],

Cell["\<\
modeNorms[p_List] := Module[{c = fourierCoefficients[p], n = Length[p]},
  <|
    \"PairPlane\" -> Sqrt[Abs[c[[2]]]^2 + Abs[c[[n]]]^2],
    \"HigherModes\" -> Sqrt[Total[Abs[c[[3 ;; n - 1]]]^2]]
  |>
];

modeConstant[p_List] := Module[{norms = modeNorms[p]},
  norms[\"HigherModes\"]/norms[\"PairPlane\"]
];

spectralRatio[n_Integer?Positive, alpha_?NumericQ] :=
  mu[n, 2, alpha]/mu[n, 1, alpha];

dominanceRatio[p_List, alpha_?NumericQ, m_Integer?NonNegative] := Module[
  {iterate, pairNorm, higherNorm},
  iterate = iterateFourier[p, alpha, m];
  pairNorm = Norm[pairPlaneProjection[iterate]];
  higherNorm = Norm[higherModeProjection[iterate]];
  higherNorm/pairNorm
];

dominanceBound[p_List, alpha_?NumericQ, m_Integer?NonNegative] :=
  modeConstant[p] spectralRatio[Length[p], alpha]^m;\
\>", "Input",
 CellLabel->
  "In[2063]:=",ExpressionUUID->"0ae6c8b3-88d3-4492-a591-a47d2ccc34ca"],

Cell[CellGroupData[{

Cell["\<\
rhoExample = spectralRatio[nExample, alphaExample];
CExample = modeConstant[pExample];
{rhoExample, CExample}\
\>", "Input",
 CellLabel->
  "In[2072]:=",ExpressionUUID->"7761ddaa-fae6-46e9-9e73-9f653948fabe"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.90699906115899`", ",", "7.2936122931608365`"}], "}"}]], "Output",\

 CellChangeTimes->{3.992802591549067*^9},
 CellLabel->
  "Out[2074]=",ExpressionUUID->"8d36d34b-6430-4c09-99a5-42f30c81540b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
dominanceTable = Table[
  {
    m,
    dominanceRatio[pExample, alphaExample, m],
    dominanceBound[pExample, alphaExample, m]
  },
  {m, 0, 50, 5}
];
dominanceTable // TableForm\
\>", "Input",
 CellLabel->
  "In[2075]:=",ExpressionUUID->"229fd2fc-1d86-4a76-89b2-ecbcd09dcab3"],

Cell[BoxData[
 TagBox[GridBox[{
    {"0", "7.2936122931608365`", "7.2936122931608365`"},
