Cell[CellGroupData[{

Cell["8. Polygon visualization", "Section",ExpressionUUID->"6c3ea936-0c81-47c0-9941-d4b799c8a594"],

Cell["\<\
Clear[polygonPoints, polygonPlot];

polygonPoints[p_List] := N@Transpose[{Re[p], Im[p]}];

polygonPlot[p_List, title_: None] := Module[{pts},
  pts = polygonPoints[p];
  Graphics[
    {
      Thick,
      Line[Append[pts, First[pts]]],
      PointSize[0.018],
      Point[pts]
    },
    Axes -> True,
    AspectRatio -> 1,
    PlotRange -> All,
    PlotLabel -> title,
    ImageSize -> Large
  ]
];\
\>", "Input",
 CellLabel->
  "In[2099]:=",ExpressionUUID->"28f1a823-8eb5-4b47-8bee-5d95a76fc526"],

Cell[CellGroupData[{

Cell["\<\
GraphicsRow[
  {
    polygonPlot[pExample, \"Initial centered polygon\"],
    polygonPlot[iteratePhysical[pExample, alphaExample, 10], \"After 10 \
iterations\"],
    polygonPlot[iteratePhysical[pExample, alphaExample, 40], \"After 40 \
iterations\"]
  },
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[2104]:=",ExpressionUUID->"5b74556c-14aa-4a64-8c94-ee91ce125a89"],

