Cell[TextData[{
 "The first cell above always produces a static plot. The animation is then \
built from precomputed graphics using ",
 StyleBox["ListAnimate",
  FontFamily->"Source Code Pro"],
 ", avoiding reliance on a held ",
 StyleBox["Manipulate",
  FontFamily->"Source Code Pro"],
 " expression."
}], "Text",ExpressionUUID->"13b54730-c5e3-4748-be96-242683498c85"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Mode-amplitude evolution", "Section",ExpressionUUID->"03b7ae11-90e5-4a6b-b3db-18e43f2e395c"],

Cell["\<\
modeAmplitudeTable[p_List, alpha_?NumericQ, maxM_Integer?NonNegative] := \
Module[
  {n = Length[p], c = fourierCoefficients[p]},
  Table[
    Prepend[
      Table[Abs[c[[k + 1]] lambda[n, k, alpha]^m], {k, 1, n - 1}],
      m
    ],
    {m, 0, maxM}
  ]
];

amplitudeData = modeAmplitudeTable[pExample, alphaExample, 50];\
\>", "Input",
 CellLabel->
  "In[2112]:=",ExpressionUUID->"f05ad704-fd9c-4f9a-ade6-1488e75c1123"],

Cell[CellGroupData[{

Cell["\<\
ListLogPlot[
  Table[
    Table[{row[[1]], row[[k + 1]]}, {row, amplitudeData}],
    {k, 1, nExample - 1}
  ],
  Joined -> True,
  AxesLabel -> {\"iteration m\", \"mode amplitude\"},
  PlotRange -> All,
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[2115]:=",ExpressionUUID->"761b602c-1c79-4f2b-ba3e-7b31bd294ada"],

