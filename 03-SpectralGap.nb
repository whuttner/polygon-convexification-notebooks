Cell[CellGroupData[{

Cell["9. Dependence on alpha", "Section",ExpressionUUID->"77355412-63c6-4dd8-9931-e4ccdb812658"],

Cell[TextData[{
 "The leading asymptotic coefficient ",
 Cell[BoxData[
  RowBox[{"6", 
   SuperscriptBox["\[Pi]", "2"], "\[Alpha]", 
   RowBox[{"(", 
    RowBox[{"1", "-", "\[Alpha]"}], ")"}]}]], "InlineFormula",ExpressionUUID->
  "cdd9b311-5fd5-4778-8321-c4fc6d5bfb49"],
 " is symmetric about ",
 Cell[BoxData[
  RowBox[{"\[Alpha]", "=", 
   FractionBox["1", "2"]}]], "InlineFormula",ExpressionUUID->
  "d9f2672d-bfb3-4e1f-b977-c3917dbccb4e"],
 " and is maximal there."
}], "Text",ExpressionUUID->"492f7c9c-83ab-4004-8f42-052388a67726"],

Cell[CellGroupData[{

Cell["\<\
alphaGrid = Range[0.02, 0.98, 0.02];

ListLinePlot[
  Table[{alpha, gamma[40, alpha]}, {alpha, alphaGrid}],
  AxesLabel -> {\"alpha\", \"gamma_40(alpha)\"},
  PlotRange -> All,
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[1180]:=",ExpressionUUID->"50b8af1b-e69b-4adc-89a8-b5b7b3684071"],

