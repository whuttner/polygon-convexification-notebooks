Cell["\<\
ListLogPlot[
  Table[{n, relativeAsymptoticError[n, alphaExample]}, {n, 10, 500}],
  Joined -> True,
  AxesLabel -> {\"n\", \"relative asymptotic error\"},
  PlotRange -> All,
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
