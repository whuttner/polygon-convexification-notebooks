84958831504a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Fourier diagonalization", "Section",ExpressionUUID->"434f0912-71dd-4283-901a-f4fd8b645c56"],

Cell["\<\
F = fourierMatrix[nExample];
lambdaList = Table[lambda[nExample, k, alphaExample], {k, 0, nExample - 1}];
diagonalizedA = Chop[ConjugateTranspose[F] . A . F];
expectedDiagonal = DiagonalMatrix[lambdaList];
diagonalizationError = Max[Abs[Flatten[N[diagonalizedA - \
expectedDiagonal]]]];
diagonalizationQ = diagonalizationError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[1137]:=",ExpressionUUID->"844a557f-7d10-43f4-8de0-25f18f32a3b4"],

