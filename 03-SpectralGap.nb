Cell[CellGroupData[{

Cell["\<\
alphaSymmetryError[n_Integer?Positive, alpha_?NumericQ] :=
  Abs[N[gamma[n, alpha] - gamma[n, 1 - alpha]]];

Table[
  {alpha, alphaSymmetryError[40, alpha]},
  {alpha, {0.1, 0.2, 0.3, 0.4}}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[1183]:=",ExpressionUUID->"482754c0-9bb0-48d8-bb76-abea5d718356"],

Cell[BoxData[
 TagBox[GridBox[{
    {"0.1`", "2.211772431870429`*^-16"},
    {"0.2`", "0.`"},
    {"0.3`", "0.`"},
    {"0.4`", "0.`"}
   },
   GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
   GridBoxSpacings->{"Columns" -> {
       Offset[0.27999999999999997`], {
        Offset[2.0999999999999996`]}, 
       Offset[0.27999999999999997`]}, "Rows" -> {
       Offset[0.2], {
        Offset[0.4]}, 
       Offset[0.2]}}],
  Function[BoxForm`e$, 
   TableForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.992800834750038*^9},
 CellLabel->
  "Out[1185]//TableForm=",ExpressionUUID->"94c14292-73f4-443a-afb4-\
a1ee2883df65"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
optimalAlphaNumerical[n_Integer?Positive] := Module[{result},
  result = NMaximize[{gamma[n, alpha], 0 < alpha < 1}, alpha];
  {alpha /. Last[result], First[result]}
];

optimalAlphaNumerical[40]\
\>", "Input",
 CellLabel->
  "In[1186]:=",ExpressionUUID->"8eb22d3c-77c5-4698-930c-d4f1c9a8f2f8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.49999999980248744`", ",", "0.009300648269344418`"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992800834824872*^9},
 CellLabel->
  "Out[1188]=",ExpressionUUID->"3c67293a-be7b-481e-8d60-9fc90d187d78"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Gap and suppression time", "Section",ExpressionUUID->"be1cfcd1-3448-49eb-ab03-7c8ff4e25b5d"],

Cell[TextData[{
 "If a relative mode contribution is bounded by ",
 Cell[BoxData[
  RowBox[{"C", 
   SuperscriptBox["e", 
    RowBox[{"-", "m", 
     SubscriptBox["\[Gamma]", "n"]}]]}]], "InlineFormula",ExpressionUUID->
  "f0fdf6bf-5eba-42e7-9696-24280d1edef5"],
 ", then the iterations needed to reduce it below ",
 Cell[BoxData[
 "\[Epsilon]"], "InlineFormula",ExpressionUUID->
  "31939a3a-3dc1-4266-b5cb-08fceeebd519"],
 " are estimated by"
}], "Text",ExpressionUUID->"da959da3-850f-44fb-b48e-928aa17dd157"],

Cell[BoxData[
 FormBox[
  RowBox[{"m", "\[GreaterEqual]", 
   FractionBox[
    RowBox[{"log", 
     RowBox[{"(", 
      RowBox[{"C", "/", "\[Epsilon]"}], ")"}]}], 
    SubscriptBox["\[Gamma]", "n"]]}], TraditionalForm]], "DisplayFormula",Expr\
essionUUID->"cbe0609d-1988-453d-a59d-b64da13f503c"],

Cell[CellGroupData[{

Cell["\<\
suppressionTime[n_Integer?Positive, alpha_?NumericQ, C_?Positive, \
epsilon_?Positive] :=
  Ceiling[Log[C/epsilon]/gamma[n, alpha]];

Table[
  {
    n,
    suppressionTime[n, alphaExample, 2., 10^-3],
    suppressionTime[n, alphaExample, 2., 10^-3]/n^2
  },
  {n, 10, 100, 10}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[1189]:=",ExpressionUUID->"ddd0f568-1626-482f-928c-cd2ff6cbb318"],

