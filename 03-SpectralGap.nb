Cell[CellGroupData[{

Cell["\<\
Show[
  ListLinePlot[
    Table[{n, scaledGap[n, alphaExample]}, {n, 10, 400}],
    AxesLabel -> {\"n\", \"n^2 gamma_n\"},
    PlotRange -> All
  ],
  Plot[
    asymptoticConstant[alphaExample],
    {n, 10, 400}
  ],
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[1175]:=",ExpressionUUID->"5a6e44ec-dece-4f3a-a348-83f14da49628"],

