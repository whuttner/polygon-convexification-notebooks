Cell[CellGroupData[{

Cell["4. Eigenvalue magnitudes", "Section",ExpressionUUID->"ced9b4df-2fea-4986-98b6-9fcf539e7871"],

Cell["The squared magnitude has the closed form", "Text",ExpressionUUID->"516f0561-d69d-4c50-a8cb-88e71f3af4ae"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    SubscriptBox["\[Mu]", "k"], "2"], "=", 
   SuperscriptBox[
    RowBox[{"|", 
     SubscriptBox["\[Lambda]", "k"], "|"}], "2"], "=", "1", "-", 
   RowBox[{"2", "\[Alpha]", 
    RowBox[{"(", 
     RowBox[{"1", "-", "\[Alpha]"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"cos", "(", 
       FractionBox[
        RowBox[{"2", "\[Pi]", "k"}], "n"], ")"}]}], ")"}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"c6afda96-e2f5-4392-\
945f-6d6a75ebb8bc"],

Cell[CellGroupData[{

Cell["\<\
muSquaredClosedForm[n_Integer?Positive, k_Integer, alpha_] :=
  1 - 2 alpha (1 - alpha) (1 - Cos[2 Pi k/n]);

magnitudeFormulaError[n_Integer?Positive, alpha_?NumericQ] :=
  Max@Table[
    Abs[N[mu[n, k, alpha]^2 - muSquaredClosedForm[n, k, alpha]]],
    {k, 0, n - 1}
  ];

magnitudeFormulaError[nExample, alphaExample]\
\>", "Input",
 CellLabel->
  "In[1146]:=",ExpressionUUID->"97c81ccc-cd1a-4063-9ed3-c153c9a37edc"],

Cell[BoxData["1.3877787807814457`*^-16"], "Output",
 CellChangeTimes->{3.9928008343691483`*^9},
 CellLabel->
  "Out[1150]=",ExpressionUUID->"7d3d65e9-f1a3-40c4-bc77-d2f13a73c3ee"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
magnitudeTable[n_Integer?Positive, alpha_?NumericQ] :=
  Table[{k, mu[n, k, alpha]}, {k, 0, n - 1}];

magnitudeTable[nExample, alphaExample] // TableForm\
\>", "Input",
 CellLabel->
  "In[1151]:=",ExpressionUUID->"81b2cc80-70a6-4d1b-aa92-4f3bc1e2cc4c"],

