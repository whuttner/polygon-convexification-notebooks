Cell[CellGroupData[{

Cell["Conclusion", "Section",ExpressionUUID->"29c6fbc7-5f43-434b-8f16-b3c8baa012ef"],

Cell[TextData[{
 "The computations verify the spectral mechanism used in Chapter 2. The \
averaging operator is diagonal in the Fourier basis, the first harmonic \
dominates every higher nonconstant mode, and the logarithmic gap is positive. \
Its leading large-",
 Cell[BoxData[
 "n"], "InlineFormula",ExpressionUUID->"9c465600-4697-4faa-96c9-afd26b6b838f"],
 " behavior is proportional to ",
 Cell[BoxData[
  SuperscriptBox["n", 
   RowBox[{"-", "2"}]]], "InlineFormula",ExpressionUUID->
  "e1cb0be7-a55b-42bb-83b3-f96874f83f0a"],
 ", with coefficient ",
 Cell[BoxData[
  RowBox[{"6", 
   SuperscriptBox["\[Pi]", "2"], "\[Alpha]", 
   RowBox[{"(", 
    RowBox[{"1", "-", "\[Alpha]"}], ")"}]}]], "InlineFormula",ExpressionUUID->
  "008f7bff-d9e2-4be5-9f5d-bf34eb25d6f3"],
 "."
}], "Text",ExpressionUUID->"c4412027-1648-47b8-ba76-9c036eed1e36"]
}, Open  ]]
}, Open  ]]
},
