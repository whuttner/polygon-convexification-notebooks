Cell[CellGroupData[{

Cell["7. Large-n asymptotic", "Section",ExpressionUUID->"a2fc7c65-5f1d-44c1-b70a-4e3eed7a6399"],

Cell["Chapter 2 gives the asymptotic behavior", "Text",ExpressionUUID->"9404a05f-436e-441b-91e3-cab2b95daea0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Gamma]", "n"], 
   RowBox[{"(", "\[Alpha]", ")"}], "\[TildeTilde]", 
   FractionBox[
    RowBox[{"6", 
     SuperscriptBox["\[Pi]", "2"], "\[Alpha]", 
     RowBox[{"(", 
      RowBox[{"1", "-", "\[Alpha]"}], ")"}]}], 
    SuperscriptBox["n", "2"]]}], TraditionalForm]], "DisplayFormula",Expressio\
nUUID->"c55310c7-8adf-40dc-977d-3470fa3c4598"],

Cell["\<\
gapLeadingTerm[n_Integer?Positive, alpha_?NumericQ] :=
  6 Pi^2 alpha (1 - alpha)/n^2;

gapRatio[n_Integer?Positive, alpha_?NumericQ] :=
  gamma[n, alpha]/gapLeadingTerm[n, alpha];

scaledGap[n_Integer?Positive, alpha_?NumericQ] :=
  n^2 gamma[n, alpha];

asymptoticConstant[alpha_?NumericQ] :=
  6 Pi^2 alpha (1 - alpha);\
\>", "Input",
 CellLabel->
  "In[1166]:=",ExpressionUUID->"064fb962-1835-4ddb-b283-a158167c638c"],

Cell[CellGroupData[{

Cell["\<\
Table[
  {
    n,
    gamma[n, alphaExample],
    gapLeadingTerm[n, alphaExample],
    gapRatio[n, alphaExample],
    scaledGap[n, alphaExample]
  },
  {n, 20, 200, 20}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[1173]:=",ExpressionUUID->"c6a26436-9ee3-429e-bb56-c79f79fe5e45"],

