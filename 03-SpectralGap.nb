Cell[CellGroupData[{

Cell["5. Symmetry and first-harmonic dominance", "Section",ExpressionUUID->"b8c4962a-56ec-4f01-be3c-a17ec545afcf"],

Cell[TextData[{
 "The magnitudes satisfy ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Mu]", "k"], "=", 
   SubscriptBox["\[Mu]", 
    RowBox[{"n", "-", "k"}]]}]], "InlineFormula",ExpressionUUID->
  "f0ac5036-c7e2-4413-9693-3ff941acdb37"],
 ". For ",
 Cell[BoxData[
  RowBox[{"n", "\[GreaterEqual]", "5"}]], "InlineFormula",ExpressionUUID->
  "804b455a-c308-44db-87ec-f59b6cd7e5e5"],
 ", the first harmonic has strictly larger magnitude than every mode ",
 Cell[BoxData[
  RowBox[{"k", "=", "2", ",", "\[Ellipsis]", ",", 
   RowBox[{"n", "-", "2"}]}]], "InlineFormula",ExpressionUUID->
  "2a793347-21e3-429d-bfe6-8712eeab3cf7"],
 "."
}], "Text",ExpressionUUID->"af0859c7-39d4-426f-9d47-9103e51828db"],

Cell["\<\
symmetryError[n_Integer?Positive, alpha_?NumericQ] :=
  Max@Table[
    Abs[N[mu[n, k, alpha] - mu[n, Mod[n - k, n], alpha]]],
    {k, 0, n - 1}
  ];

firstHarmonicDominanceMargin[n_Integer?Positive, alpha_?NumericQ] := Module[
  {higher},
  If[n < 5, Return[Missing[\"NotApplicable\"]]];
  higher = Table[mu[n, k, alpha], {k, 2, n - 2}];
  mu[n, 1, alpha] - Max[higher]
];

firstHarmonicDominanceQ[n_Integer?Positive, alpha_?NumericQ] := Module[
  {margin = firstHarmonicDominanceMargin[n, alpha]},
  If[MissingQ[margin], margin, margin > 0]
];\
\>", "Input",
 CellLabel->
  "In[1155]:=",ExpressionUUID->"444a0135-1cbc-4624-8ba1-a15a40b8eba0"],

Cell[CellGroupData[{

Cell["symmetryError[nExample, alphaExample]", "Input",
 CellLabel->
  "In[1160]:=",ExpressionUUID->"b390b368-e843-4f7c-91e9-fc3952c13a1e"],

Cell[BoxData["0.`"], "Output",
 CellChangeTimes->{3.9928008344470663`*^9},
 CellLabel->
  "Out[1160]=",ExpressionUUID->"35bbea57-b5ef-47d9-b499-a3a26072f07d"]
}, Open  ]],

