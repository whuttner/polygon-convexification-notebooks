Cell[CellGroupData[{

Cell["8. Numerical asymptotic error", "Section",ExpressionUUID->"65d771b3-7cce-47f3-958c-ffecff16863d"],

Cell[CellGroupData[{

Cell["\<\
relativeAsymptoticError[n_Integer?Positive, alpha_?NumericQ] :=
  Abs[gamma[n, alpha] - gapLeadingTerm[n, alpha]]/gamma[n, alpha];

Table[
  {n, relativeAsymptoticError[n, alphaExample]},
  {n, 20, 300, 20}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[1176]:=",ExpressionUUID->"f7f38500-c0a5-4b16-a627-ae1a056ff2df"],

