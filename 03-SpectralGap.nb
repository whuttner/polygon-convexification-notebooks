Cell[CellGroupData[{

Cell["6. The logarithmic spectral gap", "Section",ExpressionUUID->"195d3d34-5c10-4e69-ac3c-782848c83681"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Gamma]", "n"], 
   RowBox[{"(", "\[Alpha]", ")"}], "=", 
   RowBox[{"log", "(", 
    FractionBox[
     SubscriptBox["\[Mu]", "1"], 
     SubscriptBox["\[Mu]", "2"]], ")"}], ">", "0"}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"44d9975e-dfb1-427c-\
b900-e11f90cd2cee"],

Cell[CellGroupData[{

Cell["\<\
gapTable[alpha_?NumericQ, nMin_Integer?Positive, nMax_Integer?Positive] :=
  Table[{n, gamma[n, alpha]}, {n, nMin, nMax}];

gapTable[alphaExample, 5, 30] // TableForm\
\>", "Input",
 CellLabel->
  "In[1162]:=",ExpressionUUID->"98f5c6a8-5429-4ee4-960f-82399a68db01"],

