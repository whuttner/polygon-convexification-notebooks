Notebook[{

Cell[CellGroupData[{
Cell["SpectralGap", "Title",ExpressionUUID->"19907cb9-03a9-4ffa-882c-283349453c09"],

Cell["\<\
Fourier eigenvalues, spectral ordering, and large-n asymptotics\
\>", "Subtitle",ExpressionUUID->"c5c6b1bc-60bf-4cef-b1a9-7c13f36eb97b"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"bf837bdb-f11f-4e45-a975-483e507aa111"],

Cell[TextData[{
 "This notebook isolates the spectral-gap analysis from Chapter 2. It studies \
the averaging operator ",
 Cell[BoxData[
  SubscriptBox["A", "\[Alpha]"]], "InlineFormula",ExpressionUUID->
  "23822804-9fa0-4239-8207-8bdc90304b59"],
 ", computes its Fourier eigenvalues and their magnitudes, verifies \
first-harmonic dominance, and investigates the logarithmic gap"
}], "Text",ExpressionUUID->"a5e29f52-49de-4944-8ffb-e9b6836a819c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Gamma]", "n"], 
   RowBox[{"(", "\[Alpha]", ")"}], "=", 
   RowBox[{"log", "(", 
    FractionBox[
     SubscriptBox["\[Mu]", "1"], 
     SubscriptBox["\[Mu]", "2"]], ")"}]}], TraditionalForm]], "DisplayFormula",\
ExpressionUUID->"0af14663-96b3-4746-8557-5fbc02d376c0"],

Cell["\<\
All executable cells are ordinary Wolfram Language Input cells. Typeset box \
expressions appear only in explanatory cells.\
\>", "Text",ExpressionUUID->"53a3bed3-01a3-42ba-b15f-9411deabadb5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Definitions", "Section",ExpressionUUID->"caff07fe-340e-4c82-9cff-1458a99e35b1"],

Cell["\<\
ClearAll[\"Global`*\"];

omega[n_Integer?Positive] := Exp[2 Pi I/n];

fourierVector[n_Integer?Positive, k_Integer] :=
  Table[omega[n]^(j k), {j, 0, n - 1}]/Sqrt[n];

fourierMatrix[n_Integer?Positive] :=
  Transpose@Table[fourierVector[n, k], {k, 0, n - 1}];

averagingMatrix[n_Integer?Positive, alpha_?NumericQ] :=
  Table[
    (1 - alpha) Boole[ell == j] + alpha Boole[ell == Mod[j + 1, n]],
    {j, 0, n - 1}, {ell, 0, n - 1}
  ];

lambda[n_Integer?Positive, k_Integer, alpha_] :=
  (1 - alpha) + alpha Exp[2 Pi I k/n];

mu[n_Integer?Positive, k_Integer, alpha_] :=
  Abs[lambda[n, k, alpha]];

gamma[n_Integer?Positive, alpha_] :=
  Log[mu[n, 1, alpha]/mu[n, 2, alpha]];\
\>", "Input",
 CellLabel->
  "In[1116]:=",ExpressionUUID->"72536116-52b0-4ed7-8106-9ccd5c083dc8"],

Cell["The averaging operator acts by", "Text",ExpressionUUID->"6d348961-ba0d-4e6a-91d0-d13cfc56cfad"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["A", "\[Alpha]"], "p"}], ")"}], "j"], "=", 
   RowBox[{"(", 
    RowBox[{"1", "-", "\[Alpha]"}], ")"}], 
   SubscriptBox["p", "j"], "+", "\[Alpha]", 
   SubscriptBox["p", 
    RowBox[{"j", "+", "1"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"cb06fbd5-bcc2-426f-a382-c90bb257f0ec"],

Cell["\<\
nExample = 12;
alphaExample = 0.35;
A = averagingMatrix[nExample, alphaExample];\
\>", "Input",
 CellLabel->
  "In[1131]:=",ExpressionUUID->"c69af946-d9d1-489c-91ea-6359ad9e904b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Fourier eigenvalues", "Section",ExpressionUUID->"203e925c-aa63-4617-a2d9-c503ccab481c"],

Cell[TextData[{
 "For Fourier mode ",
 Cell[BoxData[
  SubscriptBox["\[CurlyPhi]", "k"]], "InlineFormula",ExpressionUUID->
  "c646a011-7695-4382-8145-d1c175e6731d"],
 ", the eigenvalue is"
}], "Text",ExpressionUUID->"8f3a8865-8eaf-4cd9-8c73-1e33e4005a99"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Lambda]", "k"], "=", 
   RowBox[{"(", 
    RowBox[{"1", "-", "\[Alpha]"}], ")"}], "+", "\[Alpha]", 
   SuperscriptBox["e", 
    FractionBox[
     RowBox[{"2", "\[Pi]", "i", "k"}], "n"]]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"b9875191-4b46-4d12-\
b561-639b2faf879c"],

Cell[CellGroupData[{

Cell["\<\
eigenResidual[n_Integer?Positive, k_Integer, alpha_?NumericQ] := Module[
  {A, phi, lam},
  A = averagingMatrix[n, alpha];
  phi = fourierVector[n, k];
  lam = lambda[n, k, alpha];
  Max[Abs[N[A . phi - lam phi]]]
];

Table[
  {k, eigenResidual[nExample, k, alphaExample]},
  {k, 0, nExample - 1}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[1134]:=",ExpressionUUID->"6a0984e9-b90d-42c4-9426-a86dc823ca8b"],

