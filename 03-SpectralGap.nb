    {"9", "0.`"},
    {"10", "6.206335383118183`*^-17"},
    {"11", "6.938893903907228`*^-17"}
   },
   GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
