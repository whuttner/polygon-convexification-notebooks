  Table[
    {n, suppressionTime[n, alphaExample, 2., 10^-3]},
    {n, 10, 150, 5}
  ],
  AxesLabel -> {\"n\", \"predicted iteration count\"},
  PlotRange -> All,
  ImageSize -> Large
]\
\>", "Input",
