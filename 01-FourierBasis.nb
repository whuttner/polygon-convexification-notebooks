Cell[CellGroupData[{

Cell["12. Degeneracy test", "Section",ExpressionUUID->"3a4eb135-0363-4354-9f8c-4fc35da8cafa"],

Cell[TextData[{
 "Writing ",
 Cell[BoxData[
  RowBox[{"u", "=", 
   RowBox[{"a", "+", "b"}]}]], "InlineFormula",ExpressionUUID->
  "d1293154-2188-4e69-afa6-a60c23be8da0"],
 " and ",
 Cell[BoxData[
  RowBox[{"v", "=", 
   RowBox[{"i", 
    RowBox[{"(", 
     RowBox[{"a", "-", "b"}], ")"}]}]}]], "InlineFormula",ExpressionUUID->
  "d0df68a9-f2a3-41e5-a79c-476ed2892cb8"],
 ", the image is a nondegenerate ellipse precisely when ",
 Cell[BoxData[
 "u"], "InlineFormula",ExpressionUUID->"13c73f65-a920-4ef8-961b-e1ce88b28b11"],
 " and ",
 Cell[BoxData[
 "v"], "InlineFormula",ExpressionUUID->"5ba023be-5680-4b09-a179-07ed4da1e3ce"],
 " are linearly independent as vectors in ",
 Cell[BoxData[
  SuperscriptBox["\[DoubleStruckCapitalR]", "2"]], "InlineFormula",
  ExpressionUUID->"84c95130-b5f3-4636-94f3-cf957813f274"],
 "."
}], "Text",ExpressionUUID->"1b585b7b-5fd6-4fc6-9a0d-3be3a17886e8"],

Cell["\<\
realVector[z_] := {Re[z], Im[z]};

pairPlaneAreaFactor[a_, b_] := Module[{u, v},
  u = a + b;
  v = I (a - b);
  Det[Transpose[{realVector[u], realVector[v]}]]
];

nondegeneratePairPlaneQ[a_, b_, tol_: 10^-10] :=
  Abs[N[pairPlaneAreaFactor[a, b]]] > tol;\
\>", "Input",
 CellLabel->
  "In[934]:=",ExpressionUUID->"b656c761-17a3-4d5b-b7e0-02c1e4280884"],

Cell[CellGroupData[{

Cell["\<\
{
  pairPlaneAreaFactor[1 + 0.3 I, 0.25 - 0.65 I],
  nondegeneratePairPlaneQ[1 + 0.3 I, 0.25 - 0.65 I],
  nondegeneratePairPlaneQ[1, 1]
}\
\>", "Input",
 CellLabel->
  "In[939]:=",ExpressionUUID->"f5458b3c-7d4c-43ea-81c1-0df09bdd29ad"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0.605`", ",", "True", ",", "False"}], "}"}]], "Output",
 CellChangeTimes->{3.9928012969478073`*^9, 3.993066243813098*^9},
 CellLabel->
  "Out[939]=",ExpressionUUID->"1945e7f2-da1e-42a5-8d48-3b3e0a0b7332"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["13. Automated verification report", "Section",ExpressionUUID->"67cfbcaa-b3af-4b7c-8f73-c49bf6e91d64"],

Cell["\<\
Clear[verificationReport];

verificationReport[] := verificationReport[20];

verificationReport[maxN_Integer?Positive] := Module[{rows},
  rows = Table[
    Module[
      {F, gramError, unitaryError, conjugateError, a, b, ellipseError},
      F = fourierMatrix[n];
      gramError = Max[Abs[Flatten[N[
        gramMatrix[n] - IdentityMatrix[n]
      ]]]];
      unitaryError = Max[Abs[Flatten[N[
        ConjugateTranspose[F] . F - IdentityMatrix[n]
      ]]]];
      conjugateError = conjugateModeError[n];
      a = 1 + I/3;
      b = 2/5 - I/4;
      ellipseError = ellipseIdentityError[n, a, b];
      <|
        \"n\" -> n,
        \"Orthonormal basis\" -> TrueQ[gramError < 10^-10],
        \"Unitary Fourier matrix\" -> TrueQ[unitaryError < 10^-10],
        \"Conjugate pairing\" -> TrueQ[conjugateError < 10^-10],
        \"Pair-plane parametrization\" -> TrueQ[ellipseError < 10^-10]
      |>
    ],
    {n, 2, maxN}
  ];
  Dataset[rows]
];\
\>", "Input",
 CellLabel->
  "In[940]:=",ExpressionUUID->"d7586a40-1da4-4cee-b7b4-c91a56ad0dde"],

Cell[CellGroupData[{

Cell["Length[DownValues[verificationReport]]", "Input",
 CellLabel->
  "In[945]:=",ExpressionUUID->"4635d097-2371-46c6-8c63-6ba0d96b1cae"],

Cell[BoxData["2"], "Output",
