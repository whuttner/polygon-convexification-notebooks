Cell[CellGroupData[{

Cell["4. Unitarity of the Fourier matrix", "Section",ExpressionUUID->"5cee5e8d-503d-471f-a56c-c08295d691bf"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
 "F"], "InlineFormula",ExpressionUUID->"6ef95078-f806-4483-afd9-cc3cf0c4e236"],
 " has the Fourier vectors as columns, then"
}], "Text",ExpressionUUID->"b2f2c39e-3649-4d4c-9c40-58da9bf37585"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["F", "\[Dagger]"], "F", "=", 
   SubscriptBox["I", "n"]}], TraditionalForm]], "DisplayFormula",ExpressionUUI\
D->"61dbdda2-a235-4393-be26-981444bd1030"],

Cell["\<\
unitaryProduct = Chop[ConjugateTranspose[F] . F];
unitarityError = Max[Abs[Flatten[N[unitaryProduct - \
IdentityMatrix[nExample]]]]];
unitarityQ = unitarityError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[887]:=",ExpressionUUID->"e1fdb818-2d65-41ad-82f9-c107a9a80c10"],

