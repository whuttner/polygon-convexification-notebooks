Cell[CellGroupData[{

Cell["9. The pair-plane", "Section",ExpressionUUID->"0e32ea52-9df9-4d8d-bc4e-179ffc3fb73b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["E", 
    RowBox[{"\[PlusMinus]", "1"}]], "=", 
   RowBox[{"Span", "{", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "1"], ",", 
     SubscriptBox[
      OverscriptBox["\[CurlyPhi]", "\[RightVector]"], 
      RowBox[{"n", "-", "1"}]]}], "}"}]}], TraditionalForm]], "DisplayFormula",\
ExpressionUUID->"9d2769fb-9279-4542-a86d-6dd38399b779"],

Cell[TextData[{
 "A vector in ",
 Cell[BoxData[
  SubscriptBox["E", 
   RowBox[{"\[PlusMinus]", "1"}]]], "InlineFormula",ExpressionUUID->
  "f27cadd4-46f3-40c9-ba55-ec0e26be0991"],
 " has components"
}], "Text",ExpressionUUID->"3de70844-0720-497b-8cab-642626cd0993"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["p", "j"], "=", 
   RowBox[{"a", 
    SuperscriptBox["\[Omega]", "j"]}], "+", 
   RowBox[{"b", 
    SuperscriptBox["\[Omega]", 
     RowBox[{"-", "j"}]]}]}], TraditionalForm]], "DisplayFormula",ExpressionUU\
ID->"170ec8e6-bfda-4fa8-a547-70b59da47e46"],

Cell["\<\
pairPlaneVector[n_Integer?Positive, a_, b_] :=
  a fourierVector[n, 1] + b fourierVector[n, n - 1];

pairPlaneCoordinates[p_List] :=
  Transpose[{Re[p], Im[p]}];\
\>", "Input",
 CellLabel->
  "In[924]:=",ExpressionUUID->"06a3d91f-7324-4558-8ca0-fe6f0681659b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Cosine-sine parametrization", "Section",ExpressionUUID->"464a12a2-b7d3-4a54-9ab6-b1deb7bb1407"],

Cell["\<\
After absorbing the common normalization into the coefficients, the \
components can be written as\
\>", "Text",ExpressionUUID->"36aa2346-6174-4d7c-a9cb-f3953d210252"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["p", "j"], "=", "u", 
   RowBox[{"cos", "(", 
    FractionBox[
     RowBox[{"2", "\[Pi]", "j"}], "n"], ")"}], "+", "v", 
   RowBox[{"sin", "(", 
    FractionBox[
     RowBox[{"2", "\[Pi]", "j"}], "n"], ")"}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"cb583925-125a-4461-\
af71-266204f7bfd7"],

Cell["\<\
ellipseSample[n_Integer?Positive, a_, b_] :=
  Table[
    (a + b) Cos[2 Pi j/n] + I (a - b) Sin[2 Pi j/n],
    {j, 0, n - 1}
  ];

ellipseIdentityError[n_Integer?Positive, a_, b_] :=
  Max[Abs[N[
    Table[a omega[n]^j + b omega[n]^(-j), {j, 0, n - 1}] -
    ellipseSample[n, a, b]
  ]]];\
\>", "Input",
 CellLabel->
  "In[927]:=",ExpressionUUID->"ef6244ce-97c9-4eb6-b436-8bd60b647a66"],

Cell[CellGroupData[{

Cell["ellipseIdentityError[17, 2 - I, -1/3 + 4 I/5]", "Input",
 CellLabel->
  "In[930]:=",ExpressionUUID->"ce00b395-2cb5-4be3-97dc-063574fed8b6"],

Cell[BoxData["1.1102230246251565`*^-15"], "Output",
 CellChangeTimes->{3.992801296823844*^9, 3.993066243637294*^9},
 CellLabel->
  "Out[930]=",ExpressionUUID->"706642a2-5456-4fc2-bc96-4b2365e04bdb"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["11. Pair-plane geometry", "Section",ExpressionUUID->"19a640c5-0028-4831-8e10-5614a0e65f62"],

Cell["\<\
pairPlanePlot[n_Integer?Positive, a_, b_] := Module[
  {p, pts, curve},
  p = pairPlaneVector[n, a, b];
  pts = pairPlaneCoordinates[p];
  curve = ParametricPlot[
    Evaluate@{
      Re[a Exp[I t] + b Exp[-I t]],
      Im[a Exp[I t] + b Exp[-I t]]
    },
    {t, 0, 2 Pi},
    PlotRange -> All
  ];
  Show[
    curve,
    Graphics[{
      Line[Append[pts, First[pts]]],
      PointSize[0.018],
      Point[pts]
    }],
    Axes -> True,
    AxesLabel -> {\"Re\", \"Im\"},
    AspectRatio -> 1,
    ImageSize -> Large
  ]
];\
\>", "Input",
 CellLabel->
  "In[931]:=",ExpressionUUID->"728b6717-92d3-4bc5-9d02-0dab7396fe2e"],

