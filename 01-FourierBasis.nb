Cell["Conclusion", "Section",ExpressionUUID->"763b05b6-1bb0-4b87-a0aa-9756ece7fed3"],

Cell[TextData[{
 "The computations verify that the normalized Fourier vectors form an \
orthonormal basis of ",
 Cell[BoxData[
  SuperscriptBox["\[DoubleStruckCapitalC]", "n"]], "InlineFormula",
  ExpressionUUID->"49468bab-e802-4ccd-8784-5c59598f8af0"],
 ", that the Fourier matrix is unitary, and that the pair-plane ",
 Cell[BoxData[
  SubscriptBox["E", 
   RowBox[{"\[PlusMinus]", "1"}]]], "InlineFormula",ExpressionUUID->
  "c8b402cd-3479-41aa-97fd-d5166d74976d"],
 " consists of sampled affine images of the circle."
}], "Text",ExpressionUUID->"62461eae-79f4-4b47-a330-ee290cb5ad6e"]
}, Open  ]]
}, Open  ]]
},
