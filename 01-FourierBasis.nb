Cell[CellGroupData[{

Cell["5. Fourier coefficients and reconstruction", "Section",ExpressionUUID->"5d58c2b2-6ca3-481e-a377-aa797c6fef51"],

Cell["\<\
fourierCoefficients[x_List] := Module[{F = fourierMatrix[Length[x]]},
  ConjugateTranspose[F] . x
];

fourierSynthesis[c_List] := Module[{F = fourierMatrix[Length[c]]},
  F . c
];\
\>", "Input",
 CellLabel->
  "In[893]:=",ExpressionUUID->"4212d288-365c-4e04-833f-04c48b29dca2"],

Cell["\<\
SeedRandom[2026];
xExample = RandomInteger[{-5, 5}, nExample] + I RandomInteger[{-5, 5}, \
nExample];
cExample = fourierCoefficients[xExample];
xRecovered = fourierSynthesis[cExample];
reconstructionError = Norm[N[xRecovered - xExample]];
reconstructionQ = reconstructionError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[896]:=",ExpressionUUID->"1a8612c0-5704-42ea-a1aa-fef9951bbf70"],

