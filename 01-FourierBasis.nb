Cell[CellGroupData[{

Cell["2. Roots-of-unity sum", "Section",ExpressionUUID->"1bdf6c35-83ee-400b-88e3-410cd065a892"],

Cell["The orthogonality calculation uses", "Text",ExpressionUUID->"fa4e94fe-b227-494b-a73e-19f82eba4675"],

Cell[BoxData[
 FormBox[
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"m", "=", "0"}], 
    RowBox[{"n", "-", "1"}]], 
   SuperscriptBox["\[Omega]", 
    RowBox[{"m", "r"}]], "=", 
   RowBox[{"{", GridBox[{
      {"n", 
       RowBox[{"r", "\[Congruent]", "0", 
        RowBox[{"(", 
         RowBox[{"mod", " ", "n"}], ")"}]}]},
      {"0", "otherwise"}
     }], "}"}]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"e479d119-71d6-40f2-9a03-d68d852a24a9"],

Cell["\<\
rootOfUnitySum[n_Integer?Positive, r_Integer] :=
  Sum[omega[n]^(m r), {m, 0, n - 1}];

rootOfUnityExpected[n_Integer?Positive, r_Integer] :=
  If[Mod[r, n] == 0, n, 0];

rootOfUnityError[n_Integer?Positive, r_Integer] :=
  Abs[N[rootOfUnitySum[n, r] - rootOfUnityExpected[n, r]]];\
\>", "Input",
 CellLabel->
  "In[870]:=",ExpressionUUID->"75d0033d-f342-4057-a0bd-7346cd1d3234"],

Cell[CellGroupData[{

Cell["\<\
Table[
  {r, Chop[N[rootOfUnitySum[nExample, r]]]},
  {r, 0, nExample - 1}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[875]:=",ExpressionUUID->"50c6a1a3-fa8f-4e87-8f41-3dae9689a3ab"],

