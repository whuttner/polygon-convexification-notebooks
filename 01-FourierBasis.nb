Cell[CellGroupData[{

Cell["8. Individual Fourier modes", "Section",ExpressionUUID->"ce82c18b-653d-44e6-8e3b-b6c64f53e718"],

Cell["\<\
modeComponentPlot[n_Integer?Positive, k_Integer] := Module[{v},
  v = fourierVector[n, k];
  ListLinePlot[
    {Re[v], Im[v]},
    DataRange -> {0, n - 1},
    PlotMarkers -> Automatic,
    PlotLegends -> {\"Re(phi_k)\", \"Im(phi_k)\"},
    AxesLabel -> {\"vertex j\", \"component value\"},
    PlotLabel -> Row[{\"Fourier mode k = \", Mod[k, n], \", n = \", n}],
    ImageSize -> Large
  ]
];\
\>", "Input",
 CellLabel->
  "In[921]:=",ExpressionUUID->"bda58cbf-b2d0-4ced-972e-50fd3a7ff4c4"],

