b24c0f1dabea"]
}, Open  ]],

Cell["\<\
rootOfUnityMaxError = Max@Table[
  rootOfUnityError[nExample, r],
  {r, -2 nExample, 2 nExample}
];
rootOfUnityQ = rootOfUnityMaxError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[876]:=",ExpressionUUID->"11ed98b1-ff3f-4e9d-be22-f04d18508c45"],

