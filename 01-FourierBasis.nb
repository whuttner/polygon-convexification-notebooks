Cell[CellGroupData[{

Cell["3. Orthonormality", "Section",ExpressionUUID->"2479b328-2a2c-4166-8cc9-ed9e589c6364"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{"k", ",", 
   RowBox[{"\[ScriptL]", "\[Element]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "\[Ellipsis]", ",", 
      RowBox[{"n", "-", "1"}]}], "}"}]}]}]], "InlineFormula",ExpressionUUID->
  "12d2e3b7-ca6a-4449-8291-9befb27b1719"],
 ","
}], "Text",
 CellChangeTimes->{{3.992813663477634*^9, 
  3.992813677554977*^9}},ExpressionUUID->"ada7738b-5030-4932-8d00-\
9d318292f31f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"], ",", 
     SubscriptBox[
      OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "\[ScriptL]"]}], 
    "\[RightAngleBracket]"}], "=", 
   FractionBox["1", "n"], 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"m", "=", "0"}], 
    RowBox[{"n", "-", "1"}]], 
   SuperscriptBox["\[Omega]", 
    RowBox[{"m", 
     RowBox[{"(", 
      RowBox[{"k", "-", "\[ScriptL]"}], ")"}]}]], "=", 
   SubscriptBox["\[Delta]", 
    RowBox[{"k", "\[ScriptL]"}]]}], TraditionalForm]], "DisplayFormula",Expres\
sionUUID->"73c99c33-03a0-4c81-b829-d49ad30077ea"],

Cell["\<\
gramMatrix[n_Integer?Positive] :=
  Table[
    hermitianInnerProduct[
      fourierVector[n, k],
      fourierVector[n, ell]
    ],
    {k, 0, n - 1}, {ell, 0, n - 1}
  ];\
\>", "Input",
 CellLabel->
  "In[880]:=",ExpressionUUID->"6f5c0786-d268-42ac-899a-dbe3ca8c4560"],

Cell[CellGroupData[{

Cell["\<\
gram = Chop[gramMatrix[nExample]];
gram // MatrixForm\
\>", "Input",
 CellLabel->
  "In[881]:=",ExpressionUUID->"0a5e52f4-7985-4e2c-96f7-90a3d2428dab"],

