Cell[CellGroupData[{

Cell["6. Parseval identity", "Section",ExpressionUUID->"338f488e-a7cf-48df-bf13-8cfa770b794a"],

Cell["Because the Fourier basis is orthonormal,", "Text",ExpressionUUID->"3bd3b337-e4d8-4dd8-bec2-d07e6a65ddd7"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{
    "\[LeftDoubleBracketingBar]", "x", "\[RightDoubleBracketingBar]"}], "2"], 
   "=", 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"k", "=", "0"}], 
    RowBox[{"n", "-", "1"}]], 
   SuperscriptBox[
    RowBox[{"|", 
     SubscriptBox["c", "k"], "|"}], "2"]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"82e08762-c0da-4464-\
8bb2-d64bee74d288"],

Cell["\<\
parsevalLeft = Norm[xExample]^2;
parsevalRight = Total[Abs[cExample]^2];
parsevalError = Abs[N[parsevalLeft - parsevalRight]];
parsevalQ = parsevalError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[905]:=",ExpressionUUID->"fdc26436-4621-465c-957d-564e1686ee21"],

Cell[CellGroupData[{

Cell["{parsevalLeft, parsevalRight}", "Input",
 CellLabel->
  "In[909]:=",ExpressionUUID->"c2803a46-9f97-43b5-9982-3b4e7e7f8b26"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"197", ",", 
   RowBox[{
    FractionBox["189", "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["5", "2"]}], "-", 
       FractionBox["9", 
        RowBox[{"2", " ", 
         SqrtBox["2"]}]]}], ")"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox["5", "2"], "-", 
       FractionBox["9", 
        RowBox[{"2", " ", 
         SqrtBox["2"]}]]}], ")"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["9", "2"]}], "-", 
       FractionBox["3", 
        RowBox[{"2", " ", 
         SqrtBox["2"]}]]}], ")"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       FractionBox["9", "2"], "-", 
       FractionBox["3", 
        RowBox[{"2", " ", 
         SqrtBox["2"]}]]}], ")"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "3"}], "+", 
       FractionBox["3", 
        SqrtBox["2"]]}], ")"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"3", "+", 
       FractionBox["3", 
        SqrtBox["2"]]}], ")"}], "2"]}]}], "}"}]], "Output",
 CellChangeTimes->{3.992801296567602*^9, 3.993066243369351*^9},
 CellLabel->
  "Out[909]=",ExpressionUUID->"652336a0-8340-4261-ad09-6bef8d2f8052"]
