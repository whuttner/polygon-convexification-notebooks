Cell[CellGroupData[{
Cell["FourierBasis", "Title",ExpressionUUID->"1913f399-c69a-4095-b0a5-760b298b8222"],

Cell["The discrete Fourier basis and the pair-plane", "Subtitle",ExpressionUUID->"bea4e711-7a36-4ad7-baf8-c42c001a1ee1"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"f8aced5d-5a11-4fc6-a842-5841ad2412d0"],

Cell[TextData[{
 "This notebook supports the Fourier-basis results of Chapter 1. It \
constructs the normalized discrete Fourier vectors, verifies orthonormality \
and completeness, computes Fourier coefficients, and illustrates the geometry \
of the pair-plane ",
 Cell[BoxData[
  SubscriptBox["E", 
   RowBox[{"\[PlusMinus]", "1"}]]], "InlineFormula",ExpressionUUID->
  "acec7781-89a1-4c55-8efa-1682590fca5e"],
 "."
}], "Text",ExpressionUUID->"6d960dfc-bcec-4c02-ba16-51bc7f44804d"],

Cell["\<\
All executable cells are ordinary Wolfram Language Input cells. Typeset box \
expressions are used only in explanatory cells.\
