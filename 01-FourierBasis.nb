Cell[CellGroupData[{

Cell["1. Definitions", "Section",ExpressionUUID->"6ad23179-9a8a-4819-abc0-d78d8297f6c7"],

Cell["\<\
ClearAll[\"Global`*\"];

omega[n_Integer?Positive] := Exp[2 Pi I/n];

fourierVector[n_Integer?Positive, k_Integer] :=
  Table[omega[n]^(j k), {j, 0, n - 1}]/Sqrt[n];

fourierMatrix[n_Integer?Positive] :=
  Transpose@Table[fourierVector[n, k], {k, 0, n - 1}];

hermitianInnerProduct[x_List, y_List] :=
  x . Conjugate[y];\
\>", "Input",
 CellLabel->
  "In[858]:=",ExpressionUUID->"2d13eb81-594d-4b36-b730-0779f8ac86db"],

Cell["The normalized Fourier vectors are", "Text",ExpressionUUID->"b86500f4-18bc-4ed5-8692-f257b74bea37"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"], "=", 
   FractionBox["1", 
    SqrtBox["n"]], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", ",", 
      SuperscriptBox["\[Omega]", "k"], ",", 
      SuperscriptBox["\[Omega]", 
       RowBox[{"2", "k"}]], ",", "\[Ellipsis]", ",", 
      SuperscriptBox["\[Omega]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "k"}]]}], ")"}], "\[Transpose]"]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"9922415c-f8d7-49bd-\
a407-292d01072ef1"],

Cell[CellGroupData[{

Cell["\<\
nExample = 8;
F = fourierMatrix[nExample];
N[F, 4] // MatrixForm\
\>", "Input",
 CellLabel->
  "In[867]:=",ExpressionUUID->"b9fcbf12-ee32-4ed9-8b0b-fa690fe1997e"],

