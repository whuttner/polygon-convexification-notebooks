Cell[CellGroupData[{

Cell["7. Conjugate pairing", "Section",ExpressionUUID->"ed0430c3-022f-4ad3-a11c-4e1cee4bf0bf"],

Cell["The Fourier modes satisfy", "Text",ExpressionUUID->"d771e763-554f-45d3-a2cf-4c61a0345b1f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   OverscriptBox[
    SubscriptBox[
     OverscriptBox["\[CurlyPhi]", "\[RightVector]"], "k"], "_"], "=", 
   SubscriptBox[
    OverscriptBox["\[CurlyPhi]", "\[RightVector]"], 
    RowBox[{"n", "-", "k"}]]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"e1d5fa82-21f7-4074-992d-2ce4f5d8135a"],

Cell["\<\
conjugateModeError[n_Integer?Positive] :=
  Max@Table[
    Norm[N[
      Conjugate[fourierVector[n, k]] -
      fourierVector[n, Mod[n - k, n]]
    ]],
    {k, 0, n - 1}
  ];\
\>", "Input",
 CellLabel->
  "In[912]:=",ExpressionUUID->"0b0e2fb1-0e2a-4e13-8113-b794698efdd4"],

Cell[CellGroupData[{

Cell["conjugateModeError[nExample]", "Input",
 CellLabel->
  "In[913]:=",ExpressionUUID->"20d8e68e-a6fb-411e-8a4a-6e899284c903"],

Cell[BoxData["0.`"], "Output",
 CellChangeTimes->{3.992801296588581*^9, 3.993066243411221*^9},
 CellLabel->
  "Out[913]=",ExpressionUUID->"8cfef8f7-d1b7-4170-a63a-942acde2ef98"]
}, Open  ]],

Cell["\<\
SeedRandom[17];
xReal = RandomInteger[{-9, 9}, nExample];
cReal = fourierCoefficients[xReal];
conjugateCoefficientError = Max@Table[
  Abs[N[
    cReal[[k + 1]] -
    Conjugate[cReal[[Mod[nExample - k, nExample] + 1]]]
  ]],
  {k, 0, nExample - 1}
];
conjugateCoefficientQ = conjugateCoefficientError < 10^-10;\
\>", "Input",
 CellLabel->
  "In[914]:=",ExpressionUUID->"a3db9446-f554-4285-b70f-109f53c07524"],

Cell[CellGroupData[{

Cell["conjugateCoefficientError", "Input",
 CellLabel->
  "In[919]:=",ExpressionUUID->"41df7b7b-f0c2-4e75-8eea-745b1a28745a"],

Cell[BoxData["0.`"], "Output",
 CellChangeTimes->{3.992801296603035*^9, 3.993066243417467*^9},
 CellLabel->
  "Out[919]=",ExpressionUUID->"9c1136b9-b889-4c59-92a5-d87131236685"]
}, Open  ]],

