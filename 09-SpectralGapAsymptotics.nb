   "0.04966793213867504`"}], "}"}]], "Output",
 CellChangeTimes->{3.992808428388649*^9},
 CellLabel->
  "Out[2903]=",ExpressionUUID->"a7084c5c-fd63-4381-9928-1ce41d78d8e5"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Dependence on alpha", "Section",ExpressionUUID->"471c57db-a3a1-4d15-84dc-92101d158d82"],

Cell["\<\
alphaGrid = Range[0.05, 0.95, 0.05];
coefficientData = Table[
  {alpha, c2[alpha], c4[alpha], c6[alpha]},
  {alpha, alphaGrid}
];\
\>", "Input",
 CellLabel->
  "In[2904]:=",ExpressionUUID->"ed3b3334-2959-4f7a-869f-6025f2ca1017"],

Cell[CellGroupData[{

Cell["\<\
ListLinePlot[
  coefficientData[[All, {1, 2}]],
  AxesLabel -> {\"alpha\", \"C2(alpha)\"},
  PlotRange -> All,
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[2906]:=",ExpressionUUID->"561ef552-5377-40ed-b80b-eadb1dd13786"],

