Cell[CellGroupData[{

Cell["\<\
Show[
  ListLinePlot[
    Table[{n, scaledResidual4[n, alphaExample]}, {n, 10, 400}],
    AxesLabel -> {\"n\", \"n^4 residual\"},
    PlotRange -> All
  ],
  Plot[c4[alphaExample], {n, 10, 400}],
  ImageSize -> Large
]\
\>", "Input",
 CellLabel->
  "In[2888]:=",ExpressionUUID->"216fa973-4924-4223-9fdf-f1cd82730a8e"],

