Cell[CellGroupData[{

Cell["2. Symbolic expansion variable", "Section",ExpressionUUID->"824aaf0a-51f2-4d34-9d15-e6c3a048db85"],

Cell["q[alpha_] := alpha (1 - alpha);", "Input",
 CellLabel->
  "In[2868]:=",ExpressionUUID->"0c3e9ebb-2a31-4ffb-a39d-a8e9d0ca49a4"],

Cell[TextData[{
 "Writing ",
 Cell[BoxData[
  RowBox[{"q", "=", 
   RowBox[{"\[Alpha]", 
    RowBox[{"(", 
     RowBox[{"1", "-", "\[Alpha]"}], ")"}]}]}]], "InlineFormula",
  ExpressionUUID->"0847e271-1a21-48a1-95c9-f999df330c5a"],
 ", the expansion has only even powers of ",
 Cell[BoxData[
  RowBox[{"1", "/", "n"}]], "InlineFormula",ExpressionUUID->
  "fa00e26c-108f-474a-a1cc-fa0c7249b26b"],
 "."
}], "Text",ExpressionUUID->"f78a70b8-cee7-4191-86b1-384448ad8901"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. First three asymptotic coefficients", "Section",ExpressionUUID->"d7446288-5ad7-46b2-a160-8a6339948b52"],

Cell["\<\
c2[alpha_] :=
  6 Pi^2 q[alpha];

c4[alpha_] :=
  Pi^4 (60 q[alpha]^2 - 10 q[alpha]);

c6[alpha_] :=
  Pi^6 (672 q[alpha]^3 - 168 q[alpha]^2 + (28/5) q[alpha]);\
\>", "Input",
 CellLabel->
  "In[2869]:=",ExpressionUUID->"a2f872e7-83cc-4036-8219-51a83549058c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Gamma]", "n"], 
   RowBox[{"(", "\[Alpha]", ")"}], "=", 
   FractionBox[
    SubscriptBox["C", "2"], 
    SuperscriptBox["n", "2"]], "+", 
   FractionBox[
    SubscriptBox["C", "4"], 
    SuperscriptBox["n", "4"]], "+", 
   FractionBox[
    SubscriptBox["C", "6"], 
    SuperscriptBox["n", "6"]], "+", 
   RowBox[{"O", "(", 
    SuperscriptBox["n", 
     RowBox[{"-", "8"}]], ")"}]}], TraditionalForm]], "DisplayFormula",Express\
ionUUID->"df4c081e-5e59-42bc-b40e-56f5e5b845a2"],

Cell[CellGroupData[{

Cell["{c2[alphaExample], c4[alphaExample], c6[alphaExample]} // N", "Input",
 CellLabel->
  "In[2874]:=",ExpressionUUID->"b74ec7b3-fa16-4bf8-b10c-b29ffb64ba41"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "13.472010007486972`", ",", "80.88607396735974`", ",", 
   "472.4703929312113`"}], "}"}]], "Output",
 CellChangeTimes->{3.992808427917486*^9},
 CellLabel->
  "Out[2874]=",ExpressionUUID->"cdc779c8-6957-4922-a39f-c7e6211bb555"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Truncated asymptotic models", "Section",ExpressionUUID->"045343fb-9c55-470b-9402-687a251a8cb2"],

Cell["\<\
gapOrder2[n_Integer?Positive, alpha_?NumericQ] :=
  c2[alpha]/n^2;

gapOrder4[n_Integer?Positive, alpha_?NumericQ] :=
  c2[alpha]/n^2 + c4[alpha]/n^4;

gapOrder6[n_Integer?Positive, alpha_?NumericQ] :=
  c2[alpha]/n^2 + c4[alpha]/n^4 + c6[alpha]/n^6;\
\>", "Input",
 CellLabel->
  "In[2875]:=",ExpressionUUID->"7f1142ec-554d-4a2a-8f9b-c060e064c797"],

Cell[CellGroupData[{

Cell["\<\
Table[
  {
    n,
    gamma[n, alphaExample],
    gapOrder2[n, alphaExample],
    gapOrder4[n, alphaExample],
    gapOrder6[n, alphaExample]
  },
  {n, 20, 200, 20}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[2880]:=",ExpressionUUID->"ea0c63a2-3391-4919-b2f1-f6f315a4c61b"],

