Notebook[{

Cell[CellGroupData[{
Cell["SpectralGapAsymptotics", "Title",ExpressionUUID->"0ce6f00a-9472-4ddb-9200-a2d266733b6f"],

Cell["Higher-order asymptotics of the logarithmic spectral gap", "Subtitle",ExpressionUUID->"437aebf1-ce08-4380-a91e-a66d7ba5a668"],

Cell[CellGroupData[{

Cell["Purpose", "Section",ExpressionUUID->"fa3df954-e238-4473-9409-69d062d266b2"],

Cell["\<\
This notebook supports the spectral-gap asymptotics studied in Chapter 4. It \
computes the exact logarithmic gap, derives its first three even-power \
asymptotic coefficients, studies scaled residuals, and compares analytic \
coefficients with numerical fits.\
\>", "Text",ExpressionUUID->"67baa982-8a45-4a28-8aab-a5cc22957381"],

Cell["\<\
All executable cells are ordinary Wolfram Language Input cells. Typeset box \
expressions appear only in explanatory cells.\
\>", "Text",ExpressionUUID->"fca2a461-e388-4380-aa6b-61806f64c336"]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Exact spectral gap", "Section",ExpressionUUID->"a4f628b8-fa82-4019-ac31-73d44784f584"],

Cell["\<\
ClearAll[\"Global`*\"];

lambda[n_Integer?Positive, k_Integer, alpha_] :=
  (1 - alpha) + alpha Exp[2 Pi I k/n];

muSquared[n_Integer?Positive, k_Integer, alpha_] :=
  1 - 2 alpha (1 - alpha) (1 - Cos[2 Pi k/n]);

mu[n_Integer?Positive, k_Integer, alpha_?NumericQ] :=
  Sqrt[muSquared[n, k, alpha]];

gamma[n_Integer?Positive, alpha_?NumericQ] :=
  (1/2) Log[muSquared[n, 1, alpha]/muSquared[n, 2, alpha]];\
\>", "Input",
 CellLabel->
  "In[2857]:=",ExpressionUUID->"18fe89f3-2674-487b-930e-2f85c0a5711a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Gamma]", "n"], 
   RowBox[{"(", "\[Alpha]", ")"}], "=", 
   FractionBox["1", "2"], "log", 
   RowBox[{"(", 
    FractionBox[
     RowBox[{"1", "-", 
      RowBox[{"2", "\[Alpha]", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Alpha]"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"cos", "(", 
          FractionBox[
           RowBox[{"2", "\[Pi]"}], "n"], ")"}]}], ")"}]}]}], 
     RowBox[{"1", "-", 
      RowBox[{"2", "\[Alpha]", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Alpha]"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"cos", "(", 
          FractionBox[
           RowBox[{"4", "\[Pi]"}], "n"], ")"}]}], ")"}]}]}]], ")"}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"16645583-e21e-4b40-\
bee9-c8a4245584ce"],

Cell[CellGroupData[{

Cell["\<\
alphaExample = 0.35;
Table[{n, gamma[n, alphaExample]}, {n, 5, 30}] // TableForm\
\>", "Input",
 CellLabel->
  "In[2866]:=",ExpressionUUID->"317f77ec-f4cf-4783-8d04-8f163a59a267"],

