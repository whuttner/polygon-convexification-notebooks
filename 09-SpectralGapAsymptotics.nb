Cell[CellGroupData[{

Cell["11. Symmetry about alpha = 1/2", "Section",ExpressionUUID->"9131f791-2029-4dcc-a324-b66226cdc18e"],

Cell[CellGroupData[{

Cell["\<\
coefficientSymmetryError[coefficient_, alpha_?NumericQ] :=
  Abs[N[coefficient[alpha] - coefficient[1 - alpha]]];

Table[
  {
    alpha,
    coefficientSymmetryError[c2, alpha],
    coefficientSymmetryError[c4, alpha],
    coefficientSymmetryError[c6, alpha]
  },
  {alpha, {0.1, 0.2, 0.3, 0.4}}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[2908]:=",ExpressionUUID->"7bb864e5-4d28-4b85-bcbb-1b30ee61a243"],

