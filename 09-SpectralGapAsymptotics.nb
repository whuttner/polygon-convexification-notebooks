Cell[CellGroupData[{

Cell["13. Effective convergence exponents", "Section",ExpressionUUID->"c7e2a0bd-2493-4c0c-b65c-7e73756c833c"],

Cell["\<\
effectiveExponent[data_List] := Module[{pairs},
  pairs = Partition[data, 2, 1];
  Table[
    -Log[pair[[2, 2]]/pair[[1, 2]]]/Log[pair[[2, 1]]/pair[[1, 1]]],
    {pair, pairs}
  ]
];

order2Errors = Table[
  {n, Abs[gamma[n, alphaExample] - gapOrder2[n, alphaExample]]},
  {n, 30, 300, 10}
];

order4Errors = Table[
  {n, Abs[gamma[n, alphaExample] - gapOrder4[n, alphaExample]]},
  {n, 30, 300, 10}
];\
\>", "Input",
 CellLabel->
  "In[2913]:=",ExpressionUUID->"666e626e-f9fa-49d5-88fe-d1e1d157ca33"],

Cell[CellGroupData[{

Cell["\<\
{
  Mean[Take[effectiveExponent[order2Errors], -8]],
  Mean[Take[effectiveExponent[order4Errors], -8]]
}\
\>", "Input",
 CellLabel->
  "In[2918]:=",ExpressionUUID->"61e31b7b-ae4e-4a70-9e42-9a002081c053"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"4.000177036728186`", ",", "5.999964059540326`"}], "}"}]], "Output",\

 CellChangeTimes->{3.992808428502288*^9},
 CellLabel->
  "Out[2918]=",ExpressionUUID->"e40bedf7-efc7-4028-81e3-8fac1926cc65"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["14. Suppression-time asymptotics", "Section",ExpressionUUID->"0194ff6e-083a-4a82-a619-5f0f4caca8c4"],

Cell["\<\
suppressionTimeExact[n_Integer?Positive, alpha_?NumericQ, C_?Positive, \
epsilon_?Positive] :=
  Log[C/epsilon]/gamma[n, alpha];

suppressionTimeLeading[n_Integer?Positive, alpha_?NumericQ, C_?Positive, \
epsilon_?Positive] :=
  Log[C/epsilon] n^2/c2[alpha];\
\>", "Input",
 CellLabel->
  "In[2919]:=",ExpressionUUID->"77bb5834-9b90-4b0c-9b86-5cefc570c2e2"],

Cell[CellGroupData[{

Cell["\<\
Table[
  {
    n,
    suppressionTimeExact[n, alphaExample, 2., 10^-3],
    suppressionTimeLeading[n, alphaExample, 2., 10^-3],
    suppressionTimeExact[n, alphaExample, 2., 10^-3]/n^2
  },
  {n, 20, 200, 20}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[2922]:=",ExpressionUUID->"073fb779-e2e8-4e1e-9767-78ad936b3ca5"],

