Cell[CellGroupData[{

Cell["Conclusion", "Section",ExpressionUUID->"eb46291f-f7b7-4372-b3d8-89e80c58a22d"],

Cell[TextData[{
 "The numerical experiments confirm the even-power expansion of the \
logarithmic spectral gap. The leading term is of order ",
 Cell[BoxData[
  SuperscriptBox["n", 
   RowBox[{"-", "2"}]]], "InlineFormula",ExpressionUUID->
  "9f38ad27-f7bb-4d4c-986b-3ea22197e2fa"],
 ", while subtracting successive analytic terms reveals stable ",
 Cell[BoxData[
  SuperscriptBox["n", 
   RowBox[{"-", "4"}]]], "InlineFormula",ExpressionUUID->
  "c6bfdf92-a825-43ed-9cbc-a17a36f530ef"],
 " and ",
 Cell[BoxData[
  SuperscriptBox["n", 
   RowBox[{"-", "6"}]]], "InlineFormula",ExpressionUUID->
  "5f53b914-aeda-4494-bfbe-0604045b0066"],
 " corrections. The fitted coefficients agree with the analytic formulas and \
inherit the symmetry ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
        "\[Alpha]", "\[DoubleLongLeftRightArrow]", "1", "-", "\[Alpha]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$\\alpha \\Longleftrightarrow 1-\\alpha$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e6926ab7-47c2-4650-8c17-d87bbbe73d10"],
 "."
}], "Text",
 CellChangeTimes->{{3.992808519549756*^9, 
  3.992808547926958*^9}},ExpressionUUID->"32eda6ef-d2b5-4b5a-9fc9-\
a3b7a97c286e"]
}, Open  ]]
}, Open  ]]
