Cell[CellGroupData[{

Cell["9. Numerical coefficient fitting", "Section",ExpressionUUID->"d8bff7bb-42fd-4110-93fd-859f72cefe19"],

Cell["\<\
fitCoefficients[alpha_?NumericQ, nMin_Integer?Positive, \
nMax_Integer?Positive] := Module[
  {data, fit},
  data = Table[
    {1/n^2, gamma[n, alpha]},
    {n, nMin, nMax}
  ];
  fit = LinearModelFit[data, {x, x^2, x^3}, x, IncludeConstantBasis -> \
False];
  fit[\"BestFitParameters\"]
];\
\>", "Input",
 CellLabel->
  "In[2898]:=",ExpressionUUID->"c74b68bd-6fd4-4547-abe9-1033d9c11d2d"],

Cell[CellGroupData[{

Cell["\<\
fittedCoefficients = fitCoefficients[alphaExample, 80, 400];
analyticCoefficients = {c2[alphaExample], c4[alphaExample], \
c6[alphaExample]};
{N[fittedCoefficients], N[analyticCoefficients]}\
\>", "Input",
 CellLabel->
  "In[2899]:=",ExpressionUUID->"0a423e98-35c7-405a-874c-381a1d635322"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "13.472010007554118`", ",", "80.88607036675198`", ",", 
     "472.52006086334995`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
    "13.472010007486972`", ",", "80.88607396735974`", ",", 
     "472.4703929312113`"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{3.992808428384543*^9},
 CellLabel->
  "Out[2901]=",ExpressionUUID->"49c02532-e1cc-41cb-9cec-1c4e646f0d15"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
fitCoefficientErrors = Abs[N[fittedCoefficients - analyticCoefficients]];
fitCoefficientErrors\
\>", "Input",
 CellLabel->
  "In[2902]:=",ExpressionUUID->"f3cc4efe-8544-4130-8f49-0b29c142f5f8"],

Cell[BoxData[
 RowBox[{"{", 
