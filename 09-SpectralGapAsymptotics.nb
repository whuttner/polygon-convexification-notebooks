Cell[CellGroupData[{

Cell["7. The n^-6 correction", "Section",ExpressionUUID->"acc8954d-0e91-4b2f-8165-e774e37daf06"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["n", "6"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Gamma]", "n"], "-", 
     FractionBox[
      SubscriptBox["C", "2"], 
      SuperscriptBox["n", "2"]], "-", 
     FractionBox[
      SubscriptBox["C", "4"], 
      SuperscriptBox["n", "4"]]}], ")"}], "\[Rule]", 
   SubscriptBox["C", "6"]}], TraditionalForm]], "DisplayFormula",ExpressionUUI\
D->"7f1d39d5-920b-4231-a94c-7a811d1293dd"],

Cell[CellGroupData[{

Cell["\<\
scaledResidual6[n_Integer?Positive, alpha_?NumericQ] :=
  n^6 (gamma[n, alpha] - c2[alpha]/n^2 - c4[alpha]/n^4);

Table[
  {n, scaledResidual6[n, alphaExample], c6[alphaExample]},
  {n, 20, 300, 20}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[2889]:=",ExpressionUUID->"dbdffc61-fa9e-4c9d-8000-7ab522039934"],

