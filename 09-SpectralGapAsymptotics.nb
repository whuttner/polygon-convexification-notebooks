Cell[CellGroupData[{

Cell["6. The n^-4 correction", "Section",ExpressionUUID->"1c21e2cb-db03-4ae9-a895-bbdd16cf7393"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["n", "4"], 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["\[Gamma]", "n"], "-", 
     FractionBox[
      SubscriptBox["C", "2"], 
      SuperscriptBox["n", "2"]]}], ")"}], "\[Rule]", 
   SubscriptBox["C", "4"]}], TraditionalForm]], "DisplayFormula",ExpressionUUI\
D->"fcba7a11-5826-4750-ac95-75f7a3c2db55"],

Cell[CellGroupData[{

Cell["\<\
scaledResidual4[n_Integer?Positive, alpha_?NumericQ] :=
  n^4 (gamma[n, alpha] - c2[alpha]/n^2);

Table[
  {n, scaledResidual4[n, alphaExample], c4[alphaExample]},
  {n, 20, 300, 20}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[2885]:=",ExpressionUUID->"ff57b75e-e6f7-4140-8f49-0657eddcfe92"],

