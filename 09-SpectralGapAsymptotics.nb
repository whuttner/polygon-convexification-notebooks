Cell[CellGroupData[{

Cell["5. Leading scaled gap", "Section",ExpressionUUID->"c44e9309-b880-457d-9cc4-92aee48805f2"],

Cell["The leading prediction is", "Text",ExpressionUUID->"02c000e4-d3f7-48d0-8fbc-6f0e39378f59"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["n", "2"], 
   SubscriptBox["\[Gamma]", "n"], 
   RowBox[{"(", "\[Alpha]", ")"}], "\[Rule]", 
   RowBox[{"6", 
    SuperscriptBox["\[Pi]", "2"], "\[Alpha]", 
    RowBox[{"(", 
     RowBox[{"1", "-", "\[Alpha]"}], ")"}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"02a2294c-8d31-4309-\
86e7-94c356f003a7"],

Cell[CellGroupData[{

Cell["\<\
scaledGap2[n_Integer?Positive, alpha_?NumericQ] :=
  n^2 gamma[n, alpha];

Table[
  {n, scaledGap2[n, alphaExample], c2[alphaExample]},
  {n, 20, 300, 20}
] // TableForm\
\>", "Input",
 CellLabel->
  "In[2881]:=",ExpressionUUID->"734794f2-db78-49c3-8562-702f3e5ef142"],

